				</button>

				<div class="frame mx-3">
					<div class="card border-0 mb-3" style="max-width: 540px;">
						<div class="row g-0">
							<div class="col-md-4 align-self-center border col-md-4">
								<img class="w-100" src="~/images/product/pro_01.png" alt="" />
							</div>

							<div class="col-md-8 card-body">
								<div class="card-title">C659NA德瑞克Smart III淨未來智慧馬桶</div>

								<ul class="describe align-items-center justify-content-between">
									<li>描述</li>
									<li>描述</li>
									<li>描述</li>
								</ul>

								<ul class="tag d-flex my-2">
									<li class="rounded-pill">奈米</li>
									<li class="rounded-pill">奈米</li>
									<li class="rounded-pill">奈米</li>
									<li class="rounded-pill">奈米</li>
								</ul>

								<div class="priceframe d-flex flex-wrap ps-3 align-items-center">
									<div class="price text-decoration-line-through me-2">150,000</div>
									<div class="discount d-flex align-items-center">
										折扣&ensp;<span class="fs-4 fw-bold text-danger price">135,000</span>
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="options px-3">
						<div class="radio d-flex align-items-center my-2">
							<div class="title">顏色</div>
							<div class="control d-flex flex-wrap">
								<input id="color_01" type="radio" class="btn-check" name="choose_color" autocomplete="off">
								<label class="btn_radio me-2 my-1 px-3 py-1 align-self-center" for="color_01">白色</label>

								<input id="color_02" type="radio" class="btn-check" name="choose_color" autocomplete="off">
								<label class="btn_radio me-2 my-1 px-3 py-1 align-self-center" for="color_02">灰色</label>
							</div>
						</div>

						<div class="buy_line row d-sm-flex d-block justify-content-evenly align-items-center">
							<div class="counter col-auto d-flex align-items-center my-2">
								<div class="title">數量</div>
								<div class="counter_input d-flex">
									<button class="btn_count_minus bg-white my-1">
										<i class="fa-solid fa-minus"></i>
									</button>

									<input class="input_count text-center my-1" name="counter" value="1">

									<button class="btn_count_plus bg-white my-1">
										<i class="fa-solid fa-plus"></i>
									</button>
								</div>
							</div>

							<div class="btn_buy col d-flex align-items-center justify-content-center text-white" type="button">
								<div class="icon_plus">加入購物車</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

