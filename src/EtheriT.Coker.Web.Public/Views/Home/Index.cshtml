<!-- BannerSwiper -->
<div id="BannerSwiper" class="container-fluid position-relative p-0">
	<div class="swiper">
		<div class="swiper-wrapper">
			<figure class="template_full_swiper swiper-slide mb-0">
				<img class="swiper_image img-fluid" src="~/upload/banner/Home/banner.jpg" alt="" />
				<figcaption class="position-absolute me-5 text-white">
					<h3 class="swiper_title my-1">Derek獨立式浴缸新上市 打造身心專屬舒壓時光</h3>
				</figcaption>
			</figure>
			<figure class="template_full_swiper swiper-slide mb-0">
				<img class="swiper_image img-fluid" src="~/upload/banner/Home/banner02.jpg" alt="" />
				<figcaption class="position-absolute me-5 text-white">
					<h3 class="swiper_title my-1">「淨未來」微電腦馬桶座系列享受瞬熱式潔淨 冬季溫暖就靠它</h3>
				</figcaption>
			</figure>
		</div>
	</div>
	<div class="swiper_button h-100 top-50 start-50 w-100 d-flex justify-content-between position-absolute">
		<button class="btn_swiper_prev_banner fs-3 bg-transparent border-0 fs-3 p-3">
			<i class="fa-solid fa-chevron-left text-white opacity-50"></i>
		</button>
		<button class="btn_swiper_next_banner fs-3 bg-transparent border-0 fs-3 p-3">
			<i class="fa-solid fa-chevron-right text-white opacity-50"></i>
		</button>
	</div>
	<div class="swiper_pagination_banner position-absolute text-center -2"></div>
</div>

<!-- EnterAdModal -->
@if (Model.enterAd.Count > 0)
{
	@foreach (var enterAd in Model.enterAd ?? new List<HtmlContentDisplayDto>())
	{
		var target = enterAd.Target ? "_blank" : "_self";
		<div id="EnterAdModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
				<div class="modal-content">
					<div class="modal-body">
						<button type="button" class="bg-white btn-close end-0 me-3 p-2 position-absolute rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
						<div class="d-flex justify-content-center">
							@if (enterAd.Link != "")
							{
								<a href="@enterAd.Link" target="@target">
									<img class="" src="@enterAd.Img" alt="@enterAd.Title" />
								</a>
							}
							else
							{
								<img class="" src="@enterAd.Img" alt="@enterAd.Title" />
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	}
}

