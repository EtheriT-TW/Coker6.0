@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Article
@using EtheriT.Coker.Application.Shared.Dto.Newsletter;
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal
@{
    ViewData["Title"] = "Newsletter";
}

<link rel="stylesheet" href="~/css/ContentManagement/Article.min.css" asp-append-version="true" />
<link rel="stylesheet" href="/lib/CokerMultiStepForm/css/Style.min.css" asp-append-version="true">
<link rel="stylesheet" href="/css/Grapes/GrapesOutsiteCss.min.css">
@{
    await Html.RenderPartialAsync(@"GrapesComponents\_ScriptComponents");
}
<script src="/lib/bootstrap/iconpicker/js/iconset/google_Material_Symbols_Outlined.min.js" asp-append-version="true"></script>
<script src="/lib/bootstrap/iconpicker/js/bootstrap-iconpicker.min.js" asp-append-version="true"></script>
<script src="/lib/CokerMultiStepForm/js/index.min.js" asp-append-version="true"></script>
<script src="~/js/Newsletter/Index.min.js" asp-append-version="true"></script>
@Html.AntiForgeryToken()
<div id="TopLine" class="py-2 px-4">
    <div class="d-flex">
        <div class="title fw-bold fs-3">電子報管理</div>
        <a class="btn btn-primary text-decoration-none align-self-center d-none" href="#" role="button">返回選單</a>
    </div>
</div>
<div class="">
    <div id="ArticleList" class="card py-2 border-0">
        <div class="card-body position-relative">
            <button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
                <span class="material-symbols-outlined">add</span>
            </button>
            @(
                Html.DevExtreme().DataGrid<ArticleListGetDto>()
                .DataSource(d => d.RemoteController().Key("Id")
                .LoadUrl("/api/Newsletter/GetNewsletters").LoadMethod("Get")
                )
                .HeaderFilter(headerFilter => headerFilter.Visible(true))
                .RemoteOperations(true)
                .ColumnHidingEnabled(true)
                .ShowBorders(true)
                .FilterRow(filterRow => filterRow
                .Visible(true)
                .ApplyFilter(GridApplyFilterMode.Auto)
                )
                .SearchPanel(searchPanel => searchPanel
                .Visible(true)
                .Width(480)
                .Placeholder("請輸入要搜尋的資料")
                )
                .ShowRowLines(true)
                .Columns(c =>
                {
                    c.AddFor(e => e.Id).Caption("編號").Width(90);
                    c.AddFor(e => e.Title).Caption("標題");
                    c.AddFor(e => e.Tags).Caption("標籤").MinWidth(200);
                    c.AddFor(e => e.NodeDate).Caption("發布日期").Width(90);
                    c.AddFor(e => e.StartTime).Caption("起始時間").Width(90).Visible(false);
                    c.AddFor(e => e.EndTime).Caption("結束時間").Width(90).Visible(false);
                    c.AddFor(e => e.permanent).Caption("永久顯示").Width(90);
                    c.AddFor(e => e.SerNO).Caption("排序").Width(90);
                    c.AddFor(e => e.Popular).Caption("人氣值").Width(90);
                    c.AddFor(e => e.PopularVisible).Caption("是否顯示人氣值").Width(150);
                    c.Add()
                    .Type(GridCommandColumnType.Buttons)
                    .Buttons(b =>
                    {
                        b.Add().Name("edit").OnClick("editButtonClicked");
                        b.Add().Icon("palette").Name("edit").OnClick("paletteButtonClicked");
                        b.Add().Icon("email").Name("sand").OnClick("sendButtonClicked");
                        b.Add().Name("delete").OnClick("deleteButtonClicked");
                    });
                })
                .ColumnAutoWidth(true)
                .Paging(paging => paging.PageSize(30))
                .Pager(pager =>
                {
                    pager.Visible(true);
                    pager.ShowPageSizeSelector(true);
                    pager.AllowedPageSizes(new[] { 10, 20, 30 });
                    pager.ShowInfo(true);
                })
                .Editing(editing =>
                {
                    editing.AllowDeleting(true);
                    editing.AllowUpdating(true);
                    editing.UseIcons(true);
                })
                .OnContentReady("contentReady")
                )
        </div>
    </div>

    <div id="ArticleContent" class="card py-2 border-0 d-none">
        <div class="card-header d-flex justify-content-between">
            <div class="fw-bold fs-5 d-flex align-items-center">
                <button class="btn_back d-flex bg-transparent border-0 align-items-center">
                    <span class="material-symbols-outlined">
                        keyboard_backspace
                    </span>
                </button>
                <div class="lh-lg">編輯電子報</div>
            </div>
            <div class="d-flex">
                <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 " form="ArticletForm">儲　存</button>
                <button class="btn_to_canvas btn-success border-0 px-3 py-1 text-white d-flex align-items-center" form="ArticletForm">
                    進階編輯<span class="material-symbols-outlined ms-1">palette</span>
                </button>
            </div>
        </div>

        <form id="ArticletForm" class="card-body form-horizontal msf needs-validation">
            <div class="progress">
                <div class="progress-bar progress-bar-success progress-bar-striped" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width: 0%">
                    <span class="sr-only">0% Complete</span>
                </div>
            </div>
            <div class="msf-header">
                <div class="row text-center">
                    <div class="msf-step col"><span>主要資料</span></div>
                    <div class="msf-step col"><span>主選單</span></div>
                    <div class="msf-step col"><span>內容區1</span></div>
                    <div class="msf-step col"><span>最新消息</span></div>
                    <div class="msf-step col"><span>活動公告</span></div>
                    <div class="msf-step col"><span>內容區2</span></div>
                    <div class="msf-step col"><span>內容區3</span></div>
                    <div class="msf-step col"><span>頁尾資料</span></div>
                </div>
            </div>
            <div class="msf-content">
                <div data-key="main" class="msf-view">
                    <div class="d-flex align-self-center mb-3 justify-content-between flex-wrap-reverse flex-md-nowrap">
                        <div class="d-flex">
                            <div id="LogoImage" class="d-flex justify-content-center image_upload formItem" data-name="Logo" data-issinge="true" data-needcompress="false">
                                @await Component.InvokeAsync(nameof(Modal), new { dispaly = "ImageUploadModal" })
                                <h3>Logo圖<br />(301*207)</h3>
                            </div>
                            <div class="d-flex justify-content-center ms-5 image_upload formItem" data-name="LogoCompress" data-issinge="true" data-needcompress="false">
                                @await Component.InvokeAsync(nameof(Modal), new { dispaly = "ImageUploadTemplateModal" })
                                <h3>email使用Logo<br />(155*96)</h3>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="align-self-center border-0 btn d-flex pb-0 pt-0">
                                <input id="PageVisible" type="checkbox" name="Visible" class="d-none selectedItem formItem" value="false" />
                                <label for="PageVisible" class="bg-transparent border-0 mb-0 text-primary d-flex align-self-center noselect" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
                                    <span class="material-symbols-outlined fs-2">visibility</span>
                                    <span class="material-symbols-outlined fs-2">visibility_off</span>
                                </label>
                            </div>

                            <div class="align-self-center border-0 btn d-flex pb-0 pt-0">
                                <input id="PopularVisible" type="checkbox" name="PopularVisible" class="d-none selectedItem formItem" value="false" />
                                <label for="PopularVisible" class="bg-transparent border-0 mb-0 text-primary d-flex align-self-center noselect" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示人氣值">
                                    <span class="material-symbols-outlined fs-2">group</span>
                                    <span class="material-symbols-outlined fs-2">group_off</span>
                                </label>
                            </div>

                            <div class="align-self-center border-0 btn d-flex pb-0 pt-0">
                                <input id="RemovedFromShelves" type="checkbox" name="RemovedFromShelves" class="d-none selectedItem formItem" value="false" checked />
                                <label for="RemovedFromShelves" class="bg-transparent border-0 mb-0 text-primary d-flex align-self-center noselect" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="上架中">
                                    <span class="material-symbols-outlined fs-2">open_in_new</span>
                                    <span class="material-symbols-outlined fs-2">open_in_new_off</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="title border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">標題</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" aria-label="With textarea" name="Title" maxlength="50" placeholder="輸入文章標題" required></textarea>
                    </div>
                    <div class="no border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">期數</span>
                        </div>
                        <input type="number" class="form-control border-0 formItem" name="No" placeholder="輸入期數" required>
                    </div>
                    <div class="BGColor border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">背景色</span>
                        </div>
                        <input type="text" class="form-control border-0 formItem" name="BGColor" placeholder="輸入背景色" required>
                    </div>
                    <div class="date input-group mb-3">
                        <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                            <span class="material-symbols-outlined me-1">calendar_today</span>發布日期
                        </div>
                        <input id="NodeDate" class="form-control rounded formItem" name="NodeDate" type="text" aria-label="Input Duration of Product" pattern="[1-9]\d{3}/\d{2}/\d{2}" autocomplete="off">
                    </div>

                    <div class="date input-group mb-3">
                        <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                            <span class="material-symbols-outlined me-1 required_sign">calendar_today</span>設定上架日期
                        </div>
                        <input id="InputDate" class="form-control rounded formItem" type="text" aria-label="Input Duration of Product" name="datetimes" pattern="[1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2} ~ [1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2}" autocomplete="off" required>
                        <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
                            <input id="PermanentCheck" class="form-check-input formItem" name="Permanent" type="checkbox" value="">
                            <label class="form-check-label fs-6 pe-2" for="PermanentCheck">永久顯示</label>
                        </div>
                    </div>

                    <div class="describe border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0">描述</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0" aria-label="With textarea formItem" name="Description" maxlength="300" placeholder="輸入文章描述"></textarea>
                    </div>

                    @await Component.InvokeAsync(nameof(Modal), new {dispaly = "TagListModal"})

                    <div class="sort input-group mb-3">
                        <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                            <span class="material-symbols-outlined me-1 required_sign">sort_by_alpha</span>排序
                        </div>
                        <input class="form-control rounded formItem" type="number" name="SerNO" data-default="500" aria-label="Input Sort of Article" disabled="disabled" required>
                        <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
                            <input class="form-check-input formItem" name="permanent" type="checkbox" value="">
                            <label class="form-check-label fs-6 pe-2" for="SortCheck">自訂排序</label>
                        </div>
                    </div>
                </div>
                <div data-key="mainManu" class="msf-view">
                    @(Html.DevExtreme().DataGrid<NewsletterLinkDto>()
                        .ShowBorders(true)
                        .OnContentReady("NewsletterReady")
                        .Paging(paging => paging.Enabled(false))
                        .Editing(editing =>
                        {
                            editing.Mode(GridEditMode.Row);
                            editing.AllowAdding(true);
                            editing.AllowDeleting(true);
                            editing.AllowUpdating(true);
                        }).Columns(c =>
                        {
                            c.AddFor(e => e.title).Caption("標題");
                            c.AddFor(e => e.link).Caption("連結");
                            c.AddFor(e => e.target).Lookup(lookup => lookup
                            .DataSource("getTarget")
                            .DisplayExpr("Name")
                            .ValueExpr("newWindow")
                            ).Caption("另開視窗");
                        }).DataSource(new List<NewsletterLinkDto>())
                        )
                </div>
                <div data-key="conten1" class="msf-view">
                    <div class="d-flex align-self-center mb-3 flex-wrap-reverse flex-md-nowrap">
                        <div id="ImageUpload" class="d-flex justify-content-center image_upload formItem" data-name="image" data-issinge="true" data-needcompress="false">
                            @await Component.InvokeAsync(nameof(Modal), new {dispaly = "ImageUploadTemplateModal"})
