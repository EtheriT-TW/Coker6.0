                        <form id="RegisterForm" class="card-body needs-validation pb-0" method="post">
                            <input type="hidden" name="authentiity_token" value="@ViewData["XSRF-TOKEN"]" />
                            <div class="register_mail input-group mb-3">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">mail</span>
                                </div>
                                <input id="InputRegisterMail" class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input Register Mail" placeholder="信箱" required name="Email">
                            </div>
                            <div class="register_name input-group mb-3">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">account_circle</span>
                                </div>
                                <input id="InputRegisterName" class="input_bg form-control rounded border-0 py-3" type="text" aria-label="Input Register Name" placeholder="姓名/名稱" required name="Name">
                            </div>
                            <div class="register_new_pass input-group">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputRegisterNewPass" class="input_bg form-control rounded border-0 py-3" type="password" autocomplete="off" aria-label="Input Register New Password" placeholder="密碼" required name="Password">
                            </div>
