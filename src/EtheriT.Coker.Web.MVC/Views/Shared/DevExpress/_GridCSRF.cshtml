@Html.AntiForgeryToken()
<script>
     function onBeforeSend(method, ajaxOptions) {
        var token = $(`input[name="AntiforgeryField"]`).val();
        //console.log(token);
        if (token) {
            ajaxOptions.headers = { "x-xsrf-token": token };
        }

        if (method === "delete") {
            var originData = ajaxOptions.data;
            ajaxOptions.data = { 'dataKey': originData.key };
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        let delayTimeout;

        // 用來標記是否正在進行中文輸入
        document.body.addEventListener('compositionstart', (e) => {
            if (isFilterInput(e.target)) {
                e.target.isComposing = true;
            }
        });

        // 完成中文輸入後，觸發過濾
        document.body.addEventListener('compositionend', (e) => {
            if (isFilterInput(e.target)) {
                e.target.isComposing = false;
                triggerFilter(e.target); // 完成輸入後立即過濾
            }
        });

        // 監聽 keydown 事件，處理 Enter 鍵觸發過濾
        document.body.addEventListener('keydown', (e) => {
            const target = e.target;
            if (isFilterInput(target)) {
                // 如果按的是 Enter 鍵，觸發過濾
                if (e.key === "Enter") {
                    triggerFilter(target);
                }
            }
        });

        // 監聽 input 事件，並進行延遲過濾
        document.body.addEventListener('input', (e) => {
            const target = e.target;
            if (isFilterInput(target) && !target.isComposing) {
                e.preventDefault(); // 取消原始 input 事件
                triggerFilterDelayed(target); // 延遲觸發過濾邏輯
            }
        });

        // 判斷是否為過濾輸入框
        function isFilterInput(element) {
            return element.classList.contains('dx-texteditor-input') &&
                element.closest('.dx-datagrid-filter-row'); // 確保是 dxDataGrid filter的範圍
        }

        // 延遲觸發過濾邏輯
        function triggerFilterDelayed(input) {
            clearTimeout(delayTimeout); // 清除上次的延遲觸發
            delayTimeout = setTimeout(() => {
                triggerFilter(input);
            }, 500); // 延遲 500 毫秒後觸發過濾
        }

        // 實際觸發過濾邏輯
        function triggerFilter(input) {
            const value = input.value;
            const gridElement = input.closest('.dx-datagrid').closest('.dx-widget');
            const gridInstance = $(gridElement).dxDataGrid("instance");

            if (gridInstance) {
                const columnIndex = Array.from(input.closest('tr').cells).indexOf(input.closest('td'));
                const columnField = gridInstance.option('columns')[columnIndex].dataField;
                gridInstance.filter([columnField, 'contains', value]);
            }
        }
    });

        // 通案：DevExtreme DataGrid FilterRow 的 IME-safe 自動套用
    function CokerDxGrid_ImeSafeFilterRow(e) {
      if (!e || e.parentType !== "filterRow") return;

      const grid = e.component;
      const eo = e.editorOptions || (e.editorOptions = {});

      // 依 editorType 判斷：selectbox/lookup vs textbox
      // DevExtreme 常見：dxTextBox / dxSelectBox / dxDateBox / dxNumberBox
      const editorType = (e.editorType || "").toLowerCase();

      // ---- A) 下拉（Lookup/SelectBox）：選了就套用，並把「全部」當清除 ----
      if (editorType.includes("selectbox") || editorType.includes("tagbox") || editorType.includes("lookup")) {
        const original = eo.onValueChanged;

        eo.onValueChanged = function (args) {
          if (typeof original === "function") original(args);

          // FilterRow 清除/全部通常會回傳 null / undefined / ""
          const val = args ? args.value : null;

          grid.columnOption(e.dataField, "filterValue",
            (val === null || val === undefined || val === "") ? null : val
          );

          // 因為 GridApplyFilterMode.OnClick，不會自動 apply，所以我們手動 apply
          if (typeof grid.applyFilter === "function") grid.applyFilter();
          else grid.refresh();
        };

        return;
      }

      // ---- B) 文字輸入（TextBox）：IME-safe debounce apply ----
      // 如果你不希望所有文字欄都 auto，可在下面加白名單判斷（我先做通案：全部文字欄生效）
      if (editorType.includes("textbox")) {
        const origInit = eo.onInitialized;
        eo.onInitialized = function (args) {
          if (typeof origInit === "function") origInit(args);

          const input = args && args.element ? $(args.element).find("input").get(0) : null;
          if (!input) return;

          // 避免重複綁定（FilterRow 重建時）
          if (input.__cokerImeBound) return;
          input.__cokerImeBound = true;

          let composing = false;
          let timer = null;

          const apply = () => {
            if (typeof grid.applyFilter === "function") grid.applyFilter();
            else grid.refresh();
          };

          const debounceApply = (ms) => {
            if (timer) clearTimeout(timer);
            timer = setTimeout(() => {
              if (!composing) apply();
            }, ms);
          };

          input.addEventListener("compositionstart", () => { composing = true; });
          input.addEventListener("compositionend", () => {
            composing = false;
            // 中文 commit 後立刻套用（可改 50~100ms）
            debounceApply(0);
          });

          input.addEventListener("input", () => {
            // 組字期間不要 apply，避免 blur 截斷中文
            if (composing) return;

            // 像 Auto：停止輸入一小段時間才查，避免每個字都打 API
            debounceApply(300);
          });
        };

        return;
      }
    }
</script>