@{
}

<link rel="stylesheet" href="~/css/Page/ShoppingCar.min.css" asp-append-version="true" />
<script src="~/js/Page/ShoppingCar.min.js" asp-append-version="true"></script>

<div class="history">
</div>


<form id="BuyStepSwiper" class="container py-4 position-relative">
	<div id="memberLogin" class="container my-5">
		<div class="rounded-1 d-flex align-items-center px-3 py-4 bg-white">
			<div>購買前登入會員可更方便查詢訂單！</div>
			<button class="bg-transparent rounded-1 mx-2">會員登入</button>
		</div>
	</div>

	<div class="swiper shadow-lg">
		<div class="swiper-wrapper">
			<div class="step1 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">購物明細</div>
				</div>

				<div class="card-body">
					<ul>
						<li class="row">
							<div class="col-6 text-start">商品資訊</div>
							<div class="col-2">單價</div>
							<div class="col-2">數量</div>
							<div class="col-2">小計</div>
						</li>

						<li class="row border-bottom border-top py-2 align-items-center">
							<div class="col-sm-6 col-12 text-start d-flex">
								<img src="/images/product/pro_pic_03.jpg">
								<div>
									<div class="fs-5 fw-bold">C613NA 二段省水奈米高背單體馬桶</div>
									<div class="d-flex">
										<div class="pe-3">白色</div>
										<div>規格說明文字</div>
									</div>
								</div>
							</div>
							<div class="unit col-2 price fw-bold fs-5">26,200</div>

							<div class="counter_input col-2 d-flex justify-content-center">
								<button class="btn_count_minus bg-white border-end-0 px-3">
									<i class="fa-solid fa-minus"></i>
								</button>

								<input class="input_count text-center py-2 ps-3" type="number" name="counter" value="1">

								<button class="btn_count_plus bg-white border-start-0 px-3">
									<i class="fa-solid fa-plus"></i>
								</button>
							</div>

							<div class="subtotal col-2 price fw-bold fs-4">26,200</div>
						</li>
					</ul>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							返回購物
						</button>

						<button class="btn_swiper_next_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							下一步
						</button>
					</div>
				</div>
			</div>

			<div class="step2 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">購物明細</div>
				</div>

				<div class="card-body">
					<div>這是區塊二</div>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							返回購物
						</button>

						<button class="btn_swiper_next_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							下一步
						</button>
					</div>
				</div>
			</div>

			<div class="step3 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">購物明細</div>
					<button class="bg-transparent px-4 py-2 text-decoration-underline">我要再選購</button>
				</div>

				<div class="card-body">
					<div>這是區塊三</div>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 text-center text-decoration-underline bg-transparent">
							回上一頁
						</button>

						<button class="border-0 px-4 py-2 mx-3 rounded-3 text-center text-white">
							<div class="fs-2 fw-bold">確認結帳</div>
							<div>進入付款程序</div>
						</button>

						<button class="border-0 text-center text-decoration-underline bg-transparent">
							我要再選購
						</button>
					</div>
				</div>
			</div>

			<div class="step4 swiper-slide">這是不能選的區塊四</div>
		</div>
	</div>

	<div class="swiper_pagination_buystep position-absolute text-center"></div>
</form>
