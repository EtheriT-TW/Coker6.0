@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Article;
@using EtheriT.Coker.Application.Shared.Dto.Directory
@using EtheriT.Coker.Application.Shared.Dto.EnterAd
@using EtheriT.Coker.Application.Shared.Dto.TechnicalCertificate
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal
@using EtheriT.Coker.Web.MVC.Startup
@{
    ViewData["Title"] = "CustomAd";
}

<link rel="stylesheet" href="~/css/AdvertisementManagement/CustomAd.min.css" asp-append-version="true" />
@{
    await Html.RenderPartialAsync(@"GrapesComponents\_ScriptComponents");
}
<script src="~/js/AdvertisementManagement/CustomAd.min.js" asp-append-version="true"></script>
@Html.AntiForgeryToken()
<div class="">
    <div id="TopLine" class="py-2 px-4">
        <div class="d-flex">
            <div class="title fw-bold fs-3">目錄管理</div>
            <a class="btn btn-primary text-decoration-none align-self-center" href="#" role="button">返回選單</a>
        </div>
    </div>
    @await Component.InvokeAsync(nameof(Modal), new { dispaly = "TagSelectModal" })
    <div id="pages">
        <div id="DirectoryList" class="card border-0">
            @await Component.InvokeAsync(nameof(Modal), new { dispaly = "PermissionDetailsModal" })
            <div class="card-body position-relative">
                <button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
                    <span class="material-symbols-outlined">add</span>
                </button>
                @(
                    Html.DevExtreme().DataGrid<DirectoryGetListDto>()
                    .DataSource(d => d.RemoteController().Key("Id")
                    .LoadUrl("/api/Directory/GetAdvertiseList").LoadMethod("Get")
                    )
                    .RemoteOperations(true)
                    .ColumnHidingEnabled(true)
                    .ShowBorders(true)
                    .FilterRow(filterRow => filterRow
                    .Visible(true)
                    .ApplyFilter(GridApplyFilterMode.Auto)
                    )
                    .SearchPanel(searchPanel => searchPanel
                    .Visible(true)
                    .Width(480)
                    .Placeholder("請輸入要搜尋的資料")
                    )
                    .ShowRowLines(true)
                    .Columns(c =>
                    {
                        c.AddFor(e => e.Id).Caption("ID").Width(40).AllowEditing(false);
                        c.AddFor(e => e.Title).Caption("標題");
                        c.AddFor(e => e.Description).Caption("描述");
                        c.AddFor(e => e.Items).Caption("綁定標籤、選單");
                        c.AddFor(e => e.SortBy).Caption("排序方式");
                        c.AddFor(e => e.Visible).Caption("是否顯示").Width(100);
                        c.Add()
                        .Type(GridCommandColumnType.Buttons)
                        .Buttons(b =>
                        {
                            b.Add().Name("edit").Visible(ThePermission.CanUpdate).OnClick("editButtonClicked");
                            b.Add().Icon("verticalaligncenter").Visible(ThePermission.CanVisble).OnClick("reladataButtonClicked");
                            b.Add().Name("delete").Visible(ThePermission.CanRemove).OnClick("deleteButtonClicked");
                        });
                    })
                    .ColumnAutoWidth(true)
                    .Paging(paging => paging.PageSize(30))
                    .Pager(pager =>
                    {
                        pager.Visible(true);
                        pager.ShowPageSizeSelector(true);
                        pager.AllowedPageSizes(new[] { 10, 20, 30 });
                        pager.ShowInfo(true);
                    })
                    .Editing(editing =>
                    {
                        editing.AllowDeleting(true);
                        editing.AllowUpdating(true);
                        editing.UseIcons(true);
                    })
                    .OnContentReady("contentReady")
                    )
            </div>
        </div>
        <div id="DirectoryContent" class="card border-0 d-none">
            <div class="card-header d-flex justify-content-between">
                <div class="fw-bold fs-5 d-flex align-items-center">
                    <button class="btn_back d-flex bg-transparent border-0 align-items-center">
                        <span class="material-symbols-outlined">
                            keyboard_backspace
                        </span>
                    </button>
                    <div class="lh-lg">編輯目錄</div>
                </div>
                <div class="d-flex">
                    <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 " form="DirectoryForm">儲　存</button>
                </div>
            </div>

            <form id="DirectoryForm" class="card-body needs-validation">
                <div class="d-flex align-self-center mb-3 justify-content-between">
                    <div class="sortby col d-flex">
                        <label class="form-label mb-0 pe-3 align-self-center text-nowrap" for="SortBy">排序方式</label>
                        <select id="SortBy" class="form-select" aria-label="Sort Type Select" required>
                            <option selected value="0">預設排序</option>
                            <option value="1">隨機排序</option>
                            <option value="2">人氣值排序</option>
                        </select>
                    </div>
                    <button class="btn_display bg-transparent border-0 text-primary d-flex align-self-center" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
                        <span class="material-symbols-outlined fs-2">visibility</span>
                    </button>
                </div>

                <div class="title border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0 required_all">標題</span>
                        <div class="count">0</div>
                    </div>
                    <textarea class="form-control border-0" aria-label="With textarea" maxlength="60" placeholder="輸入目錄標題" required></textarea>
                </div>

                <div class="description border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0">描述</span>
                        <div class="count">0</div>
                    </div>
                    <textarea class="form-control border-0" aria-label="With textarea" maxlength="150" placeholder="輸入目錄描述"></textarea>
                </div>
                <div class="tag input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_all">alternate_email</span>標籤
                    </div>
                    <input id="InputTag" class="form-control rounded text-start InputTag formItem" name="TagSelected" type="button" aria-label="Input Tag" data-bs-toggle="modal" data-bs-target="#TagModal">
                </div>

            </form>
        </div>

        <div id="DirectoryCanvas" class="card border-0 d-none">
            <div id="gjs"></div>
        </div>

        <div id="DirectoryItemps" class="card border-0 d-none">
            <div class="advertise d-none">
                <div class="card-body position-relative">
                    <div class="d-flex position-absolute z-index-up">
                        <button class="btn_back border btn-outline-light text-black d-flex p-1 rounded text-decoration-none">
                            <span class="material-symbols-outlined">arrow_back</span>
                        </button>
                        <button class="btn_add border btn-outline-light text-black d-flex p-1 rounded text-decoration-none ml-3">
                            <span class="material-symbols-outlined">add</span>
                        </button>
                    </div>
                    @(
                        Html.DevExtreme().DataGrid<DirectoryReleInfoDto>()
                        .DataSource(d => d.RemoteController().Key("Id")
                        .LoadUrl("/api/Directory/GetDirectoryDetailList").LoadMethod("Get")
                        .LoadParams(new
                        {
                            id = new JS("GetDirectoryId"),
                            type = new JS("GetDirectoryType")
                        })
                        )
                        .OnContentReady("DirectoryDatailListReady")
                        .HeaderFilter(headerFilter => headerFilter.Visible(true))
                        .RemoteOperations(true)
                        .ColumnHidingEnabled(true)
                        .ShowBorders(true)
                        .FilterRow(filterRow => filterRow
                        .Visible(true)
                        .ApplyFilter(GridApplyFilterMode.Auto)
                        )
                        .SearchPanel(searchPanel => searchPanel
                        .Visible(true)
                        .Width(480)
                        .Placeholder("請輸入要搜尋的資料")
                        )
                        .ShowRowLines(true)
                        .Columns(c =>
                        {
                            c.AddFor(e => e.Id).Caption("編號").Width(90);
                            c.AddFor(e => e.Title).Caption("標題");
                            c.AddFor(e => e.ExposureTimes).Caption("曝光次數").Width(90);
                            c.AddFor(e => e.ClickTimes).Caption("點擊次數").Width(90);
                            c.AddFor(e => e.StartTime).Caption("起始時間").Width(90).Visible(true);
                            c.AddFor(e => e.EndTime).Caption("結束時間").Width(90).Visible(true);
                            c.AddFor(e => e.SerNo).Caption("排序").Width(90);
                            c.AddFor(e => e.Visible).Caption("顯示").Width(90);
                            c.AddFor(e => e.LastModificationTime).SortOrder(SortOrder.Desc).Format("yyyy/MM/dd HH:mm").Caption("最後編輯日期").Width(160);
                            c.Add()
                            .Type(GridCommandColumnType.Buttons)
                            .Buttons(b =>
                            {
                                b.Add().Name("edit").Visible(ThePermission.CanUpdate).OnClick("editAdvertiseButtonClicked");
                                b.Add().Name("delete").Visible(ThePermission.CanRemove).OnClick("deleteAdvertiseButtonClicked");
                            });
                        })
                        .ColumnAutoWidth(true)
                        .Paging(paging => paging.PageSize(30))
                        .Pager(pager =>
                        {
                            pager.Visible(true);
                            pager.ShowPageSizeSelector(true);
                            pager.AllowedPageSizes(new[] { 10, 20, 30 });
                            pager.ShowInfo(true);
                        })
                        .Editing(editing =>
                        {
                            editing.AllowDeleting(true);
                            editing.AllowUpdating(true);
                            editing.UseIcons(true);
                        })
                        )
                </div>
            </div>
        </div>

        <div id="AdvertiseContent" class="card border-0 d-none">
            <div class="card-header d-flex justify-content-between">
                <div class="fw-bold fs-5 d-flex align-items-center">
                    <button class="btn_back d-flex bg-transparent border-0 align-items-center">
                        <span class="material-symbols-outlined">
                            keyboard_backspace
                        </span>
                    </button>
                    <div class="lh-lg">返回廣告目錄</div>
                </div>
                <div class="d-flex">
                    <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 " form="AdvertiseForm">儲　存</button>
                </div>
            </div>

            <form id="AdvertiseForm" class="card-body needs-validation">
                <input name="id" type="hidden" />
                <input name="fk_websiteId" type="hidden" />
                <div class="flex-nowrap row mb-4">
                    <div class="ad_type col d-flex">
                        <label class="form-label mb-0 pe-3 align-self-center text-nowrap" for="AdType">廣告類型</label>
                        <select id="AdType" class="form-select" aria-label="Advertise Type Select" required>
                            <option selected disabled value="" class="d-none">請選擇</option>
                            <option value="1">圖片</option>
                            <option value="2">影片</option>
                            <option value="3">Youtube影片</option>
                        </select>
                    </div>
                    <input type="checkbox" id="AdvertiseFormVisible" class="selectedItem" name="visible" value="true" checked />
                    <label for="AdvertiseFormVisible" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上" class="col-auto d-flex m-auto p-0">
                        <span class="material-symbols-outlined fs-2">visibility</span>
                        <span class="material-symbols-outlined fs-2">visibility_off</span>
                    </label>
                </div>
                <div class="ad_preview mb-3 d-flex justify-content-center align-items-center" data-fileid="" data-file="">
                    <div class="preview fs-1">預覽</div>
                    <div class="image w-100 h-100 d-none">
                        <div class="d-flex  w-100 h-100">
                            <input class="input_pic d-none flex-grow-0" type="file" accept="image/*" />
                            <button class="btn_input_pic d-flex align-items-center justify-content-center bg-transparent flex-grow-1 border-0 w-100 -100">
                                <span class="material-symbols-outlined">add_photo_alternate</span>
                                <img class="img_preview d-none" src="" />
                            </button>
                        </div>
                    </div>
                    <div class="video w-100 h-100 d-none">
                        <div class="align-items-center d-flex flex-column h-100 w-100">
                            <input class="input_video d-none flex-grow-0" type="file" accept="video/*" />
                            <video class="flex-grow-1 mt-2 video_preview" controls></video>
                            <button class="btn_input_video bg-transparent border-0 d-flex justify-content-center my-2">點擊上傳影片</button>
                        </div>
                    </div>
                    <div class="youtube w-100 h-100 d-none">
                        <iframe src="" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen class="w-100 h-100"></iframe>
                    </div>
                </div>
                <div class="ad_link input-group mb-3 d-none">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">link</span>連結網址
                    </div>
                    <input type="text" class="form-control rounded" placeholder="輸入連結網址" aria-label="Recipient's username" aria-describedby="button-addon2" name="Link">
                    <button class="btn_preview btn btn-outline-secondary px-3 rounded-right d-none" type="button" id="button-addon2">影片預覽</button>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up d-none mr-4">
                        <input id="TargetCheck" class="form-check-input" type="checkbox" value="true" name="Target">
                        <label class="form-check-label fs-6 pe-2" for="TargetCheck">開新視窗</label>
                    </div>
                </div>

                <div class="title input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">title</span>廣告標題
                    </div>
                    <input name="title" id="InputTitle" class="form-control rounded" type="text" aria-label="Input Title of Advertise" autocomplete="off" required placeholder="輸入廣告標題">
                </div>
                <div class="describe border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0">廣告描述</span>
                        <div class="count">0</div>
                    </div>
                    <textarea class="form-control border-0" aria-label="With textarea" maxlength="150" placeholder="輸入文章描述" name="describe"></textarea>
                </div>
                <div class="date input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">calendar_today</span>設定上架日期
                    </div>
                    <input id="InputDate" name="startEndDate" data-form-type="date_range" data-start="startTime" data-end="endTime" class="form-control rounded" type="text" aria-label="Input Duration of Product" name="datetimes" pattern="[1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2} ~ [1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2}" autocomplete="off" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up mr-4">
                        <input id="PermanentCheck" name="permanent" data-form-type="disabled" data-target="InputDate" class="form-check-input" type="checkbox" checked value="true">
                        <label class="form-check-label fs-6 pe-2" for="PermanentCheck">永久顯示</label>
                    </div>
                </div>
                <div class="tag input-group mb-3" name="tagSelected" data-form-type="tags">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">alternate_email</span>標籤
                    </div>
                    <input class="form-control rounded text-start InputTag" name="tagDatas" type="button" aria-label="Input Tag" data-bs-toggle="modal" data-bs-target="#TagModal">
                </div>
                <div class="sort input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">sort_by_alpha</span>排序
                    </div>
                    <input id="AdvertiseSerNO" class="form-control rounded" name="serNO" type="number" aria-label="Input Sort of Advertise" disabled="disabled" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up mr-4">
                        <input id="AdvertiseSortCheck" class="form-check-input" name="sortCheckbox" data-form-type="disabled" data-direct="reverse" data-value="500" data-target="AdvertiseSerNO" type="checkbox" value="false">
                        <label class="form-check-label fs-6 pe-2" for="AdvertiseSortCheck">自訂排序</label>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
