@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Remote
@{
    ViewData["Title"] = "Remote";
}
<div class="py-2 px-4 position-relative">
	<div id="TopLine" class="d-flex justify-content-between mb-4">
		<div class="d-flex">
			<button class="btn_back bg-transparent border-0 align-items-center d-none">
				<span class="material-symbols-outlined">
					keyboard_backspace
				</span>
			</button>
			<div class="title fw-bold fs-4">頁面瀏覽數量</div>
		</div>
	</div>
	<div id="AuditLogList" class="card border-0">
		<div class="card-body position-relative pb-5">
			@(
				Html.DevExtreme().DataGrid<RemoteListOtputDto>()
				.DataSource(d => d.RemoteController()
				.LoadUrl("/api/Remote/GetAllList").LoadMethod("Get")
				)
				.RemoteOperations(true)
				.ColumnHidingEnabled(true)
				.ShowBorders(true)
				.FilterRow(filterRow => filterRow
				.Visible(true)
				.ApplyFilter(GridApplyFilterMode.Auto)
				)
				.SearchPanel(searchPanel => searchPanel
				.Visible(true)
				.Width(480)
				.Placeholder("請輸入要搜尋的資料")
				)
				.ShowRowLines(true)
				.Columns(c =>
				{
					c.AddFor(e => e.type).Caption("類別");
					c.AddFor(e => e.name).Caption("頁面名稱");
					c.AddFor(e => e.date).Caption("日期");
					c.AddFor(e => e.count).Caption("人次");
				})
				.ColumnAutoWidth(true)
				.Paging(paging => paging.PageSize(30))
				.Pager(pager =>
				{
					pager.Visible(true);
					pager.ShowPageSizeSelector(true);
					pager.AllowedPageSizes(new[] { 10, 20, 30 });
					pager.ShowInfo(true);
				})
				)
		</div>
	</div>
</div>