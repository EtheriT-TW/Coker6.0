                        </div>
                        <div class="d-flex justify-content-center image_upload formItem" data-name="imageCompress" data-issinge="true" data-needcompress="false">
                            @await Component.InvokeAsync(nameof(Modal), new { dispaly = "ImageUploadTemplateModal" })
                            <h3>email使用圖片<br/>(800*416)</h3>
                        </div>
                    </div>
                    <div class="title border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">標題</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" aria-label="With textarea" name="Title" maxlength="50" placeholder="請輸入標題" required></textarea>
                    </div>
                    <div class="conten border mb-3 p-2 rounded">
                        <span class="input-group-text bg-transparent border-0 p-0 mb-3 required_all">內文描述</span>
                        <textarea class="form-control border-0 text h300 formItem" aria-label="With textarea" name="Conten" placeholder="請輸入內文" required></textarea>
                    </div>
                    <div class="more border mb-3 p-2 rounded formItem" data-name="More" data-type="object">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">查看更多</span>
                        </div>
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control item-menu formItem" id="conten1LinkMoreTitle" name="title" placeholder="請輸入連結文字">
                            <label for="conten1LinkMoreTitle">連結文字</label>
                        </div>
                        <div class="input-group">
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control item-menu formItem" id="conten1LinkMoreUrl" name="link" placeholder="請輸入連結">
                                <label for="conten1LinkMoreUrl">連結</label>
                            </div>
                            <div class="btn btn-outline-secondary">
                                <input id="conten1LinkMoreTarget" type="checkbox" name="target" class="d-none selectedItem visibe formItem" value="true" />
                                <label for="conten1LinkMoreTarget" class="bg-transparent border-0 text-primary d-flex align-self-center noselect" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否另開視窗">
                                    <span class="material-symbols-outlined">open_in_new</span>
                                    <span class="material-symbols-outlined">open_in_new_off</span>
                                </label>
                            </div>
                        </div>
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control item-menu formItem" id="conten1LinkMoreAlert" name="alert" placeholder="請輸入連結提示文字">
                            <label for="conten1LinkMoreAlert">連結提示文字</label>
                        </div>
                    </div>
                </div>
