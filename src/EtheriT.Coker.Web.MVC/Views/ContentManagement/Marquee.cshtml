@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Marquee
@using EtheriT.Coker.Core.Models

@{
	ViewData["Title"] = "Marquee";
}

<link rel="stylesheet" href="~/css/ContentManagement/Marquee.min.css" asp-append-version="true" />
<script src="~/js/ContentManagement/Marquee.min.js" asp-append-version="true"></script>

<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-3 px-4">
		<div class="title fw-bold fs-3">跑馬燈訊息</div>
	</div>

	<div id="" class="py-2">
		<div id="MarqueeList" class="card border-0">
			<div class="card-body position-relative">
				<button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
					<span class="material-symbols-outlined">add</span>
				</button>
				@(
					Html.DevExtreme().DataGrid<MarqueeGetDto>()
					.DataSource(d => d.RemoteController().Key("Id")
					.LoadUrl("/api/Marquee/GetAll").LoadMethod("Get")
					.DeleteUrl("/api/Marquee/Delete").DeleteMethod("Delete")
					.UpdateUrl("/api/Marquee/Update").UpdateMethod("Post")
					)
					.ColumnHidingEnabled(true)
					.ShowBorders(true)
					.FilterRow(filterRow => filterRow
					.Visible(true)
					.ApplyFilter(GridApplyFilterMode.Auto)
					)
					.SearchPanel(searchPanel => searchPanel
					.Visible(true)
					.Width(480)
					.Placeholder("請輸入要搜尋的資料")
					)
					.ShowRowLines(true)
					.Columns(c =>
					{
						c.AddFor(e => e.Id).Caption("編號").Width(50);
						c.AddFor(e => e.title).Caption("內文");
						c.AddFor(e => e.disp_opt).Caption("是否顯示").Width(90);
						c.AddFor(e => e.placement).Caption("顯示位置").Width(90);
						c.AddFor(e => e.ser_no).Caption("排序").Width(50);
						c.AddFor(e => e.link).Caption("網址");
						c.AddFor(e => e.target).Caption("另開視窗").Width(90);
						c.AddFor(e => e.StartTime).Caption("起始日期");
						c.AddFor(e => e.EndTime).Caption("結束日期");
						c.AddFor(e => e.permanent).Caption("永久顯示").Width(90);
						c.Add()
						.Type(GridCommandColumnType.Buttons)
						.Buttons(b =>
						{
							b.Add().Name("edit").OnClick("editButtonClicked");
							b.Add().Name("delete").OnClick("deleteButtonClicked");
						});
					})
					.ColumnAutoWidth(true)
					.Paging(paging => paging.PageSize(30))
					.Pager(pager =>
					{
						pager.Visible(true);
						pager.ShowPageSizeSelector(true);
						pager.AllowedPageSizes(new[] { 10, 20, 30 });
						pager.ShowInfo(true);
					})
					.Editing(editing =>
					{
						editing.AllowDeleting(true);
						editing.AllowUpdating(true);
						editing.UseIcons(true);
					})
					.OnContentReady("contentReady")
					)
			</div>
		</div>

		<div id="MarqueeContent" class="card border-0 d-none">
			<div class="card-header d-flex justify-content-between">
				<div class="fw-bold fs-5 d-flex align-items-center">
					<button class="btn_back d-flex bg-transparent border-0 align-items-center">
						<span class="material-symbols-outlined">
							keyboard_backspace
						</span>
					</button>
					<div class="lh-lg">建立貼文</div>
				</div>
				<div class="d-flex">
					<button class="btn_save btn-warning border-0 px-3 py-1 text-white mx-3" form="none">草稿</button>
					<button class="btn_done btn-primary border-0 px-3 py-1 text-white" form="PostForm">發布</button>
				</div>
			</div>

			<form id="PostForm" class="card-body needs-validation">
				<div class="d-flex align-self-center justify-content-between mb-3">
					<div class="placement d-flex">
						<label class="form-label mb-0 pe-3 align-self-center" for="Placement">刊登位置</label>
						<select id="Placement" class="form-select" aria-label="Placement Select" required>
							<option selected value="Top">頁首</option>
							<option value="Inner">內頁</option>
						</select>
					</div>
					<button id="Btn_Display" class="bg-transparent border-0 text-primary d-flex align-self-center" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
						<span class="material-symbols-outlined fs-2">visibility</span>
					</button>
				</div>

				<div class="title border mb-3 p-2 rounded">
					<div class="d-flex justify-content-between w-100">
						<span class="input-group-text bg-transparent border-0 p-0">跑馬燈訊息</span>
						<div class="title_count">0</div>
					</div>
					<textarea id="InputTitle" class="form-control border-0" aria-label="With textarea" maxlength="60" placeholder="輸入跑馬燈內文" required></textarea>
				</div>

				<div class="sort input-group mb-3">
					<div class="position-absolute ps-2 top-50 translate-middle-y z-index-up"><i class="fa-solid fa-arrow-up-wide-short pe-2"></i>排序</div>
					<input id="InputSort" class="form-control rounded" type="number" aria-label="Input Sort of Marquee" disabled="disabled" required>
					<div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
						<input id="SortCheck" class="form-check-input" type="checkbox" value="">
						<label class="form-check-label fs-6 pe-2" for="SortCheck">自訂排序</label>
					</div>
				</div>

				<div class="link input-group mb-3">
					<div class="position-absolute ps-2 top-50 translate-middle-y z-index-up"><i class="fa-solid fa-link pe-2"></i></div>
					<input id="InputLink" class="form-control rounded" type="text" aria-label="Input Link of Marquee" value="https://" required>
					<div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
						<input id="TargetCheck" class="form-check-input" type="checkbox" value="">
						<label class="form-check-label fs-6 pe-2" for="TargetCheck">開新視窗</label>
					</div>
				</div>

				<div class="date input-group mb-3">
					<div class="position-absolute ps-2 top-50 translate-middle-y z-index-up"><i class="fa-regular fa-calendar pe-2"></i>調整顯示日期</div>
					<input id="InputDate" class="form-control rounded" type="text" aria-label="Input Duration of Marquee" name="datetimes" pattern="[1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2} ~ [1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2}" autocomplete="off" required>
					<div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
						<input id="PermanentCheck" class="form-check-input" type="checkbox" value="">
						<label class="form-check-label fs-6 pe-2" for="PermanentCheck">永久顯示</label>
					</div>
				</div>
			</form>
		</div>

		<div class="text-end my-2">※前台最多僅顯示十筆資料</div>
	</div>
</div>