                    </div>
                    <div class="modal-body">
                        <div class="text-center fs-4 fw-bold">@L.get("ResetPasswordTitle")</div>
                        <div class="px-3 pt-2">@L.get("PasswordRuleHint")</div>
                        <form id="ResetForm" class="card-body needs-validation" method="post">
                            <input type="hidden" name="authentiity_token" value="@ViewData["XSRF-TOKEN"]" />
                            <div class="reset_old_pass input-group d-none">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputResetOldPass" class="input_bg form-control rounded border-0 py-3 pass" type="password" autocomplete="off" aria-label="Input Old Password" placeholder="@L.get("OldPassword")" required name="OldPassword" disabled>
                                <div class="position-absolute pe-3 end-0 top-50 d-flex translate-middle-y fs-4">
                                    <button class="btn_passtoggle material-symbols-outlined text-black-50 bg-transparent border-0 px-0" title="@L.get("ShowPassword")">visibility_off</button>
                                </div>
                            </div>
                            <div id="ResetOldPassFeedBack" class="lh-1 text-danger pt-1 d-none">　</div>
                            <div class="reset_new_pass input-group">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputResetNewPass" class="input_bg form-control rounded border-0 py-3 pass" type="password" autocomplete="off" aria-label="Input Reset New Password" placeholder="@L.get("Password")" required name="Password">
                                <div class="position-absolute pe-3 end-0 top-50 d-flex translate-middle-y fs-4">
                                    <button class="btn_passtoggle material-symbols-outlined text-black-50 bg-transparent border-0 px-0" title="@L.get("ShowPassword")">visibility_off</button>
                                </div>
                            </div>
                            <div id="ResetNewPassFeedBack" class="lh-1 text-danger pt-1">　</div>
                            <div class="reset_check_pass input-group">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputResetCheckPass" class="input_bg form-control rounded border-0 py-3 pass" type="password" autocomplete="off" aria-label="Input Reset Check Password" placeholder="@L.get("ConfirmPassword")" required name="PasswordConfirm">
                                <div class="position-absolute pe-3 end-0 top-50 d-flex translate-middle-y fs-4">
                                    <button class="btn_passtoggle material-symbols-outlined text-black-50 bg-transparent border-0 px-0" title="@L.get("ShowPassword")">visibility_off</button>
                                </div>
                            </div>
                            <div id="ResetCheckPassFeedBack" class="lh-1 text-danger pt-1">　</div>
                            <div class="reset_vcode input-group">
                                <input id="InputResetVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Reset Verification Code" placeholder="@L.get("VerificationCode")" maxlength="4" autocomplete="off" required>
                                <div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
                                    <img id="ResetImgCaptcha" alt="@L.get("Captcha")" class="img-fluid" src="" />
                                </div>
                            </div>
                        </form>
                        <div class="px-3 d-flex justify-content-end">
                            <button class="btn_refresh border-0 bg-transparent text-black-50">@L.get("RefreshVerificationCode")</button>
                        </div>
                        <button class="btn_reset w-100 rounded border-0 text-white py-2 fs-5 my-3">@L.get("Reset")</button>
                        <button class="btn_resetforget bg-transparent border-0 text-decoration-underline text-black-50 w-100 d-none">@L.get("ForgotPassword")?</button>
                    </div>
                </div>
            </div>
        </div>
        <div id="ForgetModal" class="modal fade" aria-hidden="true" aria-labelledby="ForgetModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered justify-content-center">
                <div class="modal-content">
                    <div class="modal-header border-0">
                        <button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="text-center fs-4 fw-bold">@L.get("ForgotPassword")</div>
                        <form id="ForgetForm" class="card-body needs-validation" method="post">
                            <input type="hidden" name="authentiity_token" value="@ViewData["XSRF-TOKEN"]" />
                            <div class="forget_mail input-group mb-3">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">mail</span>
                                </div>
                                <input id="InputForgetMail" class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input Forget Mail" placeholder="@L.get("Email")" required name="Email">
                            </div>
                            <div class="forget_vcode input-group">
                                <input id="InputForgetVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Forget Verification Code" placeholder="@L.get("VerificationCode")" maxlength="4" autocomplete="off" required>
                                <div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
                                    <img id="ForgetImgCaptcha" alt="@L.get("Captcha")" class="img-fluid" src="" />
                                </div>
                            </div>
                        </form>
                        <div class="d-flex justify-content-end px-3">
                            <button class="btn_backlogin border-0 bg-transparent text-end text-black-50 me-1">@L.get("BackToLogin")</button>
                            <button class="btn_refresh border-0 bg-transparent text-black-50">@L.get("RefreshVerificationCode")</button>
                        </div>
                        <button class="btn_forget w-100 rounded border-0 text-white py-2 fs-5 my-3">@L.get("Send")</button>
                    </div>
                </div>
            </div>
        </div>
        <div id="Cookie" class="cookie position-fixed text-white w-100 bottom-0 justify-content-center align-items-center">
            <p class="cookie_text my-3 pe-3">@L.get("cookieDeclare")</p>
            <div id="Cookie_button">
                <div class="btn_cookie_accept m-2 p-1 px-4 rounded-2 text-center">@L.get("accept")</div>
                <div class="btn_cookie_reject m-2 p-1 px-4 rounded-2 text-center">@L.get("reject")</div>
            </div>
        </div>
        @if (ViewBag.option != "product")
        {
            <div id="ShoppingCarModal" class="modal fade" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
                @await Component.InvokeAsync(nameof(Modal), new { dispaly = "ShoppingCarModal" })
            </div>
        }
    }
    <div id="videoModal" tabindex="-1" aria-labelledby="videoModal" aria-hidden="true" class="modal fade">
        <div class="modal-dialog modal-xl modal-dialog-centered h-75">
            <div class="modal-content bg-black h-100">
                <div class="modal-header">
                    <button type="button" data-bs-dismiss="modal" aria-label="Close" class="btn-close rounded-circle bg-light"></button>
                </div>
                <div class="modal-body h-100 text-white text-center m-5">
                    <i class="fa fa-duotone fa-spinner fa-spin-pulse fa-10x"></i>
                    <div class="fa-3x massage d-none">影片連結設定錯誤</div>
                </div>
            </div>
        </div>
    </div>
    <div id="SwiperModal" tabindex="-1" aria-labelledby="videoModal" aria-hidden="true" class="modal fade">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-fullscreen">
            <div class="modal-content bg-black h-100">
                <div b-6jkwzezpeq="" class="justify-content-center modal-header position-relative py-2">
                    <div class="imgalt fs-4 text-white"></div>
                    <button b-6jkwzezpeq="" type="button" data-bs-dismiss="modal" aria-label="Close" class="bg-light btn-close end-0 mx-2 position-absolute rounded-circle"></button>
                </div>
                <div class="modal-body">
                    <div id="pictureSwiper" class="swiper pb-2">
                        <div class="swiper-button-prev rounded-circle"></div>
                        <div class="swiper-wrapper"></div>
                        <div class="swiper-button-next rounded-circle"></div>
                    </div>
                    <div id="pictureSwiperThumbs" thumbsSlider="" class="swiper pt-2">
                        <div class="swiper-wrapper"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="FlipBookModal" tabindex="-1" aria-labelledby="FlipBookModalLabel" aria-hidden="true" class="modal fade FlipBookModal">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" aria-label="Close" data-bs-dismiss="modal" id="idmmf" class="btn-close"></button>
                </div>
