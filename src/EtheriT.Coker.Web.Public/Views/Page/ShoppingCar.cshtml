<link rel="stylesheet" href="~/css/Page/ShoppingCar.min.css" asp-append-version="true" />
<script src="~/js/Page/ShoppingCar.min.js" asp-append-version="true"></script>

<div class="history container my-4 d-flex flex-wrap justify-content-center justify-content-md-end">
	<a class="bg-white text-center m-1 py-2" href="/Favorites">
		<div>收藏商品<span class="fw-bold">20</span>件</div>
	</a>
	<a href="" class="bg-white text-center m-1 py-2">
		<div>買過商品<span class="fw-bold">3</span>件</div>
	</a>
</div>


<div id="BuyStepSwiper" class="container pt-5 pb-4 position-relative">
	<div id="memberLogin" class="container my-5">
		<div class="rounded-1 px-3 py-4 bg-white d-flex align-items-center justify-content-center justify-content-sm-start">
			<div>購買前登入會員可更方便查詢訂單！</div>
			<button class="bg-transparent rounded-1 ms-0 ms-sm-3">會員登入</button>
		</div>
	</div>

	<div class="swiper shadow-lg">
		<div class="swiper-wrapper">
			<div class="step1 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">購物明細</div>
				</div>

				<div class="card-body pt-5">
					<div class="row pe-4 d-none d-lg-flex">
						<div class="col-6 text-start">商品資訊</div>
						<div class="col-2">單價</div>
						<div class="col-2">數量</div>
						<div class="col-2">小計</div>
					</div>

					<ul class="purchase_list pb-4">
						<li class="row border-bottom border-top py-2 align-items-lg-center position-relative">
							<div class="col-auto col-lg-6 text-start px-sm-2 d-flex">
								<img src="/images/product/pro_pic_03.jpg">
								<div class="d-lg-block d-none overflow-hidden">
									<div class="pro_name fw-bold">C613NA 二段省水奈米高背單體馬桶</div>
									<div class="d-flex flex-wrap">
										<div class="pe-3">白色</div>
										<div>規格說明文字</div>
									</div>
								</div>
							</div>

							<div class="content col col-lg-6 row align-items-lg-center overflow-hidden ps-0">
								<div class="d-lg-none d-block text-start pe-5 pe-sm-0">
									<div class="pro_name fw-bold">C613NA 二段省水奈米高背單體馬桶</div>
									<div class="pro-detail d-flex flex-wrap">
										<div class="pe-3">白色</div>
										<div class="specifications">規格說明文字</div>
									</div>
								</div>

								<div class="unit price col-12 col-lg-4 mt-3 mt-lg-0 fw-bold align-self-center text-end text-lg-center" data-unittotal="26200">26,200</div>

								<div class="counter_input col-12 col-lg-4 d-flex justify-content-end justify-content-lg-center">
									<button class="btn_count_minus bg-white border-end-0">
										<i class="fa-solid fa-minus"></i>
									</button>

									<input class="input_count text-center py-1" type="number" name="counter" value="1">

									<button class="btn_count_plus bg-white border-start-0">
										<i class="fa-solid fa-plus"></i>
									</button>
								</div>

								<div class="subtotal col-4 price fw-bold fs-5 d-lg-block d-none"></div>
							</div>

							<div class="btn_side_icon position-absolute d-flex flex-column end-0 p-2">
								<span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="移到收藏">
									<button class="btn_move_to_favorites bg-transparent border-0">
										<i class="fa-regular fa-heart"></i>
									</button>
								</span>
								<span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="移除商品">
									<button class="btn_remove_pro bg-transparent border-0">
										<i class="fa-solid fa-xmark"></i>
									</button>
								</span>
							</div>
						</li>
					</ul>

					<div class="endline pe-sm-5 col-12 col-md-6 offset-md-6">
						<div class="border-bottom py-2 d-flex justify-content-end text-end">
							<div>商品金額</div>
							<div id="Totalprice" class="price"></div>
						</div>
						<div class="py-2 d-flex justify-content-end text-end">
							<div>小計</div>
							<div id="Subtotal" class="price"></div>
						</div>
					</div>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							返回購物
						</button>

						<button class="btn_swiper_next_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							下一步
						</button>
					</div>
				</div>
			</div>

			<div class="step2 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">運送方式</div>
				</div>

				<div class="card-body px-0">
					<ul class="px-5 mb-3 transport">
						<li class="d-flex">
							<div class="form-check w-50 text-start">
								<input class="form-check-input" type="radio" name="TransportRadio" id="FreeTrans">
								<label class="form-check-label" for="FreeTrans">
									免運
								</label>
							</div>
							<div class="w-50">免運<span>(您已符合免運條件)</span></div>
						</li>
					</ul>

					<div class="title px-3 py-2 d-flex align-items-center justify-content-between">
						<div class="fs-5 my-2">付款方式</div>
					</div>

					<ul class="px-5 text-start py-4 border-bottom mb-4">
						<li class="form-check py-2">
							<input class="form-check-input" type="radio" name="PaymentRadio" id="ATMPayment">
							<label class="form-check-label" for="ATMPayment">
								ATM
							</label>
						</li>
						<li class="form-check py-2">
							<input class="form-check-input" type="radio" name="PaymentRadio" id="CardPayment">
							<label class="form-check-label" for="CardPayment">
								線上刷卡
							</label>
						</li>
						<li class="form-check py-2">
							<input class="form-check-input" type="radio" name="PaymentRadio" id="LINEPayment">
							<label class="form-check-label" for="LINEPayment">
								LINE Pay
							</label>
						</li>
					</ul>

					<div class="endline px-3 pe-sm-5 col-12 col-md-6 offset-md-6">
						<div class="py-2 d-flex justify-content-end text-end">
							<div>商品金額</div>
							<div id="EndTotalprice" class="price"></div>
						</div>
						<div class="py-2 d-flex justify-content-end text-end">
							<div>運費</div>
							<div id="Freight" class="price" data-freight="0"></div>
						</div>
						<div class="py-2 border-top d-flex justify-content-end text-end">
							<div>小計</div>
							<div id="EndSubtotal" class="price"></div>
						</div>
					</div>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							返回上一頁
						</button>

						<button class="btn_swiper_next_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
							下一步
						</button>
					</div>
				</div>
			</div>

			<div class="step3 card text-center swiper-slide">
				<div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
					<div class="fs-5 my-2">購物明細</div>
					<button class="bg-transparent px-4 py-2 text-decoration-underline">我要再選購</button>
				</div>


				<div class="card-body px-0">
					<div class="record container d-flex align-items-center justify-content-center justify-content-sm-end">
						<div>本次消費總金額：</div>
						<div id="TotalSpend" class="totalprice fw-bold fs-5 price"></div>
						<button class="btn_gofirst bg-transparent ms-4 px-2 px-sm-4 py-1 py-sm-2 text-decoration-underline">返回查看商品明細</button>
					</div>

					<div class="orderer">
						<div class="title px-3 py-2 my-3 d-flex align-items-center">
							<div class="fs-5">訂購人資料</div>
							<button class="btn_edit_data bg-transparent border-0 fs-3 ms-1">
								<i class="fa-regular fa-pen-to-square"></i>
							</button>
						</div>

						<form class="content text-start my-4 p-sm-0 px-4">
							<div class="mb-2 row align-items-center">
								<label for="InputName" class="col-auto col-sm-2 col-form-label text-end">姓　名：</label>
								<div class="col col-sm-10 show">姓名</div>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputName" placeholder="請輸入真實中文姓名">
								</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputMail" class="col-auto  col-sm-2 col-form-label text-end">E-mail：</label>
								<div class="col col-sm-10 show">郵箱</div>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputName">
								</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputCellPhone" class="col-auto col-sm-2 col-form-label text-end">手機號碼：</label>
								<div class="col col-sm-10 show">手機號碼</div>
								<div class="col-sm-4 phone justify-content-between align-items-center">
									<div class="col-3 col-sm phone_front">
										<input type="number" class="phone_front form-control" id="InputCellPhoneFront">
									</div>
									<div>-</div>
									<div class="col phone_back">
										<input type="number" class="phone_back form-control" id="InputCellPhoneBack">
									</div>
								</div>
								<div class="col example">(例如：0900-123456)</div>
							</div>

							<div class="mb-2 row align-items-center contact_phone">
								<label for="InputPhone" class="col-auto col-sm-2 col-form-label text-end">聯絡電話：</label>
								<div class="col col-sm-10 show">電話號碼</div>
								<div class="col-sm-4 phone justify-content-between align-items-center">
									<div class="col-3 col-sm phone_front">
										<input type="number" class="phone_front form-control" id="InputPhoneFront">
									</div>
									<div>-</div>
									<div class="col phone_back">
										<input type="number" class="phone_back form-control" id="InputPhoneBack">
									</div>
								</div>
								<div class="col-auto text-center mt-2 mt-sm-0">分機</div>
								<div class="col-auto ext">
									<input type="number" class="form-control text-center px-2 mt-2 mt-sm-0" id="InputExt">
								</div>
								<div class="col example mt-2 mt-sm-0">(例如：0900-123456)</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputAddress" class="col-auto col-sm-2 col-form-label text-end">地　　址：</label>
								<div class="col col-sm-10 show">地址</div>
								<div class="col-sm-2">
									<input type="text" class="form-control" aria-label="State" placeholder="請選擇縣市">
								</div>
								<div class="col-sm-2 my-2 my-sm-0">
									<input type="text" class="form-control" aria-label="City" placeholder="請選擇鄉鎮">
								</div>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputAddress">
								</div>
							</div>
						</form>
					</div>

					<div class="recipient">
						<div class="title px-3 py-2 my-3 d-flex align-items-center">
							<div class="fs-5">收件人資料</div>
							<ul class="d-sm-flex text-start">
								<li class="form-check mb-0 ms-3">
									<input class="form-check-input" type="radio" name="RecipientRadio" id="SameData">
									<label class="form-check-label" for="SameData">同訂購人資訊</label>
								</li>
								<li class="form-check mb-0 ms-3">
									<input class="form-check-input" type="radio" name="RecipientRadio" id="EditData">
									<label class="form-check-label" for="EditData">修改收件人資料</label>
								</li>
							</ul>
						</div>

						<form class="content text-start my-4 p-sm-0 px-4">
							<div class="mb-2 row align-items-center">
								<label for="InputName" class="col-auto col-sm-2 col-form-label text-end">姓　　名：</label>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputName" placeholder="請輸入真實中文姓名">
								</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputCellPhone" class="col-auto col-sm-2 col-form-label text-end">手機號碼：</label>
								<div class="col-sm-4 phone justify-content-between align-items-center">
									<div class="col-3 col-sm phone_front">
										<input type="number" class="phone_front form-control" id="InputCellPhoneFront">
									</div>
									<div>-</div>
									<div class="col phone_back">
										<input type="number" class="phone_back form-control" id="InputCellPhoneBack">
									</div>
								</div>
								<div class="col example">(例如：0900-123456)</div>
							</div>

							<div class="mb-2 row align-items-center contact_phone">
								<label for="InputPhone" class="col-auto col-sm-2 col-form-label text-end">聯絡電話：</label>
								<div class="col-sm-4 phone justify-content-between align-items-center">
									<div class="col-3 col-sm phone_front">
										<input type="number" class="phone_front form-control" id="InputPhoneFront">
									</div>
									<div>-</div>
									<div class="col phone_back">
										<input type="number" class="phone_back form-control" id="InputPhoneBack">
									</div>
								</div>
								<div class="col-auto text-center mt-2 mt-sm-0">分機</div>
								<div class="col-auto ext">
									<input type="number" class="form-control text-center px-2 mt-2 mt-sm-0" id="InputExt">
								</div>
								<div class="col example mt-2 mt-sm-0">(例如：0900-123456)</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputAddress" class="col-auto col-sm-2 col-form-label text-end">地　　址：</label>
								<div class="col-sm-2">
									<input type="text" class="form-control" aria-label="State" placeholder="請選擇縣市">
								</div>
								<div class="col-sm-2 my-2 my-sm-0">
									<input type="text" class="form-control" aria-label="City" placeholder="請選擇鄉鎮">
								</div>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputAddress">
								</div>
							</div>

							<div class="row">
								<label for="InputNotes" class="col-auto col-sm-2 col-form-label text-end">備　　註：</label>
								<div class="col-sm-9">
									<textarea class="form-control" id="InputNotes" rows="3"></textarea>
								</div>
							</div>
						</form>
					</div>

					<div class="bill">
						<div class="title px-3 py-2 my-3 d-flex align-items-center">
							<div class="fs-5">發票與寄送</div>
							<ul class="d-sm-flex text-start">
								<li class="form-check mb-0 ms-3">
									<input class="form-check-input" type="radio" name="BillRadio" id="SameAsOrderer">
									<label class="form-check-label" for="SameAsOrderer">同訂購人資訊</label>
								</li>
								<li class="form-check mb-0 ms-3">
									<input class="form-check-input" type="radio" name="BillRadio" id="SameAsRecipient">
									<label class="form-check-label" for="SameAsRecipient">同收件人資訊</label>
								</li>
								<li class="form-check mb-0 ms-3">
									<input class="form-check-input" type="radio" name="BillRadio" id="ForCompany">
									<label class="form-check-label" for="ForCompany">公司用(寄送)</label>
								</li>
							</ul>
						</div>

						<form class="content text-start my-4 p-sm-0 px-4">
							<div class="mb-2 row">
								<label for="InputInvoice" class="col-auto col-sm-2 col-form-label text-end">發票抬頭：</label>
								<div class="col-sm-6">
									<input type="text" class="form-control" id="InputInvoice">
								</div>
							</div>

							<div class="mb-2 row">
								<label for="InputGUINum" class="col-auto col-sm-2 col-form-label text-end">統　　編：</label>
								<div class="col-sm-6">
									<input type="text" class="form-control" id="InputGUINum">
								</div>
							</div>

							<div class="mb-2 row align-items-center">
								<label for="InputAddress" class="col-auto col-sm-2 col-form-label text-end">地　　址：</label>
								<div class="col-sm-2">
									<input type="text" class="form-control" aria-label="State" placeholder="請選擇縣市">
								</div>
								<div class="col-sm-2 my-2 my-sm-0">
									<input type="text" class="form-control" aria-label="City" placeholder="請選擇鄉鎮">
								</div>
								<div class="col-sm-4">
									<input type="text" class="form-control" id="InputAddress">
								</div>
							</div>
						</form>
					</div>

					<div class="payment_method title px-3 py-2 my-3 d-flex align-items-center justify-content-between">
						<div class="align-items-center d-flex">
							<div class="fs-5">付款方式</div>
							<div class="fs-2 fw-bold px-3">Line Pay</div>
						</div>
						<button class="btn_goprev bg-transparent border-0">變更付款方式</button>
					</div>

					<div class="swiper_button my-0 my-sm-5 d-flex flex-column flex-sm-row align-items-center justify-content-center">
						<button class="btn_swiper_prev_buystep border-0 text-center text-decoration-underline bg-transparent p-2">
							回上一頁
						</button>

						<button class="border-0 px-4 py-2 mx-3 rounded-3 text-center text-white">
							<div class="fs-2 fw-bold">確認結帳</div>
							<div>進入付款程序</div>
						</button>

						<button class="border-0 text-center text-decoration-underline bg-transparent p-2">
							我要再選購
						</button>
					</div>
				</div>
			</div>

			<div class="swiper-slide"></div>
		</div>
	</div>

	<div class="swiper_pagination container position-absolute position-relative">
		<div class="centerline position-absolute container"><hr class="opacity-100" /></div>

		<div class="swiper_pagination_buystep position-absolute"></div>


		<div class="step_name position-absolute container d-flex text-center justify-content-between p-0">
			<div class="">購物車</div>
			<div class="">運送及付款方式</div>
			<div class="">填寫資料</div>
			<div class="">完成訂購</div>
		</div>
	</div>

</div>
