                    <form id="RadioShipping" class="px-4 px-sm-5 mb-3 shipping needs-validation" method="post" novalidate>
                        <input type="hidden" name="authentiity_token" value="@Model.token" />
                        <div class="row gx-0">
                            @if (Model.freightModels.Count > 0)
                            {
                                var has_invalid = false;
                                @foreach (var freight in Model.freightModels ?? new List<FreightDisplayDto>())
                                {
                                    var check = freight.Set_Default ? "checked" : "";
                                    var boxFeesJson = System.Text.Json.JsonSerializer.Serialize(freight.LogisticsBoxFees ?? new List<LogisticsBoxFeeDisplayDto>());

                                    <div class="form-check text-start col-12 col-sm-3 my-2">
                                        <input id="FreeShip_@freight.Id"
                                               class="form-check-input"
                                               type="radio"
                                               name="RadioShipping"
                                               value="@freight.Id"
                                               data-freight-status-type="@freight.FreightStatusType"
                                               data-freight-type="@((int)freight.FreightType)"
                                               data-discount-freight-type="@(freight.DiscountFreightType.HasValue ? ((int)freight.DiscountFreightType.Value).ToString() : "")"
                                               data-freight="@(freight.Freight)"
                                               data-lowcon="@(freight.Low_Con)"
                                               data-disfreight="@(freight.Dis_Freight)"
                                               data-isdefault="@freight.Set_Default"
                                               data-boxfees='@Html.Raw(boxFeesJson)'
                                               data-support-cash-on-delivery="@freight.SupportCashOnDelivery"
                                               @check
                                               required>
                                        <label class="form-check-label" for="FreeShip_@freight.Id">@freight.Title</label>

                                        @if (freight.GetMap)
                                        {
                                            <input type="button"
                                                   class="btn_getmap bg-transparent border-0 ms-1 text-decoration-underline"
                                                   value="選擇門市"
                                                   data-subtype="@freight.LogisticsSubType"
                                                   data-support-cash-on-delivery="@freight.SupportCashOnDelivery"
                                                   title="選擇門市">
                                        }

                                        @{
                                            if (!has_invalid)
                                            {
                                                <div class="invalid-feedback">請選擇運送方式</div>
                                                has_invalid = true;
                                            }
                                        }
                                    </div>

                                    <div class="text-start freight-describe col-12 col-sm-9 my-2">
                                        @freight.Describe
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="noshipping">店家尚未設定運費方式</div>
                            }
                        </div>
                    </form>

