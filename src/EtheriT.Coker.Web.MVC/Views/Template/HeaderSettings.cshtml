@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal;
@{
    ViewData["Title"] = "HeaderSettings";
}
<link rel="stylesheet" href="~/css/Template/HeaderSettings.min.css" asp-append-version="true" />
<script src="~/js/Template/HeaderSettings.min.js" asp-append-version="true"></script>
<form id="headerSetting" name="headerSetting" class="container py-4">
    <h2 class="mb-4 d-flex justify-content-between">
        版頭管理
        <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 btn" type="submit" form="headerSetting">儲　存</button>
    </h2>

    <!-- ✅ 基本設定 -->
    <div class="card mb-4">
        <div class="card-header">基本設定</div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="showMarquee">
                        <label class="form-check-label" for="showMarquee">顯示跑馬燈</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="showPagePath">
                        <label class="form-check-label" for="showPagePath">顯示頁面路徑</label>
                    </div>
                </div>
            </div>
            <label class="form-label mt-3">Logo 位置：</label>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="headType" value="1" id="logoTop" checked>
                <label class="form-check-label" for="logoTop">上</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="headType" value="0" id="logoLeft">
                <label class="form-check-label" for="logoLeft">左</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="headType" value="2" id="logoLeft">
                <label class="form-check-label" for="logoLeft">與banner重疊</label>
            </div>
        </div>
    </div>

    <!-- ✅ Logo 上傳 -->
    <div class="card mb-4 d-none">
        <div class="card-header">主選單設定</div>
        <div class="card-body">
            <div id="LogoImageUpload" data-issinge="true" data-needcompress="false">
                <div class="title mb-2">Logo</div>
                @await Component.InvokeAsync(nameof(Modal), new { dispaly = "ImageUploadModal" })
            </div>
        </div>
    </div>

    <!-- ✅ Banner 管理 -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between">
            <span>Banner 管理</span>
        </div>
        <div class="card-body">
            <div class="slider-container" id="sliderList">
                <!-- Banner 將由 JS 動態產生 -->
                <div class="slider-item add-new" title="新增 Banner">
                    <span class="material-symbols-outlined add-icon">add</span>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- ✅ 完整 Modal 區塊 -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">編輯 Banner 資料</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editIndex">
                <div id="customLinkBox" class="url-input-box d-none">
                    <input type="text" class="form-control form-control-sm" placeholder="貼上圖片網址" />
                    <div class="text-end mt-1">
                        <button class="btn btn-sm btn-primary">確認</button>
                    </div>
                </div>
                <!-- 桌機圖片 -->
                <div class="mb-3 image-upload-container">
                    <label class="form-label">桌機版圖片</label>
                    <div class="position-relative">
                        <img id="editDesktopImagePreview" src="/images/noImg.jpg" class="img-fluid rounded mb-2">
                        <div class="image-remove-icon material-symbols-outlined">close</div>
                        <div class="image-link-icon material-symbols-outlined" data-type="desktop">link</div>
                    </div>
                    <input id="editDesktopImageInput" type="file" class="form-control d-none">
                </div>

                <!-- 手機圖片 -->
                <div class="mb-3 image-upload-container">
                    <label class="form-label">手機版圖片</label>
                    <div class="position-relative">
                        <img id="editMobileImagePreview" src="/images/noImg.jpg" class="img-fluid rounded mb-2">
                        <div class="image-remove-icon material-symbols-outlined">close</div>
                        <div class="image-link-icon material-symbols-outlined" data-type="mobile">link</div>
                    </div>
                    <input id="editMobileImageInput" type="file" class="form-control d-none">
                </div>

                <!-- 標題 -->
                <div class="mb-3">
                    <label class="form-label">標題</label>
                    <input type="text" class="form-control" id="editTitle">
                </div>

                <!-- 副標題 -->
                <div class="mb-3">
                    <label class="form-label">副標題</label>
                    <input type="text" class="form-control" id="editSubtitle">
                </div>

                <!-- 連結 -->
                <div class="mb-3">
                    <label class="form-label">連結網址</label>
                    <input type="url" class="form-control" id="editLink">
                </div>

                <!-- 啟用開關 -->
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editEnabled">
                    <label class="form-check-label" for="editEnabled">啟用</label>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button class="btn btn-primary">儲存</button>
            </div>
        </div>
    </div>
</div>

<!-- ✅ 圖片連結輸入小視窗 -->
<div class="modal fade" id="urlModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">輸入圖片網址</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control" id="imageUrlInput" placeholder="https://...">
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button class="btn btn-primary" id="confirmUrlButton">確定</button>
            </div>
        </div>
    </div>
</div>
