@using EtheriT.Coker.Web.Public.Views.Shared.Components.Footer
@using EtheriT.Coker.Application.Shared.i18n
@using EtheriT.Coker.Application.Shared.Dto.enumType.Processor
@model FooterViewModel

@{
    var nonce = ViewContext.HttpContext.Items["CSPNonce"] as string;
}

@if (!string.IsNullOrWhiteSpace(Model.css))
{
    <style nonce="@nonce">@Html.Raw(@Model.css)</style>
}

<div id="footer" class="w-100 d-flex justify-content-center align-items-center flex-column footer-bg">
    <coker-safe-html content="@Model.html"
                     website-id="@Model.HtmlSanitizeWebsiteId"
                     source-type="@HtmlSanitizeSourceType.頁尾"
                     source-id="@Model.HtmlSanitizeSourceId"
                     content-key="@Model.HtmlSanitizeHtmlContentKey"
                     sanitize-policy="@Model.HtmlSanitizePolicy"></coker-safe-html>
</div>