@using EtheriT.Coker.Web.Public.Models
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Modal

<link rel="stylesheet" href="~/css/Page/Favorites.min.css" asp-append-version="true" />
<script src="~/js/Page/Favorites.min.js" asp-append-version="true"></script>

<div id="ShoppingCarModal" class="modal fade" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
	@await Component.InvokeAsync(nameof(Modal), new {dispaly = "ShoppingCarModal"})
</div>

<nav id="Breadcrumb" class="container mt-3" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a href="/">首頁</a></li>
		<li class="breadcrumb-item active" aria-current="page">我的收藏</li>
	</ol>
</nav>

<div Id="Facorites_Title" class="fs-4 text-center my-3">
	<span class="member_name"></span> 收藏 共<span class="total">70</span>項<span class="search_place"></span> 商品
</div>

<div id="Filter" class="container-fluid border-bottom border-2">
	<div class="container row m-auto px-sm-4 px-0 flex-wrap-reverse justify-content-center">
		<div class="sort_radio container col d-flex justify-content-around justify-content-lg-start">
			<input id="sort_complex" type="radio" class="btn-check" name="choose_sort" autocomplete="off" checked>
			<label class="btn_sort_complex" for="sort_complex">綜合排序</label>

			<input id="sort_sales" type="radio" class="btn-check" name="choose_sort" autocomplete="off">
			<label class="btn_sort_sales" for="sort_sales">銷量排行</label>

			<input id="sort_new" type="radio" class="btn-check" name="choose_sort" autocomplete="off">
			<label class="btn_sort_new" for="sort_new">新上市</label>
		</div>

		<div class="options col-auto row row-cols-sm-auto my-2 align-items-center justify-content-center">
			<button class="btn_sort_hot col-3 mx-2 p-0 border-0 bg-transparent">熱門搜尋</button>
			<button class="btn_sort_price col-2 mx-2 p-0 border-0 bg-transparent">
				價格
				<i class="fa-solid fa-arrows-up-down"></i>
			</button>
			<button class="btn_filter col-2 order-sm-1 mx-2 p-0 border-0 bg-transparent">篩選</button>
			<button class="btn_typography col-2 order-sm-1 mx-2 p-0 border-0 bg-transparent">
				<i class="fa-solid fa-table-list"></i>
			</button>
			<input class="price_low border-0 price_low text-end px-1 mt-1 mt-sm-0" placeholder="最低價">
			<div class="col-1 p-0 text-center mt-1 mt-sm-0">~</div>
			<input class="price_high border-0 price_low text-end px-1 mt-1 mt-sm-0" placeholder="最高價">
			<button class="btn_confirm col-2 mx-2 border-0 text-white mt-1 mt-sm-0" type="button">確認</button>
		</div>
	</div>
</div>

