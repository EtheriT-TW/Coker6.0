    <script nonce="@ViewBag.Nonce">
        sessionStorage.setItem("PageKey","@ViewBag.PageKey");
        const local = @Html.Raw(L.getAllJsonString());
        const SiteId = @ViewBag.SiteId;
        const SearchWord = @Html.Raw(ViewBag.SearchWord);
        const BackstageUrl = "@ViewBag.BackstageUrl";
        const OAuthSuccess ="@ViewBag.OAuthSuccess";
        const OAuthError = "@ViewBag.OAuthError";
