@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Article
@{
	ViewData["Title"] = "NewArticle";
}

<link rel="stylesheet" href="~/css/ContentManagement/NewArticle.min.css" asp-append-version="true" />
<script src="~/js/ContentManagement/NewArticle.min.js" asp-append-version="true"></script>

<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-3 px-4">
		<div class="title fw-bold fs-3">新增文章</div>
	</div>

	<div id="" class="py-2">
		<div id="ArticleList" class="card border-0">
			<div class="card-body position-relative">
				<button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
					<span class="material-symbols-outlined">add</span>
				</button>
				@(
					Html.DevExtreme().DataGrid<ArticleListGetDto>()
					.DataSource(d => d.RemoteController().Key("Id")
					.LoadUrl("/api/Article/GetAllList").LoadMethod("Get")
					)
					.RemoteOperations(true)
					.ColumnHidingEnabled(true)
					.ShowBorders(true)
					.FilterRow(filterRow => filterRow
					.Visible(true)
					.ApplyFilter(GridApplyFilterMode.Auto)
					)
					.SearchPanel(searchPanel => searchPanel
					.Visible(true)
					.Width(480)
					.Placeholder("請輸入要搜尋的資料")
					)
					.ShowRowLines(true)
					.Columns(c =>
					{
						c.AddFor(e => e.Title).Caption("標題").Width(200);
						c.AddFor(e => e.Description).Caption("描述");
						c.AddFor(e => e.Visible).Caption("是否顯示").Width(90);
						c.AddFor(e => e.SerNO).Caption("排序").Width(90);
						c.AddFor(e => e.Popular).Caption("人氣值").Width(150);
						c.AddFor(e => e.PopularVisible).Caption("是否顯示人氣值").Width(150);
						c.Add()
						.Type(GridCommandColumnType.Buttons)
						.Buttons(b =>
						{
							b.Add().Name("edit").OnClick("editButtonClicked");
							b.Add().Icon("palette").Name("edit").OnClick("paletteButtonClicked");
							b.Add().Name("delete").OnClick("deleteButtonClicked");
						});
					})
					.ColumnAutoWidth(true)
					.Paging(paging => paging.PageSize(30))
					.Pager(pager =>
					{
						pager.Visible(true);
						pager.ShowPageSizeSelector(true);
						pager.AllowedPageSizes(new[] { 10, 20, 30 });
						pager.ShowInfo(true);
					})
					.Editing(editing =>
					{
						editing.AllowDeleting(true);
						editing.AllowUpdating(true);
						editing.UseIcons(true);
					})
					.OnContentReady("contentReady")
					)
			</div>
		</div>

		<div id="ArticleContent" class="card border-0 d-none">
			<div class="card-header d-flex justify-content-between">
				<div class="fw-bold fs-5 d-flex align-items-center">
					<button class="btn_back d-flex bg-transparent border-0 align-items-center">
						<span class="material-symbols-outlined">
							keyboard_backspace
						</span>
					</button>
					<div class="lh-lg">建立文章</div>
				</div>
				<div class="d-flex">
					<button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 " form="ProductForm">發　布</button>
					<button class="btn_to_canvas btn-success border-0 px-3 py-1 text-white d-flex align-items-center" form="ProductForm">
						進階編輯<span class="material-symbols-outlined ms-1">palette</span>
					</button>
				</div>
			</div>

			<form id="PostForm" class="card-body needs-validation">
				<div class="d-flex align-self-center justify-content-between mb-3">
					<button id="Btn_Display" class="bg-transparent border-0 text-primary d-flex align-self-center" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
						<span class="material-symbols-outlined fs-2">visibility</span>
					</button>
				</div>

				<div class="title border mb-3 p-2 rounded">
					<div class="d-flex justify-content-between w-100">
						<span class="input-group-text bg-transparent border-0 p-0 required_all">描述</span>
						<div class="title_count">0</div>
					</div>
					<textarea id="InputTitle" class="form-control border-0" aria-label="With textarea" maxlength="60" placeholder="輸入跑馬燈內文" required></textarea>
				</div>

				<div class="sort input-group mb-3">
					<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
						<span class="material-symbols-outlined me-1 required_sign">sort_by_alpha</span>排序
					</div>
					<input id="InputSort" class="form-control rounded" type="number" aria-label="Input Sort of Article" disabled="disabled" required>
					<div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up">
						<input id="SortCheck" class="form-check-input" type="checkbox" value="">
						<label class="form-check-label fs-6 pe-2" for="SortCheck">自訂排序</label>
					</div>
				</div>
			</form>
		</div>

		<div id="ArticleCanvas" class="card border-0 d-none">
			<div class="card-body position-relative pb-5">
				這裡是Canvas頁面
			</div>
		</div>
	</div>
</div>