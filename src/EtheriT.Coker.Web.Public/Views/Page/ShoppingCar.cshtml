@if (Model.PageData != null && !string.IsNullOrWhiteSpace(Model.PageData.Html))
{
    <Content id="main" class="d-none">@HttpUtility.HtmlEncode(Model.PageData.Html)</Content>
}

@if (Model.ParentData != null && !string.IsNullOrWhiteSpace(Model.ParentData.Html))
{
    <Content id="ParentNode" class="d-none">@HttpUtility.HtmlEncode(Model.ParentData.Html)</Content>
}
<div class="history container my-4 d-flex flex-wrap justify-content-center justify-content-md-end d-none">
    <a class="bg-white text-center m-1 py-2" href="/@ViewData["OrgName"]/Favorites">
        <div>收藏商品<span class="fw-bold">20</span>件</div>
    </a>
    <a href="" class="bg-white text-center m-1 py-2">
        <div>買過商品<span class="fw-bold">3</span>件</div>
    </a>
</div>
<div id="BuyStepSwiper" class="container pt-5 pb-4 mt-4 position-relative">
    @if (ViewBag.LoginEnable != null && ViewBag.LoginEnable && !ViewBag.isLogin)
    {
        <div id="memberLogin" class="container my-5">
            <div class="rounded-1 px-3 py-4 bg-white d-flex align-items-center justify-content-center justify-content-sm-start">
                <div>購買前登入會員可更方便查詢訂單！</div>
                <button class="btn_call_login bg-transparent rounded-1 ms-0 ms-sm-3">會員登入</button>
            </div>
        </div>
    }

    <div class="swiper shadow-lg mt-5">
        <div class="swiper-wrapper">
            <div id="Step1" class="card text-center swiper-slide">
                <div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
                    <div class="fs-5 my-2">購物明細</div>
                </div>

                <div class="card-body pt-5 d-none">
                    <div class="list_title row d-none d-lg-flex">
                        <div class="col-6 text-start">商品資訊</div>
                        <div class="col-2">單價</div>
                        <div class="col-2">數量</div>
                        <div class="col-2">小計</div>
                    </div>
                    <template id="Template_Cart_Group">
                        <li class="purchase_group border-top py-2" data-group-id="">
                            <div class="group_header mb-2">
                                <label class="form-check d-flex align-items-center">
                                    <input type="checkbox" class="form-check-input me-2 js-group-check">
                                    <span class="group_title fw-bold" data-field="title"></span>
                                    <span class="badge bg-secondary ms-2" data-field="count">0 件</span>
                                </label>
                                <div class="text-muted small" data-field="describe"></div>
                            </div>

                            <ul class="group_items list-unstyled mb-0"></ul>

                            <div class="group_footer mt-2 pt-2 d-flex justify-content-between align-items-center">
                                <small class="text-muted">已選 <span class="js-selected-count">0</span> 件</small>
                                <div>
                                    <span class="fw-bold">小計：</span>
                                    <span class="js-group-subtotal red_text fw-bold" data-subtotal="0">$0</span>
                                </div>
                            </div>
                        </li>
                    </template>


                    <template id="Template_Cart_Details">
                        <li class="purchase_item row border-bottom border-top py-2 align-items-lg-center position-relative" data-scid="">
                            <div class="image col-lg-6 col-sm-2 col-4 row gx-0">
                                <div class="d-flex align-content-center pro_link col-lg-2 col-12 me-3">
                                    <input type="checkbox" name="buyItems" class="me-2" />
                                    <label>
                                        <img data-key="imagePath" class="pro_image img-fluid" alt="商品" src="">
                                    </label>
                                </div>
                                <a data-key="link" class="pro_link col text-start overflow-hidden" href="" target="_blank" rel="noopener noreferrer">
                                    <div class="content d-lg-block d-none">
                                        <div data-key="title" class="pro_name single_line fw-bold"></div>
                                        <div class="pro_detail d-flex flex-wrap">
                                            <div data-key="spec" class="pro_specification pe-3"></div>
                                        </div>
                                        <div data-key="freight" class="fixedFreight"></div>
                                    </div>
                                </a>
                            </div>
                            <div class="nostock text-start col-sm-6 col d-none">
                                <div data-key="title" class="pro_name d-lg-none single_line fw-bold"></div>
                                <div class="pro_detail d-lg-none d-flex flex-wrap">
                                    <div data-key="spec" class="pro_specification pe-3"></div>
                                </div>
                                <div class="h5 fw-bold red_text">商品規格已下架或庫存為0</div>
                            </div>
                            <div class="content col-sm-6 col row gx-0 overflow-hidden">
                                <a data-key="link" class="pro_link" href="" title="連結至：商品" target="_blank" rel="noopener noreferrer">
                                    <div class="d-lg-none d-block text-start">
                                        <div data-key="title" class="pro_name single_line fw-bold"></div>
                                        <div class="pro_detail d-flex flex-wrap">
                                            <div data-key="spec" class="pro_specification pe-3"></div>
                                            @*<div class="pro_instructions single_line"></div>*@
                                        </div>
                                    </div>
                                </a>

                                <div class="col-12 col-lg-4 my-3 my-lg-0 fw-bold align-self-center text-start text-lg-center">
                                    <div data-key="oldPrice" data-type="price" class="pro_old_unit fw-light text-decoration-line-through d-none"></div>
                                    <div data-key="price" data-type="price" class="pro_unit cart-price-block">
                                        <div class="cart-price-main"></div>
                                        <div class="cart-price-bonus d-none"></div>
                                    </div>
                                </div>

                                <div class="counter_input col-12 col-lg-4 d-flex justify-content-start justify-content-lg-center align-items-center">
                                    <button class="btn_count_minus bg-white border-end-0">
                                        <i class="fa-solid fa-minus"></i>
                                        <span class="d-none">減少</span>
                                    </button>
                                    <label class="d-none" for="quantityInput1">數量</label>
                                    <input data-key="quantity" id="quantityInput1" class="pro_quantity text-center py-1" type="number" name="counter" value="">

                                    <button class="btn_count_plus bg-white border-start-0">
                                        <i class="fa-solid fa-plus"></i>
                                        <span class="d-none">增加</span>
                                    </button>
                                </div>

                                <div data-key="subtotal" data-type="price" class="pro_subtotal col-4 fw-bold fs-5 d-lg-block d-none cart-price-block" data-subtotal="">
                                    <div class="cart-price-main"></div>
                                    <div class="cart-price-bonus d-none"></div>
                                </div>
                            </div>

                            <div class="btn_side_icon position-absolute d-flex flex-column top-50 translate-middle-y end-0 p-2">

                                @if (ViewBag.LoginEnable)
                                {
                                    @if (ViewBag.isLogin)
                                    {
                                        <span class="d-inline-block favorites" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="加入/移除收藏">
                                            <button class="btn_move_to_favorites bg-transparent border-0">
                                                <i class="fa-regular fa-heart text-danger"></i>
                                                <span class="d-none">加入/移除收藏</span>
                                            </button>
                                        </span>
                                    }
                                }
                                <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="移除商品">
                                    <button class="btn_remove_pro bg-transparent border-0">
                                        <i class="fa-solid fa-xmark"></i>
                                        <span class="d-none">移除商品</span>
                                    </button>
                                </span>
                            </div>
                        </li>
                    </template>
                    <ul class="purchase_list ps-4 pe-5"></ul>

                    <div class="priceline priceline-step1 pe-sm-5 col-12 col-md-7 offset-md-5">
                        <div class="summary-main-row">
                            <div class="summary-label">商品金額</div>
                            <div class="summary-amount dual-price">
                                <span class="bonus-part"><span class="bonus"></span>點</span>
                                <span class="plus-sign">+</span>
                                <span class="cash-part subtotal price"></span>
                            </div>
                        </div>

                        <div class="summary-main-row bonusDiscionLine d-none">
                            <div class="summary-label">紅利折抵</div>
                            <div class="summary-amount bonusDiscion price-negative"></div>
                        </div>

                        <div class="summary-note-row bonusRuleLine d-none">
                            <div class="summary-note-value bonusRedeemRuleText"></div>
                            <div class="summary-note-label"></div>
                        </div>

                        <div class="summary-panel">
                            <div class="summary-main-row bonusUseTotalLine d-none">
                                <div class="summary-label">使用總紅利</div>
                                <div class="summary-amount bonusUseTotalValue"></div>
                            </div>

                            <div class="summary-total-row">
                                <div class="summary-label">小計</div>
                                <div data-key="payableSubtotal" class="summary-amount payable_subtotal price fs-5 fw-bold red_text"></div>
                            </div>

                            <div class="summary-reward-row bonusRedeemHintLine d-none">
                                <div class="summary-reward-box">
                                    <i class="fa-solid fa-gift summary-reward-icon"></i>
                                    <span class="bonusEarnHintText"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="js-bonus-nextstep-hint text-danger small mb-2 d-none text-center">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        <span class="js-bonus-nextstep-text"></span>
                    </div>

                    <div class="swiper_button my-5 d-flex justify-content-center">
                        <a href="@ViewData["prodCatalog"]" title="繼續購物：回商品目錄" class="btn_backshop btn_gray_dark border-0 mx-2 p-0 py-2 rounded-3 text-center text-white">返回購物</a>
                        <button class="btn_swiper_next_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
                            下一步
                        </button>
                    </div>
                </div>

                <div id="Purchase_Null" class="align-items-center flex-column justify-content-center">
                    <div class="mt-5">您的購物車是空的</div>
                    <a class="btn_backshop btn_gray_dark border-0 p-0 py-2 rounded-3 text-center text-white my-5" href="@ViewData["prodCatalog"]" title="繼續購物：回商品目錄">點此返回選購</a>
                </div>
            </div>

            <div id="Step3" class="card text-center swiper-slide">
                <div class="card-header px-3 py-2 d-flex align-items-center justify-content-between">
                    @* <div class="fs-5 my-2">購物明細</div> *@
                    <div class="fs-5">訂購人資料</div>
                    <button class="btn_edit_data bg-transparent border-0 fs-3 ms-1" title="編輯">
                        <i class="fa-regular fa-pen-to-square"></i>
                        <span class="d-none">編輯</span>
                    </button>
                    <button class="btn_inituser border-0 ms-auto opacity-75 text-decoration-underline">恢復預設資料</button>
                </div>

                <div class="card-body px-0">
                    <div id="OrdererForm">
                        <div class="default_data">
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">姓　　名：</div>
                                <div data-key="orderer" class="col ps-0 text-start"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">電子郵件：</div>
                                <div data-key="ordererEmail" class="col ps-0 text-start"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">手機號碼：</div>
                                <div data-key="ordererCellPhone" class="col ps-0 text-start"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">地　　址：</div>
                                <div data-key="ordererAddress" class="col ps-0 text-start"></div>
                            </div>
                        </div>

                        <form id="Form_Orderer" class="px-3 px-sm-5 d-none needs-validation" method="post" novalidate>
                            <input type="hidden" name="authentiity_token" value="@Model.token" />
                            <div class="row mx-0">
                                <div class="form-floating mb-3 col-12 col-sm-6 px-0">
                                    <input id="OrdererInputName" class="orderer_name form-control" name="orderer" type="text" placeholder="name" value="" minlength="2" required>
                                    <label class="required" for="OrdererInputName">姓　　名</label>
                                </div>
                                <div class="gender d-flex align-self-center col-12 col-sm-6 mb-3">
                                    <div class="form-check pe-3">
                                        <input id="OrdererRadioSir" class="form-check-input" type="radio" name="ordererSex" value="1" required>
                                        <label class="form-check-label" for="OrdererRadioSir">男</label>
                                    </div>
                                    <div class="form-check pe-3">
                                        <input id="OrdererRadioMiss" class="form-check-input" type="radio" name="ordererSex" value="2" required>
                                        <label class="form-check-label" for="OrdererRadioMiss">女</label>
                                    </div>
                                    <div class="form-check">
                                        <input id="OrdererRadioElse" class="form-check-input" type="radio" name="ordererSex" value="3" required>
                                        <label class="form-check-label" for="OrdererRadioElse">其他</label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-floating mb-3 col-12 col-sm-6 e-mail">
                                <input id="OrdererInputMail" class="orderer_mail form-control" name="ordererEmail" type="email" placeholder="name@example.com" value="" required>
                                <label class="required" for="OrdererInputMail">E-mail</label>
                            </div>
                            <div class="form-floating mb-3 col-12 col-sm-6 cell-phone">
                                <input id="OrdererInputCellPhone" class="orderer_phone form-control" name="ordererCellPhone" type="tel" placeholder="請輸入手機號碼" value="" pattern="[0][9]\d{8}" maxlength="10" required>
                                <label class="required" for="OrdererInputCellPhone">手機號碼</label>
                            </div>
                            <div class="row">
                                <div class="form-floating mb-3 col-4 col-sm-2 tel-area">
                                    <input id="OrdererInputTelPhoneArea" class="orderer_areacode form-control" name="zone" type="tel" placeholder="請輸入區碼" value="" pattern="[0]\d{1,3}" maxlength="4">
                                    <label class="px-4" for="OrdererInputTelPhoneArea">電話區碼</label>
                                </div>
                                <div class="form-floating mb-3 col-8 col-sm-4 pe-sm-0 ps-0 tel-phone">
                                    <input id="OrdererInputTelPhone" class="orderer_cellphone form-control" name="ordererTelePhone" type="tel" placeholder="請輸入聯繫電話" value="" pattern="\d{7}" maxlength="7">
                                    <label for="OrdererInputTelPhone">聯絡電話</label>
                                </div>
                                <div class="form-floating mb-3 col-6 col-sm-3 phone-ext">
                                    <input id="OrdererInputTelPhoneExt" class="orderer_extension form-control" name="ext" type="tel" placeholder="請輸入分機號碼" value="" pattern="\d*">
                                    <label class="px-4" for="OrdererInputTelPhoneExt">分機</label>
                                </div>
                            </div>
                            <div id="Orderer_TWzipcode" class="row">
                                <div class="county form-floating mb-3 col-6 col-sm-3" data-role="county"></div>
                                <div class="district form-floating mb-3 col-6 col-sm-3 pe-sm-0 ps-0" data-role="district"></div>
                                <div class="form-floating mb-3 col-12 col-sm-6">
                                    <input id="OrdererInputAddress" class="orderer_address form-control" name="ordererAddress" type="text" placeholder="請輸入地址" value="" required>
                                    <label class="px-4 required" for="OrdererInputAddress">地址</label>
                                </div>
                            </div>
                            @if (ViewBag.LoginEnable != null && ViewBag.LoginEnable && ViewBag.isLogin)
                            {
                                <div class="form-check memberUpdate">
                                    <input id="MemberUpdate" class="form-check-input" type="checkbox">
                                    <label class="form-check-label" for="MemberUpdate">同時更新會員資料<span class="ps-2 text-danger">*Email為登入帳號，不會回存</span></label>
                                </div>
                            }
                        </form>

                        <form id="Form_Memo" class="px-3 mt-4 pt-4 border-top px-sm-5 needs-validation" method="post" novalidate>
                            <div class="row">
                                <div class="form-floating mb-3 col-12">
                                    <textarea id="TextareaRemark" name="remark" class="form-control" placeholder="備註"></textarea>
                                    <label for="TextareaRemark" class="px-4">備　　註</label>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div id="RecipientForm">
                        <div class="title px-3 py-2 my-3 d-flex align-items-center">
                            <div class="fs-5 text-end">收件人資料</div>
                            <ul class="d-flex flex-wrap text-start mb-0">
                                <li class="form-check mb-0 ms-3">
                                    <input id="radio_recipient_order" class="form-check-input" type="radio" name="RecipientRadio" value="order" checked>
                                    <label class="form-check-label" for="radio_recipient_order">同訂購人資訊</label>
                                </li>
                                <li class="form-check mb-0 ms-3">
                                    <input id="radio_recipient_edit" class="form-check-input" type="radio" name="RecipientRadio" value="edit">
                                    <label class="form-check-label" for="radio_recipient_edit">輸入收件人資料</label>
                                </li>
                                @if (ViewBag.LoginEnable)
                                {
