                            <div class="register_check_pass input-group">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputRegisterCheckPass" class="input_bg form-control rounded border-0 py-3" type="password" autocomplete="off" aria-label="Input Register Check Password" placeholder="確認密碼" required name="PasswordConfirm">
                            </div>
                            <div id="RegisterCheckPassFeedBack" class="lh-1 text-danger pt-1">　</div>
                            <div class="register_vcode input-group">
                                <input id="InputRegisterVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Register Verification Code" placeholder="輸入驗證碼" maxlength="4" required>
                                <div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
                                    <img id="RegisterImgCaptcha" alt="驗證碼" class="img-fluid" src="" />
                                </div>
                            </div>
                        </form>
                        <div class="px-3">
                            <div class="d-flex  justify-content-end pt-0 pb-3">
                                <button class="btn_refresh border-0 bg-transparent text-black-50">刷新驗證碼</button>
                            </div>
                            <div class="form-check">
                                <input id="CheckAccept" class="form-check-input" type="checkbox" value="">
                                <label class="form-check-label" for="CheckAccept">我已詳細閱讀並同意<span><a class="text-black text-decoration-underline" href="/@ViewData["OrgName"]/Terms" title="連結至：會員條款(另開新視窗)" target="_blank">會員條款</a></span></label>
                            </div>
                        </div>
                        <button class="btn_register w-100 rounded border-0 text-white py-2 fs-5 my-3">註　冊</button>
                    </div>
                </div>
            </div>
        </div>
        <div id="ResetModal" class="modal fade" aria-hidden="true" aria-labelledby="ResetModal" tabindex="-1">
