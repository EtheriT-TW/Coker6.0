@using EtheriT.Coker.Application.Shared.Dto.HtmlContent
@using EtheriT.Coker.Web.Public.Views.Shared.Components.SideFloating
@model SideFloatingViewModel

<link rel="stylesheet" href="~/css/SideFloating/SideFloating.min.css" asp-append-version="true" />
<script src="~/js/SideFloating/SideFloating.min.js" asp-append-version="true"></script>

<div id="Floating_Center" class="position-fixed d-flex flex-column align-items-center d-none d-lg-block">
	@if (Model.rightSideAd.Count > 0)
	{
		@foreach (var rightSideAd in Model.rightSideAd ?? new List<HtmlContentDisplayDto>())
		{
			var target = rightSideAd.Target ? "_blank" : "_self";
			@if (rightSideAd.Link != "")
			{
				<div><a href="@rightSideAd.Link" target="@target"><img class="my-1 shadow" src="@rightSideAd.Img" alt="@rightSideAd.Title"></a></div>
			}
			else
			{
				<div><img class="my-1 shadow" src="@rightSideAd.Img" alt="@rightSideAd.Title"></div>
			}
		}
	}
	else
	{
		<div id="History" class="text-end">
			<div id="CollapseHistory" class="">
				<div class="title text-center text-white">瀏覽紀錄</div>
				<ul class="m-0">
					<li class="mb-1 border" data-pid="1"><a class="pro_link" href="/Toilet/1"><img class="img-fluid" src="~/images/product/pro_pic_01.jpg" alt="" /></a></li>
					<li class="mb-1 border" data-pid="1"><a class="pro_link" href="/Toilet/1"><img class="img-fluid" src="~/images/product/pro_pic_01.jpg" alt="" /></a></li>
					<li class="mb-1 border" data-pid="1"><a class="pro_link" href="/Toilet/1"><img class="img-fluid" src="~/images/product/pro_pic_01.jpg" alt="" /></a></li>
					<li class="mb-1 border" data-pid="1"><a class="pro_link" href="/Toilet/1"><img class="img-fluid" src="~/images/product/pro_pic_01.jpg" alt="" /></a></li>
				</ul>
				<a class="collect d-flex justify-content-center align-items-center text-white mb-1" href="/Favorites">
					<i class="fa-solid fa-regular fa-heart px-1"></i>
					<div class="text">收藏</div>
					<div class="amount px-1">20</div>
				</a>
				<a class="checkout d-flex justify-content-center align-items-center text-white py-1 mb-1" href="/ShoppingCar">
					<i class="fa-solid fa-cart-shopping px-1"></i>
					<div class="text px-1">結帳</div>
				</a>
			</div>
		</div>
	}
</div>

<div id="Floating_Bottom" class="position-fixed d-flex flex-column align-items-center bottom-0 end-0 p-2">
	<button id="btn_chat" class="bg-transparent border-0 rounded-circle">
		<img class="img-fluid" src="~/images/icon-linechat.png" alt="" />
	</button>

	<div id="Chatbot_Frame" class="card position-absolute border-0">
		<div class="card-header fw-bold">LINE</div>
		<div class="card-body text-center">
			<figure class="m-0">
				<img class=" card-img-topw-50" src="~/images/QRcode_linechatbot.png" alt="Chatbot QRcode">
				<figcaption>
					<div class="mt-3">透過行動條碼加入LINE好友</div>
				</figcaption>
			</figure>
			<div>或直接點擊下方按鈕進行連結</div>
			<a class="h-100 rounded" href="line://ti/p/&#64;993kweuu?oat_referrer=PROFILE"><div class="btn_gochat mt-2 py-1">前往聊天</div></a>
		</div>
	</div>

	<button id="btn_gotop" class="bg-black border-0 mt-3 px-3 rounded-3 text-white">
		<i class="fa-solid fa-chevron-up"></i>
		<div>Top</div>
	</button>
</div>