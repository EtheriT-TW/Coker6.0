                            <div class="py-2 d-flex justify-content-end text-end">
                                <div>商品金額</div>
                                <div data-key="productSubtotal" class="subtotal col-4 price">0</div>
                            </div>

                            <div class="py-2 d-flex justify-content-end text-end productBonusLine d-none">
                                <div>商品紅利</div>
                                <div data-key="productBonus" class="productBonusValue col-4">0 點</div>
                            </div>

                            <div class="py-2 d-flex justify-content-end text-end bonusDiscionLine d-none">
                                <div class="summary-label">紅利折抵</div>
                                <div data-key="redeemBonus" class="bonusDiscion col-4 price-negative">0 點</div>
                            </div>

                            <div class="py-2 d-flex justify-content-end text-end">
                                <div>運費</div>
                                <div data-key="freight" class="shipping_fee col-4 price">0</div>
                            </div>

                            <div class="py-2 d-flex justify-content-end text-end bonusUseTotalLine d-none">
                                <div>本次消費總紅利</div>
                                <div data-key="bonus" class="bonusUseTotalValue col-4">0 點</div>
                            </div>

                            <div class="py-2 border-top d-flex justify-content-end text-end align-items-baseline">
                                <div>本次消費總金額</div>
                                <div data-key="total" class="total_amount col-4 price fs-5 fw-bold">0</div>
                            </div>
                        </div>

                    </div>

                    <div class="orderer_data">
                        <div class="title px-3 py-2 my-3 d-flex align-items-center fs-5 text-end">訂購人資料</div>

                        <div class="content">
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">姓　　名：</div>
                                <div data-key="orderer" data-type="name" class="col text-start ps-0"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">電子郵件：</div>
                                <div data-key="ordererEmail" data-type="email" class="col text-start ps-0"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">手機號碼：</div>
                                <div data-key="ordererCellPhone" data-type="phone" class="col text-start ps-0"></div>
                            </div>
                        </div>
                    </div>

                    <div class="recipient_data">
                        <div class="title px-3 py-2 my-3 d-flex align-items-center fs-5">收件人資料</div>

                        <div class="content">
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">姓　　名：</div>
                                <div data-key="recipient" data-type="name" class="col text-start ps-0"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">電子郵件：</div>
                                <div data-key="recipientEmail" data-type="email" class="col text-start ps-0"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">手機號碼：</div>
                                <div data-key="recipientCellPhone" data-type="phone" class="col text-start ps-0"></div>
                            </div>
                            <div class="row">
                                <div class="col-auto col-sm-2 text-end ps-4">地　　址：</div>
                                <div data-key="recipientAddress" data-type="address" class="col text-start ps-0"></div>
                            </div>
                        </div>
                    </div>
                    @if (ViewBag.HasInvoice)
                    {
                        <div class="invoice_type" data-carrier-count="@ViewBag.Carrier.Count">
                            <div class="title px-3 py-2 my-3 d-flex align-items-center fs-5">發票類型：<span class="fs-6" data-key="InvoiceTypeTitle"></span></div>
                            <div class="content">
                                <div class="person d-none">
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">型  別：</div>
                                        <div data-key="personalInvoiceTypeTitle" class="col text-start ps-0"></div>
                                    </div>
                                    @if (ViewBag.Carrier.Contains("MobileCarrier"))
                                    {
                                        <div class="mobileCarrier d-none">
                                            <div class="row">
                                                <div class="col-auto col-sm-2 text-end ps-4">手機條碼：</div>
                                                <div data-key="carrier" class="col text-start ps-0"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="company d-none">
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">發票抬頭：</div>
                                        <div data-key="invoiceTitle" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">統　　編：</div>
                                        <div data-key="uniformId" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">地　　址：</div>
                                        <div data-key="invoiceAddress" class="col text-start ps-0"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="invoice_data">
                            <div class="title px-3 py-2 my-3 d-flex align-items-center fs-5">發票寄送</div>

                            <div class="content">
                                <div class="orderer d-none">
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">姓　　名：</div>
                                        <div data-key="orderer" data-type="name" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">電子郵件：</div>
                                        <div data-key="ordererEmail" data-type="email" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">手機號碼：</div>
                                        <div data-key="ordererCellPhone" data-type="phone" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">地　　址：</div>
                                        <div data-key="ordererAddress" data-type="address" class="col text-start ps-0"></div>
                                    </div>
                                </div>
                                <div class="recipient d-none">
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">姓　　名：</div>
                                        <div data-key="recipient" data-type="name" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">電子郵件：</div>
                                        <div data-key="recipientEmail" data-type="email" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">手機號碼：</div>
                                        <div data-key="recipientCellPhone" data-type="phone" class="col text-start ps-0"></div>
                                    </div>
                                    <div class="row">
                                        <div class="col-auto col-sm-2 text-end ps-4">地　　址：</div>
                                        <div data-key="recipientAddress" data-type="address" class="col text-start ps-0"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    <div id="PaymentData">
                        <div class="storememo d-none">@ViewData["storeMemo"]</div>
                        <div class="title px-3 py-2 my-3 d-flex align-items-center">
                            <div class="fs-5">付款方式</div>
                            <div data-key="payment" class="payment_method px-3 fs-5">尚未選擇付款方式</div>
                        </div>

                        <div class="pay_info px-4 d-none">
                            <p>繳費完成後，請利用Email主動與客服聯絡。告知您姓名、轉帳帳戶末五碼，或是相關匯款資訊，以利核對您的款項。</p>
                            <div class="border-bottom border-top text-start py-3 my-3">
                                <div class="mb-2 row align-items-center">
                                    <div class="col-auto col-sm-2 text-end">應繳金額新台幣：</div>
                                    <div class="col ps-0">新台幣<span class="total_amount paid_amount fs-5 fw-bold"></span></div>
                                </div>
                                <div class="mb-2 row align-items-center">
                                    <div class="col-auto col-sm-2 text-end">繳費期限：</div>
                                    <div class="paid_date col ps-0"></div>
                                </div>
                            </div>
                        </div>
                        <p class="pay_mail px-4"></p>
                        <div class="btn_back_home d-flex justify-content-center my-4">
                            <a href="/@ViewData["OrgName"]/home">
                                <div class="fs-5 fw-bold px-3 py-1 rounded text-white">回首頁</div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="swiper_pagination container position-absolute position-relative">
        <div class="centerline position-absolute container"><hr class="opacity-100" /></div>

        <div class="swiper_pagination_buystep position-absolute"></div>

        <div class="step_name position-absolute container d-flex text-center justify-content-between p-0">
            <div class="">購物車</div>
            <div class="">填寫資料</div>
            <div class="">完成訂購</div>
        </div>
    </div>
</div>


