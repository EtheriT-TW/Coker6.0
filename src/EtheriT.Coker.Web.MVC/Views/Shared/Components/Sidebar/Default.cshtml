@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Sidebar;
@using EtheriT.Coker.Web.MVC.Startup;
@model Site;
<script>
	const defaultUrl = "@Model.WebRootLink";
	const OrgName = "@Model.OrgName";
	const PageName = `@ViewData["Title"].ToString()`;
</script>
<nav class="navbar navbar-dark bg-primary">
	<a class="navbar-brand m-0 py-2 brand-title" href="#">@Model.Title</a>
	<span></span>
	<a class="navbar-brand py-2 material-icons toggle-sidebar" href="#">menu</a>
</nav>
<nav class="navigation">
	<ul>
		@{
			string PageName;
			ThePermission.Initable = false;
			foreach (var item in Model.Jobs)
			{
				@if (item.jobItemModels == null)
				{
					if (item.CanVisble)
					{
						string myClass = item.PageName == ViewData["Title"].ToString() ? "active" : "";
						if (myClass == "active") {
							ThePermission.CanVisble = item.CanVisble;
							ThePermission.CanUpdate = item.CanUpdate;
							ThePermission.CanRemove = item.CanRemove;
							ThePermission.CanCreate = item.CanCreate;
						}
						<li class="@myClass">
								<a title="@item.Title" asp-controller="@item.Controller" asp-action="@item.Action">
								<span class="nav-icon material-icons">@item.Icon</span>@item.Title
							</a>
						</li>
					}
				}
				else if (item.CanVisble)
				{
					string brighten = "";
					if (item.jobItemModels.Exists(e => e.PageName == ViewData["Title"].ToString()))
					{
						var n = item.jobItemModels.Find(e => e.PageName == ViewData["Title"].ToString());
						ThePermission.CanVisble = n.CanVisble;
						ThePermission.CanUpdate = n.CanUpdate;
						ThePermission.CanRemove = n.CanRemove;
						ThePermission.CanCreate = n.CanCreate;
						brighten = "active open";
					}

					<li class="@brighten">

						<a title="@item.Title" asp-controller="@item.Controller" asp-action="@item.Action">
							<span class="nav-icon material-icons "> @item.Icon </span>@item.Title<span class="toogle-sub-nav material-icons"> keyboard_arrow_right </span>
						</a>
						<ul class="sub-nav">
							@foreach (var subJob in item.jobItemModels ?? new List<JobMenu>())
							{
								if (subJob.CanVisble)
								{
									string myClass = subJob.PageName == ViewData["Title"].ToString() ? "active" : "";
									<li class="@myClass">
										<a title="@subJob.Title" asp-controller="@subJob.Controller" asp-action="@subJob.Action">
											<span class="nav-icon material-icons">@subJob.Icon</span>@subJob.Title
										</a>
									</li>
								}
							}
						</ul>
					</li>
				}
			}
			ThePermission.Initable = true;
		}
	</ul>
</nav>