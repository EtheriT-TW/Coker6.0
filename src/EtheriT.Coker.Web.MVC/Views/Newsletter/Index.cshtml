                    </div>
                    <div class="conten border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">內文</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" name="Conten" aria-label="With textarea" maxlength="300" placeholder="請輸入內文" required></textarea>
                    </div>
                </div>
                <div data-key="conten3" class="msf-view">
                    <div class="d-flex justify-content-between mb-5 mt-3">
                        <div class="d-flex justify-content-center ms-5 image_upload formItem" data-name="image" data-issinge="true" data-needcompress="false">
