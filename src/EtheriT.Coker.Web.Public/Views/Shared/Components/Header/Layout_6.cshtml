@using EtheriT.Coker.Application.Shared.Dto.Marquee;
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Header
@using EtheriT.Coker.Web.Public.Views.Shared.Components.MenuItem
@model HeaderViewModel

<link rel="stylesheet" href="~/css/Header/Header_Layout_6.min.css" asp-append-version="true" />
<script src="~/js/Header/Header_Layout_6.min.js" asp-append-version="true"></script>

@{
    string imgurl = Model.LogoImageUrl?.Substring(0, Model.LogoImageUrl?.LastIndexOf("/")??0)??"";
}
<script nonce="@ViewBag.Nonce">
    const orgName = getComputedStyle(document.documentElement).getPropertyValue('--orgName').trim();
    document.documentElement.style.setProperty('--homeBackground', `url('/upload/${orgName}/backgroundtop.jpg')`);
</script>
<div class="text-white pb-lg-5">
    <div class=" menu">
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-light">
                <a href="#" title="展開主選單" class="btn d-lg-none px-0 d-lg-none order-0" type="button" data-bs-toggle="collapse" data-bs-target="#headermenu" aria-expanded="false" aria-controls="headermenu">
                    <span class="material-symbols-outlined fs-1 text-white">
                        menu
                    </span>
                </a>
                <a class="navbar-brand p-0 m-0 order-1" href="/" title="連結至:首頁">
                    <img class="logoimg" src="@Model.LogoImageUrl" alt=" " asp-append-version="true">
                    <h1 class="sr-only">@Model.Title</h1>
                </a>
                <div class="collapse navbar-collapse order-lg-2 order-3" id="headermenu">
                    <ul class="navbar-nav position-relative">
                        <li class="">
                            <a id="AU" accesskey="U" href="#AU" class="hide accesskey" title="上方區域">:::</a>
                        </li>
                        @foreach (var menu in Model.menuItemModels ?? new List<MenuItemModel>())
                        {
                            var target = menu.Target == true ? "_blank" : "_self";
                            var title = menu.Target == true ? $"連結至：{menu.Title}(另開視窗)" : $"連結至：{menu.Title}";
                            <li class="nav-item active">
                                <a class="nav-link" href="@menu.Link" title="@title" target="@target" rel="@(menu.Target == true ? $"noopener noreferrer" : "")">@menu.Title <span class="sr-only">(current)</span></a>
                            </li>
                        }
                    </ul>
                </div>
                <div class=" order-2 order-lg-3"><a href="/@ViewData["OrgName"]/Search" class="d-flex ps-1 "><span class="material-symbols-outlined text-white">search</span></a></div>
            </nav>
        </div>
    </div>
</div>
<a href="@Model.HomeLink" title="連結至:@Model.Title">
    <img class="titleimage m-auto d-block" src="@imgurl/headertitile.png" alt="Header Titile" />
</a>
<div class="headernews m-auto d-block position-relative mb-5">
    <img class="d-md-flex d-none m-auto d-block" src="@imgurl/marqueeblockbig.png" alt="Header Marquee Background" />
    <img class="d-md-none m-auto d-block" src="@imgurl/marqueeblocksmall.png" alt="Header Marquee Background" />
    <div class="content position-absolute row align-items-center w-100">
        <div class="title  fw-bold  col-md-1 p-0 col-12 text-center">近期訊息</div>
        <div class="text overflow-hidden text-white p-0 col">
            <div class="swiper marqueeSwiper">
                <div class="swiper-wrapper">
                    @foreach (var marquee in Model.marqueeModels ?? new List<MarqueeDisplayDto>())
                    {
                        var target = marquee.target == true ? "_blank" : "_self";
                        var title = marquee.target == true ? $"連結至：{marquee.title}(另開視窗)" : $"連結至：{marquee.title}";
                        var link = marquee.link;
                        if (string.IsNullOrEmpty(link))
                        {
                            <div class="swiper-slide"><div class="overflow-hidden text" data-bs-toggle="tooltip" title="@marquee.title">@marquee.title <span class="sr-only">(current)</span></div></div>
                        }
                        else
                        {
                            <div class="swiper-slide"><a class="overflow-hidden text" data-bs-toggle="tooltip" title="@title" href="@link" target="@target" rel="@(marquee.target == true ? $"noopener noreferrer" : "")">@marquee.title <span class="sr-only">(current)</span></a></div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
