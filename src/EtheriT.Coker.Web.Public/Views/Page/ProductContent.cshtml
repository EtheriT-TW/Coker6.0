@{
}

<link rel="stylesheet" href="~/css/Page/ProductContent.css" asp-append-version="true" />
<script src="~/js/Page/ProductContent.js" asp-append-version="true"></script>

<nav id="Breadcrumb" class="container mt-3" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a href="/">首頁</a></li>
		<li class="breadcrumb-item"><a href="/">Derek商品</a></li>
		<li class="breadcrumb-item"><a href="/">馬桶</a></li>
		<li class="breadcrumb-item active" aria-current="page">C659NA德瑞克Smart III淨未來智慧馬桶</li>
	</ol>
</nav>

<div class="container">
	<div id="Product" class="row gx-3">
		<div class="image col-6">
			<ul class="tag">
				<li>奈米</li>
				<li>奈米</li>
				<li>奈米</li>
				<li>奈米</li>
			</ul>
		</div>
		<div class="content col-6">
			<div class="title fs-5">C659NA德瑞克Smart III淨未來智慧馬桶</div>

			<div class="d-flex align-items-center justify-content-between px-3">
				<div class="describe my-2">
					<p>描述<br>描述<br>描述</p>
				</div>
				<div class="track text-center">
					<i class="btn_favorites fa-regular fa-heart"></i>
					<div>追蹤</div>
				</div>
			</div>

			<hr class="m-1" />

			<div class="specification px-4 text-center my-2">
				<p class="text-start w-100">規格<br>規格</p>
				<div class="btn_detailed px-4 py-1 d-inline-flex rounded-pill" type="button">
					<div class="me-2">詳細規格</div>
					<i class="fa-solid fa-angle-down h5 m-0"></i>
				</div>
			</div>

			<div class="certification px-3">
				<div>標章認證</div>
				<ul class="badge d-flex flex-wrap">
					<li><img src="~/images/badge/badge_01.jpg" alt="" /></li>
					<li><img src="~/images/badge/badge_02.jpg" alt="" /></li>
					<li><img src="~/images/badge/badge_03.jpg" alt="" /></li>
					<li><img src="~/images/badge/badge_04.jpg" alt="" /></li>
					<li><img src="~/images/badge/badge_05.jpg" alt="" /></li>
				</ul>
			</div>

			<hr class="m-1"/>

			<div class="d-flex justify-content-between align-items-center">
				<div class="price d-flex ps-3 align-items-center">
					<div class="mprice me-2">市價 150,000元</div>
					<div class="discount d-flex align-items-center">折扣<span class="fs-4 fw-bold text-danger">$135,000</span></div>
				</div>
				<div class="model pe-3 text-black-50">型號：C659NA</div>
			</div>

			<hr class="m-1" />

			<div class="options px-3 my-2">
				<div class="color d-flex">
					<div>顏色</div>
				</div>
				<div class="amount d-flex">
					<div>數量</div>
				</div>
			</div>

			<div class="btn_buy d-flex align-items-center justify-content-center" type="button">
				<i class="me-2 fa-regular fa-square-plus"></i>
				<div>我要購買</div>
			</div>

		</div>
	</div>
</div>

<div id="CenterLine" class="container d-flex">
	<div>產品說明</div>
	<div>技術文件</div>
	<div id="shareBlock" class="d-flex align-items-center justify-content-end">
		<div>分享：</div>
	</div>
</div>

<div id="ProductDescription" class="container">
	<p class="p-3">產品說明內文</p>

	<div id="Warn" class="d-flex">
	</div>

	<img class="py-2" src="~/images/banner/Home/banner.jpg" alt="" />

	<iframe src="https://www.youtube.com/embed/JGEj2nhPvDs" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>

	<img class="py-2" src="~/images/banner/Home/banner.jpg" alt="" />

</div>


