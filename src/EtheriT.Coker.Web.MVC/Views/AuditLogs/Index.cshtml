@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Dto.AuditLog;
@{
    ViewData["Title"] = "AuditLogs";
}

<div class="py-2 px-4 position-relative">
    <div id="TopLine" class="d-flex justify-content-between mb-4">
        <div class="d-flex">
            <button class="btn_back bg-transparent border-0 align-items-center d-none">
                <span class="material-symbols-outlined">
                    keyboard_backspace
                </span>
            </button>
            <div class="title fw-bold fs-4">操作紀錄</div>
        </div>
    </div>

    <div id="AuditLogList" class="card border-0">
        <div class="card-body position-relative pb-5">
            @(
                Html.DevExtreme().DataGrid<AuditLogListDto>()
                .DataSource(d => d.RemoteController().Key("Id")
                .LoadUrl("/api/AuditLog/GetAllList").LoadMethod("Get")
                )
                .RemoteOperations(true)
                .ColumnHidingEnabled(true)
                .ShowBorders(true)
                .FilterRow(filterRow => filterRow
                .Visible(true)
                .ApplyFilter(GridApplyFilterMode.Auto)
                )
                .SearchPanel(searchPanel => searchPanel
                .Visible(true)
                .Width(480)
                .Placeholder("請輸入要搜尋的資料")
                )
                .ShowRowLines(true)
                .Columns(c =>
                {
                    c.AddFor(e => e.ServiceName).Caption("服務名稱");
                    c.AddFor(e => e.MethodName).Caption("方法名稱");
                    c.AddFor(e => e.ClientName).Caption("使用者名稱");
                    c.AddFor(e => e.ExecutionTime).Format("yyyy/MM/dd HH:mm:ss").Caption("執行時間").SortOrder(SortOrder.Desc);
                    c.AddFor(e => e.ClientIpAddress).Caption("IP");
                    c.AddFor(e => e.Parameters).Caption("參數").AllowHiding(true);
                    c.AddFor(e => e.ReturnValue).Caption("回應").AllowHiding(true);
                })
                .ColumnAutoWidth(true)
                .Paging(paging => paging.PageSize(30))
                .Pager(pager =>
                {
                    pager.Visible(true);
                    pager.ShowPageSizeSelector(true);
                    pager.AllowedPageSizes(new[] { 10, 20, 30 });
                    pager.ShowInfo(true);
                })
                )
        </div>
    </div>
</div>