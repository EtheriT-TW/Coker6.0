@{
}

<link rel="stylesheet" href="~/css/Page/ShoppingCar.min.css" asp-append-version="true" />
<script src="~/js/Page/ShoppingCar.min.js" asp-append-version="true"></script>

<div class="history">
</div>

<form id="stepform" class="container-fluid py-5">
	<ul id="stepprogressbar" class="overflow-hidden">
		<li data-translation="step1" class="active now text-center"></li>
		<li data-translation="step2" class="text-center"></li>
		<li data-translation="step3" class="text-center"></li>
		<li data-translation="step4" class="text-center"></li>
	</ul>

	<div id="memberLogin" class="container my-5">
		<div class="rounded-1 d-flex align-items-center px-3 py-4 bg-white">
			<div>購買前登入會員可更方便查詢訂單！</div>
			<button class="bg-transparent rounded-1 mx-2">會員登入</button>
		</div>
	</div>

	<fieldset class="step1 container active">
		<div class="bg-white">
			<div class="title px-3 py-2">
				<div class="fs-5 my-2">購買明細</div>
			</div>

			<div class="content bg-white">
				<div class="my-5 px-3">這是區塊一</div>
			</div>

			<div class="selectbutton d-flex justify-content-center">
				<button class="btn_prev border-0 rounded-3 text-white mx-2 my-5">返回購物</button>
				<button class="btn_next border-0 rounded-3 text-white mx-2 my-5">下一步</button>
			</div>
		</div>
	</fieldset>

	<fieldset class="step2 container">
		<div class="bg-white">
			<div class="title px-3 py-2">
				<div class="fs-5 my-2">購買明細</div>
			</div>

			<div class="content bg-white">
				<div class="my-5 px-3">這是區塊二</div>
			</div>

			<div class="selectbutton d-flex justify-content-center">
				<button class="btn_prev border-0 rounded-3 text-white mx-2 my-5">返回購物</button>
				<button class="btn_next border-0 rounded-3 text-white mx-2 my-5">下一步</button>
			</div>
		</div>
	</fieldset>

	<fieldset class="step3 container">
		<div class="bg-white">
			<div class="title px-3 py-2 d-flex align-items-center justify-content-between">
				<div class="fs-5 my-2">購買明細</div>
				<button class="bg-transparent px-4 py-2 text-decoration-underline">我要再選購</button>
			</div>

			<div class="content bg-white">
				<div class="my-5 px-3">這是區塊三</div>
			</div>
		</div>
	</fieldset>
</form>