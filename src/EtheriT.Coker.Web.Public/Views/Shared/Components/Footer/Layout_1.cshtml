@using EtheriT.Coker.Web.Public.Views.Shared.Components.Footer
@using EtheriT.Coker.Application.Shared.i18n;
@model FooterViewModel

<link rel="stylesheet" href="~/css/Footer/Footer_Layout_1.min.css" asp-append-version="true" />
<script src="~/js/Footer/Footer_Layout_1.min.js" asp-append-version="true"></script>

@if (Model.footerViewModels != null && Model.footerViewModels.Count > 0)
{
    <div id="Collapse_Button" class="center">
        <i class="fa-solid fa-chevron-down text-black"></i>
    </div>
    <div class=" container listMenu d-flex justify-content-center align-items-center">
        <div id="Footer_Menu">
            <div class="FooterMenuList abreast row row-cols-2">
                @foreach (var menu in Model.footerViewModels)
                {
                    <div class="paging_frame col">
                        @if (string.IsNullOrEmpty(menu.Link))
                        {
                            <p>@menu.Title</p>
                        }
                        else
                        {
                            <p><a href="@menu.Link" title="連結至：@menu.Title">@menu.Title</a></p>
                        }
                        <div class="abreast">
                            <ul>
                                @foreach (var sub_menu in menu.footerViewModels ?? new List<FooterViewModel>())
                                {
                                    <li><a href="@sub_menu.Link" class="text-white">@sub_menu.Title</a></li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
<div id="Footer_Bottom" class="center">
    <div id="Logo_Bottom">
        <div></div>
        <span><a href="/" title="連結至：首頁"><img src="@Model.Logo_Image" width="120" alt="@ViewData["OrgName"]" asp-append-version="true" /></a></span>
    </div>
    <div id="Other_Web_Button" class=" center">
        @if (!string.IsNullOrEmpty(Model.Facebook_Link))
        {
            <a href="@Model.Facebook_Link" title="連結至:粉絲團(另開新視窗)" target="_blank" class="link_icon"><i class="fa-brands fa-facebook-f"></i></a>
        }
        @if (!string.IsNullOrEmpty(Model.YoutubeChannel_Link))
        {
            <a href="@Model.YoutubeChannel_Link" title="連結至:YT頻道(另開新視窗)" target="_blank" class="link_icon"><i class="fa-brands fa-youtube"></i></a>
        }
        @if (!string.IsNullOrEmpty(Model.IG_Link))
        {
            <a href="@Model.IG_Link" title="連結至:IG粉絲團(另開新視窗)" target="_blank" class="link_icon"><i class="fa-brands fa-instagram"></i></a>
        }
        @if (!string.IsNullOrEmpty(Model.LINE_Link))
        {
            <a href="@Model.LINE_Link" title="連結至:LINE(另開新視窗)" target="_blank" class="link_icon"><i class="fa-brands fa-line"> </i></a>
        }
        @if (Model.Other_Image_Link != null && Model.Other_Image_Link.Any())
        {
            @foreach (var data in Model.Other_Image_Link)
            {
                <a href="@data.Link" title="連結至:@data.Title" target="_blank" class="link_image"><img src="@data.Source" alt="@data.Name" asp-append-version="true" /></a>
            }
        }
    </div>
    @if (Model.Content != null)
    {
        <div id="Copyright" class="abreast">
            @for (int i = 0; i < Model.Content.Count; i++)
            {
                <p>@Model.Content[i]</p>
            }
        </div>
    }
</div>