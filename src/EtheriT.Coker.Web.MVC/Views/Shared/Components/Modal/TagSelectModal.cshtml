@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Tag
@using EtheriT.Coker.Web.MVC.Extensions

<link rel="stylesheet" href="~/css/Components/TagListModal.min.css" asp-append-version="true" />
<script src="~/js/Components/TagListModal.min.js" asp-append-version="true"></script>
@{
    await Html.RenderPartialAsync(@"DevExpress\_GridCSRF");
    var hasManySystem = Context.CheckHasManySystem();
}
<div id="TagModal" class="modal fade" tabindex="-1" aria-labelledby="Tag Modal Label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">選擇標籤</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="bg-white p-3">
                    @(
                        Html.DevExtreme().DataGrid<TagGetAllListDto>()
                        .DataSource(d => d.RemoteController().Key("Id")
                        .LoadUrl("/api/Tag/GetAllList?tid=null").LoadMethod("Get")
                        .LoadParams(new { tids = new JS("getSelectSort") })
                        .InsertUrl("/api/Tag/TagAddUp").InsertMethod("Post")
                        .OnBeforeSend("onBeforeSend")
                        )
                        .ID("TagList")
                        .Selection(s =>
                        s.Mode(SelectionMode.Multiple).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always)
                        )
                        .RemoteOperations(true)
                        .ColumnHidingEnabled(false)
                        .ShowBorders(true)
                        .FilterRow(filterRow => filterRow
                            .Visible(true)
                            .ApplyFilter(GridApplyFilterMode.OnClick)
                        )
                        .SearchPanel(searchPanel => searchPanel
                        .Visible(true)
                        .Placeholder("請輸入要搜尋的資料")
                        )
                        .Editing(editing =>
                        {
                            editing.Mode(GridEditMode.Row);
                            editing.AllowAdding(true);
                            editing.NewRowPosition(GridNewRowPosition.ViewportTop);
                            editing.UseIcons(true);
                        })
                        .OnEditorPreparing("onTagGridEditorPreparing")
                        .Columns(c =>
                        {
                            c.AddFor(e => e.IsSelected).Caption("是否勾選").Visible(false).AllowEditing(false).SortOrder(SortOrder.Desc);
                            if (hasManySystem)
                            {
                                c.AddFor(e => e.SiteNameTitle).Caption("網站名稱").Width(150).AllowEditing(false);
                            }
                            c.AddFor(e => e.TagGroupTitle).Caption("群組名稱").Width(150).AllowEditing(false).Lookup(lookup => lookup
                                .DataSource(ds => ds.RemoteController()
                                    .LoadUrl("/api/Tag/TagGroupLookUp")
                                    .LoadMethod("Get")
                                )
                                .ValueExpr("tagGroupTitle")
                                .DisplayExpr("tagGroupTitle")
                            );
                            c.AddFor(e => e.Title).Caption("標籤名稱").Width(150);
                        })
                        .Toolbar(toolbar =>
                        {
                            toolbar.Items(items =>
                            {
                                items.Add()
                            .Location(ToolbarItemLocation.Before)
                            .Widget(w =>
                            w.Button()
                            .Text("選項清除")
                            .Disabled(true)
                            .OnClick("TagList_ClearBtnClick")
                            .OnInitialized("TagList_ClearBtnInit")
                            );
                            });
                            toolbar.Items(i =>
                            {
                                i.Add()
                            .Name(DataGridToolbarItem.AddRowButton)
                            .ShowText(ToolbarItemShowTextMode.Always)
                            .Location(ToolbarItemLocation.Before);
                            });
                            toolbar.Items(i =>
                            {
                                i.Add()
                            .Name(DataGridToolbarItem.SearchPanel)
                            .ShowText(ToolbarItemShowTextMode.Always)
                            .Location(ToolbarItemLocation.After);
                            });
                        })
                        .OnSelectionChanged("TagList_SelectChange")
                        .OnContentReady("tagContentReady")
                        .OnRowInserting("dataSaving")
                        .OnRowUpdating("dataSaving")
                        .Paging(paging => paging.PageSize(10))
                        )
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn_tag_save btn btn-primary">確認</button>
            </div>
        </div>
    </div>
</div>