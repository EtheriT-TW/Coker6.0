@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Product
@{
	ViewData["Title"] = "SpecSetting";
}

<link rel="stylesheet" href="~/css/ProductManagement/SpecSetting.min.css" asp-append-version="true" />
<script src="~/js/ProductManagement/SpecSetting.min.js" asp-append-version="true"></script>

<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-3 px-4">
		<div class="title fw-bold fs-3">規格設定</div>
	</div>

	<div id="" class="py-2">
		<div id="SpecSettingList" class="card border-0">
			<div class="card-body position-relative">
				<button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
					<span class="material-symbols-outlined">add</span>
				</button>
				@(
					Html.DevExtreme().DataGrid<ProductGetAllSpecListDto>()
					.DataSource(d => d.RemoteController().Key("Id")
					.LoadUrl("/api/Product/GetAllSpecList").LoadMethod("Get")
					)
					.RemoteOperations(true)
					.ColumnHidingEnabled(true)
					.ShowBorders(true)
					.FilterRow(filterRow => filterRow
					.Visible(true)
					.ApplyFilter(GridApplyFilterMode.Auto)
					)
					.SearchPanel(searchPanel => searchPanel
					.Visible(true)
					.Width(480)
					.Placeholder("請輸入要搜尋的資料")
					)
					.ShowRowLines(true)
					.Columns(c =>
					{
						c.AddFor(e => e.Id).Caption("編號").Width(50);
						c.AddFor(e => e.Type).Caption("規格類型");
						c.AddFor(e => e.Title).Caption("規格名稱");
						c.Add()
						.Type(GridCommandColumnType.Buttons)
						.Buttons(b =>
						{
							b.Add().Name("edit").OnClick("editButtonClicked");
							b.Add().Name("delete").OnClick("deleteButtonClicked");
						});
					})
					.ColumnAutoWidth(true)
					.Paging(paging => paging.PageSize(30))
					.Pager(pager =>
					{
						pager.Visible(true);
						pager.ShowPageSizeSelector(true);
						pager.AllowedPageSizes(new[] { 10, 20, 30 });
						pager.ShowInfo(true);
					})
					.Editing(editing =>
					{
						editing.AllowDeleting(true);
						editing.AllowUpdating(true);
						editing.UseIcons(true);
					})
					.OnContentReady("contentReady")
					)
			</div>
		</div>

		<div id="SpecSettingContent" class="card border-0 d-none">
			<div class="card-header d-flex justify-content-between">
				<div class="fw-bold fs-5 d-flex align-items-center">
					<button class="btn_back d-flex bg-transparent border-0 align-items-center">
						<span class="material-symbols-outlined">
							keyboard_backspace
						</span>
					</button>
					<div class="lh-lg">規格設置</div>
				</div>
				<div class="d-flex">
					<button class="btn_done btn-primary border-0 rounded px-sm-4 px-2 py-1 text-white" form="SpecSettingForm">發布</button>
				</div>
			</div>

			<form id="SpecSettingForm" class="card-body needs-validation">
				<div class="title input-group mb-3">
					<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up required_text">
						<span class="material-symbols-outlined me-1 required_sign">image</span>規格類型
					</div>
					<input id="InputType " class="form-control rounded-right" list="TypeList" placeholder="規格選項" required>
					<datalist id="TypeList">
						<option value="顏色" data-tid="1"></option>
						<option value="尺寸" data-tid="1"></option>
						<option value="其他" data-tid="1"></option>
					</datalist>
				</div>

				<div class="title input-group mb-3">
					<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up required_text">
						<span class="material-symbols-outlined me-1 required_sign">image</span>規格名稱
					</div>
					<input id="InputTitle" class="form-control rounded" type="text" aria-label="Input Name of Freight" autocomplete="off" required>
					<div class="icon_hint position-absolute ps-2 top-50 end-0 d-flex translate-middle-y z-index-up" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="建議輸入正確圖片說明，可以增加搜尋度">
						<span class="material-icons me-1">help</span>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>

