@using EtheriT.Coker.Application.Shared.Dto.Advertise;
@using EtheriT.Coker.Application.Shared.Dto.HtmlContent
@using EtheriT.Coker.Application.Shared.Dto.enumType.Processor
@using EtheriT.Coker.Application.Shared.i18n;
@using EtheriT.Coker.Web.Public.Views.Shared.Components.SideFloating
@model SideFloatingViewModel
@{
    var nonce = ViewContext.HttpContext.Items["CSPNonce"] as string;
    ViewBag.Nonce = nonce;
}
<link rel="stylesheet" href="~/css/SideFloating/SideFloating.min.css" asp-append-version="true" />
<script src="~/js/SideFloating/SideFloating.min.js" asp-append-version="true"></script>

<div id="Floating_Center" class="position-fixed flex-column align-items-center">
	@if (Model.rightSideAd.Count > 0)
	{
        @foreach (var rightSideAd in Model.rightSideAd ?? new List<AdvertiseDisplayDto>())
        {
            var image = rightSideAd.FileLink?.FirstOrDefault()?.Link ?? "";
            var actionType = (int)rightSideAd.ActionType;
            var target = rightSideAd.Target == true ? "_blank" : "_self";
            var rel = rightSideAd.Target == true ? "noopener noreferrer" : "";
            var title = rightSideAd.Target == true
            ? L.get("LinkToAndBlank", rightSideAd.Title)
            : L.get("LinkTo", rightSideAd.Title);

            if (string.IsNullOrWhiteSpace(image))
            {
                continue;
            }

            <div class="side-floating-item"
                 data-aid="@rightSideAd.Id"
                 data-action-type="@actionType">

                @if (actionType == 1 && !string.IsNullOrWhiteSpace(rightSideAd.Link))
                {
                    <a href="@rightSideAd.Link"
                       target="@target"
                       rel="@rel"
                       title="@title"
                       class="side-floating-trigger">
                        <img class="my-1 shadow" src="@image" alt="@rightSideAd.Title">
                    </a>
                }
                else if (actionType == 2)
                {
                    <button type="button"
                            class="side-floating-trigger side-floating-expand-trigger bg-transparent border-0 p-0"
                            aria-expanded="false"
                            aria-controls="SideFloatingPanel_@rightSideAd.Id"
                            aria-label="@rightSideAd.Title">
                        <img class="side-floating-trigger-image my-1 shadow"
                             src="@image"
                             alt="@rightSideAd.Title">

                        <span class="side-floating-trigger-close"
                              aria-hidden="true">×</span>
                    </button>

                    <div id="SideFloatingPanel_@rightSideAd.Id"
                         class="side-floating-panel d-none"
                         data-side-floating-panel>

                        @if (!string.IsNullOrWhiteSpace(rightSideAd.Css))
                        {
                            <style nonce="@Model.Nonce">
                                @Html.Raw(rightSideAd.Css)
                            </style>
                        }

                        <div class="side-floating-content js-form-source" data-form-title="@rightSideAd.Title" data-source-type="@((int)HtmlSanitizeSourceType.廣告)" data-source-id="@rightSideAd.Id">
                            <coker-safe-html content="@rightSideAd.Html"
                                             website-id="@Model.WebsiteId"
                                             source-type="@HtmlSanitizeSourceType.廣告"
                                             source-id="@rightSideAd.Id"
                                             content-key="Published"
                                             sanitize-policy="PublicHtml">
                            </coker-safe-html>
                        </div>
                    </div>
                }
                else
                {
                    <img class="my-1 shadow" src="@image" alt="@rightSideAd.Title">
                }
            </div>
        }
	}
	@if (false)
	{
		<div id="History" class="text-end">
			<div id="CollapseHistory" class="d-none">
				<div class="title text-center text-white">瀏覽紀錄</div>
				<ul class="history_list m-0"></ul>
				@if (ViewBag.ShoppingEnable != null && ViewBag.ShoppingEnable && ViewBag.storeBuyState.IndexOf("noPay") < 0)
				{
					<a class="collect d-flex justify-content-center align-items-center text-white mb-1" href="/@ViewData["OrgName"]/Favorites">
						<i class="fa-solid fa-regular fa-heart px-1"></i>
						<div class="text">收藏</div>
						<div class="amount px-1">20</div>
					</a>
					<a class="checkout d-flex justify-content-center align-items-center text-white py-1 mb-1" href="/@ViewData["OrgName"]/ShoppingCar">
						<i class="fa-solid fa-cart-shopping px-1"></i>
						<div class="text px-1">結帳</div>
					</a>
				}
			</div>
		</div>
	}
</div>

<div id="Floating_Bottom" class="position-fixed d-flex flex-column align-items-center bottom-0 end-0 pb-2">
	@if (Model.Chatbot)
	{
		<button id="btn_chat" class="bg-transparent border-0 rounded-circle">
			<img class="img-fluid" src="~/upload/icon-linechat.png" alt="" />
		</button>
		<div id="Chatbot_Frame" class="card position-absolute border-0">
			<div class="card-header fw-bold">LINE</div>
			<div class="card-body text-center">
				<figure class="m-0">
					<img class=" card-img-topw-50" src="~/upload/QRcode_linechatbot.png" alt="Chatbot QRcode">
					<figcaption>
						<div class="mt-3">透過行動條碼加入LINE好友</div>
					</figcaption>
				</figure>
				<div>或直接點擊下方按鈕進行連結</div>
				<a class="h-100 rounded" href="line://ti/p/&#64;993kweuu?oat_referrer=PROFILE"><div class="btn_gochat mt-2 py-1">前往聊天</div></a>
			</div>
		</div>
	}
	<button id="btn_gotop" class="bg-black border-0 text-white">
		<i class="fa-solid fa-chevron-up"></i>
		<div>Top</div>
	</button>
</div>