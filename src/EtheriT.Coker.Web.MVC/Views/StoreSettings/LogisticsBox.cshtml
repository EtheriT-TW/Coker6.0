@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Freight
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal
@{
	ViewData["Title"] = "LogisticsBox";
}

<link rel="stylesheet" href="~/css/StoreSettings/LogisticsBox.min.css" asp-append-version="true" />
<script src="~/js/StoreSettings/LogisticsBox.min.js" asp-append-version="true"></script>

<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-4">
		<div class="d-flex">
			<div class="title fw-bold fs-3">箱型設定</div>
		</div>
	</div>

	<div id="" class="py-2">
		<div id="LogisticsBoxList" class="card border-0">
			<div class="card-body position-relative pb-5">
				<button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
					<span class="material-symbols-outlined">add</span>
				</button>
				@(
					Html.DevExtreme().DataGrid<GetLogisticsBoxAllListInputDto>()
						.DataSource(d => d.RemoteController().Key("Id")
						.LoadUrl("/api/Freight/GetLogisticsBoxAllList").LoadMethod("Get")
						)
						.RemoteOperations(true)
						.ColumnHidingEnabled(true)
						.ShowBorders(true)
						.FilterRow(filterRow => filterRow
						.Visible(true)
						.ApplyFilter(GridApplyFilterMode.Auto)
						)
						.SearchPanel(searchPanel => searchPanel
						.Visible(true)
						.Width(480)
						.Placeholder("請輸入要搜尋的資料")
						)
						.ShowRowLines(true)
						.Columns(c =>
						{
							c.AddFor(e => e.Id).Caption("編號").Width(50);
							c.AddFor(e => e.Name).Caption("標題");
							c.AddFor(e => e.Sort).Caption("排序");
							c.AddFor(e => e.IsActive).Caption("顯示");
							c.Add().Type(GridCommandColumnType.Buttons)
								.Buttons(b =>
								{
									b.Add().Name("edit").OnClick("editButtonClicked");
									b.Add().Name("delete").OnClick("deleteButtonClicked");
								});
						})
						.ColumnAutoWidth(true)
						.Paging(paging => paging.PageSize(30))
						.Pager(pager =>
						{
							pager.Visible(true);
							pager.ShowPageSizeSelector(true);
							pager.AllowedPageSizes(new[] { 10, 20, 30 });
							pager.ShowInfo(true);
						})
						.Editing(editing =>
						{
							editing.AllowDeleting(true);
							editing.AllowUpdating(true);
							editing.UseIcons(true);
						})
						.OnContentReady("contentReady")
						)
			</div>
		</div>

		<div id="LogisticsBoxContent" class="card border-0 d-none">
			<div class="card-header d-flex justify-content-between">
				<div class="fw-bold fs-5 d-flex align-items-center">
					<button class="btn_back d-flex bg-transparent border-0 align-items-center">
						<span class="material-symbols-outlined">
							keyboard_backspace
						</span>
					</button>
					<div class="lh-lg title"></div>
				</div>
				<button class="btn_done btn-primary border-0 px-3 py-1 text-white" form="LogisticsBoxForm">　儲存　</button>
			</div>

			<form id="LogisticsBoxForm" class="card-body needs-validation">
				<input name="Id" type="hidden" />

				<div class="row g-3">
					<div class="col-12 col-lg-6">
						<label for="InputName" class="form-label fw-bold">名稱</label>
						<input id="InputName" class="form-control" type="text" maxlength="50" autocomplete="off" required />
						<div class="invalid-feedback">請輸入箱型名稱。</div>
					</div>

					<div class="col-12 col-lg-3">
						<label for="InputCapacityPoint" class="form-label fw-bold">容量點數</label>
						<input id="InputCapacityPoint" class="form-control" type="number" min="1" step="1" required />
						<div class="form-text">此箱型可承載的 PackingPoint 上限。</div>
						<div class="invalid-feedback">請輸入大於 0 的整數。</div>
					</div>

					<div class="col-12 col-lg-3">
						<label for="InputSort" class="form-label fw-bold">排序</label>
						<input id="InputSort" class="form-control" type="number" step="1" value="0" required />
						<div class="invalid-feedback">請輸入排序值。</div>
					</div>

					<div class="col-12 col-lg-4">
						<div class="form-check form-switch mt-2">
							<input id="InputIsActive" class="form-check-input" type="checkbox" checked />
							<label class="form-check-label fw-bold" for="InputIsActive">啟用箱型</label>
						</div>
						<div class="text-muted small mt-1">停用後保留資料，但不建議提供新設定使用。</div>
					</div>

					<div class="col-12">
						<div class="alert alert-light border mb-0" role="alert">
							<div class="fw-bold mb-1">目前模式</div>
							<div id="BoxFormHint" class="text-muted">此頁目前僅完成前端互動，尚未串接儲存 API。</div>
						</div>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>