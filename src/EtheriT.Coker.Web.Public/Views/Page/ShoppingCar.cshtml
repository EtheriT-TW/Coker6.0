									<input id="OrdererInputName" class="orderer_name form-control" type="text" placeholder="name" value="姓名" minlength="2" required>
									<label class="required" for="OrdererInputName">姓　　名</label>
								</div>
								<div class="gender d-flex align-self-center col-12 col-sm-6 mb-3">
									<div class="form-check pe-3">
										<input id="OrdererRadioSir" class="form-check-input" type="radio" name="OrdererRadioGender" value="1" required checked>
										<label class="form-check-label" for="RadioSir">男</label>
