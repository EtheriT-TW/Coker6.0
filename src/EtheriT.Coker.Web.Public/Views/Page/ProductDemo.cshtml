@using EtheriT.Coker.Web.Public.Views.Shared.Components.Modal
@model PageViewModel
@{
	ViewData["SideName"] = Model.PageData.SiteName;
	ViewData["PageName"] = Model.PageData.Title;
	ViewData["OrgName"] = Model.orgName;
	ViewData["Description"] = Model.PageData.Description;
	ViewData["CurrentUrl"] = Model.PageData.CurrentUrl;
	ViewData["VisibleHeader"] = Model.PageData.VisibleHeader;
	ViewData["VisibleFooter"] = Model.PageData.VisibleFooter;
}

<link rel="stylesheet" href="~/css/Page/Product.css" asp-append-version="true" />
<script src="~/js/Page/Product.js" asp-append-version="true"></script>

<div id="ShoppingCarModal" class="modal fade" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
	@await Component.InvokeAsync(nameof(Modal), new {dispaly = "ShoppingCarModal"})
</div>

<nav id="Breadcrumb" class="container mt-3" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a href="/@ViewData["OrgName"]/home">首頁</a></li>
		<li class="breadcrumb-item">Derek商品</li>
		<li class="breadcrumb-item active" aria-current="page">馬桶</li>
	</ol>
</nav>

<div id="Filter" class="container-fluid">
	<div class="container row m-auto  px-0 py-3 justify-content-sm-between justify-content-center align-items-center">
		<div class="col-auto col-md row align-items-center">
			<div class="title col-auto fs-3 fw-bold">馬桶</div>
			<div class="total col-auto">共<span>50</span>個品項</div>
		</div>
		<div class="sort col-auto d-flex align-items-center">
			<button class="btn_sort_hot border-0 bg-transparent">熱門搜尋</button>
			<button class="btn_sort_price border-0 bg-transparent">
				價格<i class="fa-solid fa-arrows-up-down"></i>
			</button>
			<button class="btn_view_type align-items-center bg-transparent border-0 d-flex p-0" type="button" data-type="1">
				<span class="material-symbols-outlined">grid_view</span>
			</button>
		</div>
		<div class="range col-auto row mt-1 mt-sm-0">
			<label for="priceLow" class="d-none">最低價</label>
			<input id="priceLow" class="price_low col px-1 text-end" type="number" placeholder="最低價">
			<div class="text-center col-auto align-self-center">~</div>
			<label for="priceHigh" class="d-none">最高價</label>
			<input id="priceHigh" class="price_high col px-1 text-end" type="number" placeholder="最高價">
			<button class="btn_confirm border-0 text-white col-auto ms-2" type="button">確認</button>
		</div>
	</div>
</div>

<div class="container">
	<div class="tag_category row border m-auto mt-4 mb-0 align-items-center">
		<div class="title col-auto px-4 hstack">分類</div>
		<ul class="col row my-2"></ul>
	</div>
</div>

<div class="fs-2 my-4 text-center">猜您會喜歡</div>
<div id="GuessYouLikeSwiper" class="swiper_four_grid container-fluid position-relative">
	<div class="swiper container">
		<div class="swiper-wrapper py-5"></div>
	</div>

	<div class="swiper_button container d-flex p-0 justify-content-between position-absolute start-50 top-50 translate-middle">
		<button class="btn_swiper_prev_guessyoulike bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-left fa-stack-1x fa-inverse opacity-75"></i>
			</span>
		</button>

		<button class="btn_swiper_next_guessyoulike bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-right fa-stack-1x fa-inverse opacity-75"></i>
			</span>
		</button>
	</div>
	<div class="swiper-scrollbar"></div>
</div>

<div id="Ads" class="container-fluid">
	<div class="container">
		<div class="fs-4 fw-bold py-3">廣告</div>
		<div class="card-group">
			<div class="card bg-transparent border-0 me-sm-2 m-0">
				<a href=""><img class="card-img-top w-100" src="~/upload/hotad1.jpg" alt="ads_1" /></a>
				<figcaption class="card-body">
					<a class="card-text text-black" href="">母親節來臨，以全新獨立式浴缸系列與「淨未來瞬熱式微電腦馬桶座」，給天下媽媽們一份療癒身心之禮</a>
				</figcaption>
				<ul class="card-footer row bg-transparent border-0 m-0">
					<li class="col-auto ps-0">淨未來</li>
					<li class="col-auto ps-0">全自動</li>
					<li class="col-auto ps-0">冷熱SPA按摩</li>
				</ul>
			</div>
			<figure class="card bg-transparent border-0 ms-sm-2 m-0">
				<a href=""><img class="card-img-top w-100" src="~/upload/hotad2.jpg" alt="ads_2" /></a>
				<figcaption class="card-body">
					<a class="card-text text-black" href="">Derek獨立式美型缸系列，以壓克力材質形塑柔和輪廓，分為經典款、魅力款、個性款、古典款，造型多樣、擺放自由度高，完美匹配多種裝潢風格。</a>
				</figcaption>
				<ul class="card-footer row bg-transparent border-0 m-0">
					<li class="col-auto ps-0">浴缸</li>
					<li class="col-auto ps-0">新品</li>
				</ul>
			</figure>
		</div>
	</div>
</div>

<div id="Catalog" class="container bg-warning row m-auto my-5 justify-content-center">
	<div class="text col-md-4 my-5 align-self-center">
		<div class="fs-3 fw-bold">2022</div>
		<div class="align-items-center d-flex fs-2 fw-bold">
			最新型錄
			<span class="fa-stack fa-stack fs-6">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<a href="/@ViewData["OrgName"]/Catalog">
					<i class="fa-solid fa-chevron-right fa-stack-1x fa-inverse"></i>
				</a>
			</span>
		</div>
		<div class="fs-5 fw-bold">淨．善．靚．美</div>
		<div>用最好的智慧馬桶，守護家的健康生活</div>
	</div>

	<div class="col-md-4 col-sm-12 align-self-center text-center">
		<img class="m-5 w-75" src="~/upload/mu_0.png" alt="" />
	</div>
</div>

<div class="fs-2 my-4 text-center">熱門商品</div>
<div id="HotProductsSwiper" class="swiper_four_grid container-fluid position-relative">
	<div class="swiper container">
		<div class="swiper-wrapper py-5"></div>
	</div>

	<div class="swiper_button container d-flex p-0 justify-content-between position-absolute start-50 top-50 translate-middle">
		<button class="btn_swiper_prev_hotproducts bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-left fa-stack-1x fa-inverse opacity-75"></i>
			</span>
		</button>

		<button class="btn_swiper_next_hotproducts bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-right fa-stack-1x fa-inverse opacity-75"></i>
			</span>
		</button>
	</div>
</div>

<div id="Badge" class="container row row-cols-1 row-cols-sm-2 row-cols-lg-4 text-center m-auto my-5 position-relative">
	<figure class="col mb-sm-5 mb-lg-0">
		<img class="w-25" src="~/upload/pro_icon1.jpg" alt="" />
		<figcaption>
			<h5 class="card-title fw-bold">安心線上付款</h5>
			<div class="card-text">透過SSL加密機制<br>提供安全信用卡付款</div>
		</figcaption>
	</figure>

	<div class="vr position-absolute translate-middle-y px-0"></div>

	<figure class="col">
		<img class="w-25" src="~/upload/pro_icon2.jpg" alt="" />
		<figcaption>
			<h5 class="card-title fw-bold">免運服務</h5>
			<div class="card-text">結帳商品滿<span class="price">8000</span>免運費</div>
		</figcaption>
	</figure>

	<div class="vr position-absolute end-50 translate-middle px-0"></div>

	<figure class="col">
		<img class="w-25" src="~/upload/pro_icon3.jpg" alt="" />
		<figcaption>
			<h5 class="card-title fw-bold">售後服務</h5>
			<div class="card-text">享有七天鑑賞期</div>
		</figcaption>
	</figure>

	<div class="vr position-absolute translate-middle-y px-0"></div>

	<figure class="col">
		<img class="w-25" src="~/upload/pro_icon4.jpg" alt="" />
		<figcaption>
			<h5 class="card-title fw-bold">商品問與答</h5>
			<div class="card-text">免費服務電話<br>0800-063366</div>
		</figcaption>
	</figure>
</div>

<div id="AdsSwiper" class="container position-relative">
	<div class="swiper">
		<div class="swiper-wrapper">
			<div class="swiper-slide">
				<img class="img-fluid" src="~/upload/proban1.jpg" alt="" />
			</div>
			<div class="swiper-slide">
				<img class="img-fluid " src="~/upload/pro_ban2.jpg" alt="" />
			</div>
		</div>
	</div>
	<div class="swiper_button container d-flex p-0 justify-content-between position-absolute start-50 top-50 translate-middle">
		<button class="btn_swiper_prev_ads border-0 p-0 text-center bg-transparent fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-left fa-stack-1x fa-inverse"></i>
			</span>
		</button>
		<button class="btn_swiper_next_ads border-0 p-0 text-center bg-transparent fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-right fa-stack-1x fa-inverse"></i>
			</span>
		</button>
	</div>
</div>

<div class="fs-2 my-4 text-center">相關商品</div>
<div id="RelatedProductsSwiper" class="swiper_four_grid container-fluid position-relative">
	<div class="swiper container">
		<div class="swiper-wrapper py-5"></div>
	</div>

	<div class="swiper_button container d-flex p-0 justify-content-between position-absolute start-50 top-50 translate-middle">
		<button class="btn_swiper_prev_relatedproducts bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-left fa-stack-1x fa-inverse opacity-75"></i>
			</span>
			<span class="d-none">上一頁</span>
		</button>

		<button class="btn_swiper_next_relatedproducts bg-transparent border-0 p-0 fs-3">
			<span class="fa-stack">
				<i class="fa-solid fa-circle fa-stack-2x"></i>
				<i class="fa-solid fa-chevron-right fa-stack-1x fa-inverse opacity-75"></i>
			</span>
			<span class="d-none">下一頁</span>
		</button>
	</div>
</div>

<template id="Template_ProdCard">
	<div class="swiper-slide">
		<figure class="prod_card card border-0 p-3">
			<a class="text-center" href="" alt=""><img class="card-img-top w-auto" src="" alt="" /></a>
			<figcaption>
				<div class="card-body position-relative">
					<div class="top_line position-absolute end-0">
						<button class="btn_favorites bg-transparent border-0">
							<i class="fs-5 fa-regular fa-heart"></i>
							<span class="d-none">關注</span>
						</button>
						<button class="btn_share bg-transparent border-0">
							<i class="fs-5 fa-solid fa-share"></i>
							<span class="d-none">分享</span>
						</button>
					</div>
					<h5 class="card-title price fw-bold"></h5>
					<div class="card-text lh-lg"><a class="text-black" href="" alt=""></a></div>
				</div>
				<div class="card-footer bg-transparent border-0 py-0 row g-0">
					<button class="btn_cart border-0 col-auto bg-transparent p-0" data-bs-toggle="modal" data-bs-target="#ShoppingCarModal">
						<span class="fa-stack">
							<i class="fa-solid fa-circle fa-stack-2x"></i>
							<i class="fa-solid fa-cart-shopping fa-stack-1x fa-inverse"></i>
						</span>
						<span class="d-none">放入購物車</span>
					</button>
				</div>
			</figcaption>
		</figure>
	</div>
</template>