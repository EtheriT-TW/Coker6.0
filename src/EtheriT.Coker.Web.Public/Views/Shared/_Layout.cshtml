    <div id="FlipBookModal" tabindex="-1" aria-labelledby="FlipBookModalLabel" aria-hidden="true" class="modal fade FlipBookModal">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" aria-label="Close" data-bs-dismiss="modal" id="idmmf" class="btn-close"></button>
                </div>
