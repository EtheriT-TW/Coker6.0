@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Advertise;
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal;
@{
    ViewData["Title"] = "右側浮動廣告";
}

<link rel="stylesheet" href="~/css/AdvertisementManagement/RightSideAd.min.css" asp-append-version="true" />
@{
    await Html.RenderPartialAsync(@"GrapesComponents\_ScriptComponents");
}
<script src="~/js/AdvertisementManagement/RightSideAd.min.js" asp-append-version="true"></script>

<div id="RightSideAdPage">
    <div id="TopLine" class="py-2 px-4">
        <div class="d-flex">
            <div class="title fw-bold fs-3">右側浮動廣告</div>
            <a class="btn btn-primary text-decoration-none align-self-center d-none" href="#" role="button">返回選單</a>
        </div>
    </div>

    <div id="PageContent">
        <div id="RightSideAdList" class="card border-0" data-hash-page="List">
            <div class="card-body position-relative">
                <button type="button"
                        class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none"
                        data-hash-go="new">
                    <span class="material-symbols-outlined">add</span>
                </button>
                @(
                        Html.DevExtreme().DataGrid<AdvertiseDto>()
                        .DataSource(d => d.RemoteController().Key("Id")
                        .LoadUrl("/api/Advertise/GetRightSideAdList").LoadMethod("Get")
                        )
                        .RemoteOperations(true)
                        .ColumnHidingEnabled(true)
                        .ShowBorders(true)
                        .FilterRow(filterRow => filterRow
                        .Visible(true)
                        .ApplyFilter(GridApplyFilterMode.Auto)
                        )
                        .SearchPanel(searchPanel => searchPanel
                        .Visible(true)
                        .Width(480)
                        .Placeholder("請輸入要搜尋的資料")
                        )
                        .ShowRowLines(true)
                        .Columns(c =>
                        {
                            c.AddFor(e => e.Title).Caption("名稱").Width(200);
                            c.AddFor(e => e.ImgLink).Caption("圖示")
                                                                            .AllowFiltering(false)
                                                                            .AllowSorting(false)
                                                                            .CellTemplate(
                                                                            @<text>
                                                                                <div class="list_img">
                                                                                    <img class="" src="<%- value %>" alt="" />
                                                                                </div>
                                                                            </text>
                                                                        );
                            c.AddFor(e => e.Link).Caption("連結").Width(200);
                            c.AddFor(e => e.SerNO).Caption("排序").Width(50);
                            c.AddFor(e => e.Visible).Caption("是否顯示").Width(90);
                            c.AddFor(e => e.Target).Caption("另開視窗").Width(90);
                            c.AddFor(e => e.StartTime).Caption("起始日期").Width(125);
                            c.AddFor(e => e.EndTime).Caption("結束日期").Width(125);
                            c.AddFor(e => e.permanent).Caption("永久顯示").Width(90);
                            c.Add()
                            .Type(GridCommandColumnType.Buttons)
                            .Buttons(b =>
                            {
                                b.Add().Name("edit").OnClick("editButtonClicked");
                                b.Add()
                                    .Icon("palette")
                                    .Hint("進階編輯")
                                    .Visible(new JS("showPaletteButton"))
                                    .OnClick("paletteButtonClicked");
                                b.Add().Name("delete").OnClick("deleteButtonClicked");
                            });
                        })
                    .ColumnAutoWidth(true)
                    .Paging(paging => paging.PageSize(30))
                    .Pager(pager =>
                    {
                        pager.Visible(true);
                        pager.ShowPageSizeSelector(true);
                        pager.AllowedPageSizes(new[] { 10, 20, 30 });
                        pager.ShowInfo(true);
                    })
                    .Editing(editing =>
                    {
                        editing.AllowDeleting(true);
                        editing.AllowUpdating(true);
                        editing.UseIcons(true);
                    })
                    .OnContentReady("contentReady")
                    )
            </div>
            <div class="text-end my-2 text-danger">※前台最多顯示4筆資料</div>
        </div>

        <div id="RightSideAdContent" class="card border-0 d-none" data-hash-page="Content">
            <div class="card-header d-flex justify-content-between">
                <div class="fw-bold fs-5 d-flex align-items-center">
                    <button type="button"
                            class="btn_back d-flex bg-transparent border-0 align-items-center"
                            data-hash-back>
                        <span class="material-symbols-outlined">
                            keyboard_backspace
                        </span>
                    </button>
                    <div class="lh-lg" data-hash-title>廣告設置</div>
                </div>
                <div class="d-flex">
                    <button class="btn_done btn-primary border-0 px-3 py-1 text-white" type="submit" form="AdForm">發　布</button>
                    <button class="js-edit-html-content btn-success border-0 px-3 py-1 text-white align-items-center btn d-none">
                        進階編輯<span class="material-symbols-outlined ms-1 text-white">palette</span>
                    </button>
                </div>
            </div>

            <form id="AdForm" class="card-body needs-validation" novalidate>
                <input name="id" type="hidden" />
                <div class="d-flex align-self-center justify-content-between mb-3">
                    <div class="d-flex flex-column align-items-center mb-1">
                        <div id="ImageUpload" class="d-flex justify-content-center image_upload" data-issinge="true" data-needcompress="false">
                            @await Component.InvokeAsync(nameof(Modal), new {dispaly = "ImageUploadModal"})
                        </div>
                    </div>
                    <input type="checkbox" id="AdFormVisible" class="selectedItem" name="visible" value="true" />
                    <label for="AdFormVisible" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上" class="d-flex align-items-center">
                        <span class="material-symbols-outlined fs-2">visibility</span>
                        <span class="material-symbols-outlined fs-2">visibility_off</span>
                    </label>
                </div>

                <div class="name input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">image</span>圖片名稱
                    </div>
                    <input id="InputName" class="form-control rounded" type="text" aria-label="Input Name of Freight" autocomplete="off" required name="title">
                    <div class="icon_hint position-absolute ps-2 top-50 end-0 d-flex translate-middle-y z-index-up" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="建議輸入正確圖片說明，可以增加搜尋度">
                        <span class="material-symbols-outlined me-1">help</span>
                    </div>
                </div>

                <div class="action_type mb-3">
                    <div class="ad-field-label">
                        <span class="material-symbols-outlined me-1 required_sign">touch_app</span>
                        前台互動方式
                    </div>

                    <select id="AdvertiseActionType"
                            class="form-select rounded"
                            name="actionType"
                            required>
                        <option value="1" selected>連結型廣告(啟用連結網址)</option>
                        <option value="2">內容展開型廣告(進階設定設置內容)</option>
                        <option value="3">純展示廣告(不設定)</option>
                    </select>
                </div>

                <div class="ad_link input-group mb-3 js-action-link">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">link</span>連結網址
                    </div>
                    <input type="text" id="AdvertiseLink" class="form-control rounded" placeholder="https://" aria-label="Recipient's username" aria-describedby="button-addon2" name="link" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up me-4">
                        <input id="TargetCheck" class="form-check-input" type="checkbox" value="true" name="target">
                        <label class="form-check-label fs-6 pe-2" for="TargetCheck">開新視窗</label>
                    </div>
                </div>

                <div class="sort input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">sort_by_alpha</span>排序
                    </div>
                    <input id="AdvertiseSerNO" class="form-control rounded" name="serNO" type="number" aria-label="Input Sort of Advertise" disabled="disabled" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up me-4">
                        <input id="AdvertiseSortCheck" class="form-check-input" name="sortCheckbox" data-form-type="disabled" data-direct="reverse" data-value="500" data-target="AdvertiseSerNO" type="checkbox" value="false">
                        <label class="form-check-label fs-6 pe-2" for="AdvertiseSortCheck">自訂排序</label>
                    </div>
                </div>

                <div class="date input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">calendar_today</span>調整顯示日期
                    </div>
                    <input id="InputDate" name="startEndDate" data-form-type="date_range" data-start="startTime" data-end="endTime" class="form-control rounded" type="text" aria-label="Input Duration of Product" pattern="[1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2} ~ [1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2}" autocomplete="off" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up me-4">
                        <input id="PermanentCheck" name="permanent" data-form-type="disabled" data-target="InputDate" class="form-check-input" type="checkbox" checked value="true">
                        <label class="form-check-label fs-6 pe-2" for="PermanentCheck">永久顯示</label>
                    </div>
                </div>
            </form>
        </div>

        <div id="RightSideAdHtmlContent" class="card border-0 d-none" data-hash-page="HtmlContent">
            <div id="gjs"></div>
        </div>
    </div>
</div>