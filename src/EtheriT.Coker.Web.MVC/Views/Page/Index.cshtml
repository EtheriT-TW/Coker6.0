@{
    ViewData["Title"] = "CustomPage";
}
<!--導入grapesjs-->
<link rel="stylesheet" href="/lib/grapesjs/css/grapes.min.css">
<script src="/lib/grapesjs/grapes.min.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-preset-webpage/index.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-blocks-basic/index.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-style-bg/grapesjs-style-bg.min.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-tabs/grapesjs-tabs.min.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-blocks-table/grapesjs-blocks-table.min.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-custom-code/index.js"></script>
<script src="/lib/grapesjs/plugin/grapesjs-tui-image-editor/index.js"></script>
<script src="~/js/Grapes/Index.min.js" asp-append-version="true"></script>
<!--導入menuEditor-->
<script type="text/javascript" src="/lib/jquery-menu-editor/jquery-menu-editor.min.js" asp-append-version="true"></script>
<script type="text/javascript" src="/lib/bootstrap/iconpicker/js/iconset/fontawesome5-3-1.min.js"></script>
<script type="text/javascript" src="/lib/bootstrap/iconpicker/js/bootstrap-iconpicker.min.js" asp-append-version="true"></script>
<!--導入頁面配置-->
<link rel="stylesheet" href="~/css/Page/index.min.css" asp-append-version="true" />
<script src="~/js/Page/index.min.js" asp-append-version="true"></script>

<div class="py-2 px-4 position-relative">
    <div id="TopLine" class="d-flex justify-content-between mb-4">
        <div class="title fw-bold fs-4">自訂頁面</div>
        <a class="btn btn-primary" data-bs-toggle="offcanvas" href="#offcanvasSite" role="button" aria-controls="offcanvasSite">
            網站地圖
        </a>
    </div>
</div>
<div id="gjs">
    <div class="container-fluid">
        <div class="row gjs-row">
            <div class="col-md-4 gjs-cell">
                One of three columns
            </div>
            <div class="col-md-4 gjs-cell">
                One of three columns
            </div>
            <div class="col-md-4 gjs-cell">
                One of three columns
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <label for="validationCustom01" class="form-label">First name</label>
        <input type="text" class="form-control" id="validationCustom01" value="Mark" required>
        <div class="valid-feedback">
            Looks good!
        </div>
        <table class="table"></table>
    </div>
</div>
<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasSite" aria-labelledby="offcanvasSiteLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="offcanvasSiteleLabel">網站地圖</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <div class="row">
            <button type="button" id="btnExtend" class="btn btn-primary d-flex justify-content-center">
                <span class="material-symbols-outlined">arrow_forward_ios</span>
                <span>新增選單</span>
            </button>
        </div>
        <div id="EditBlock" class="row">
            <ul id="myEditor" class="sortableLists list-group item-menu d-none"></ul>
            <div class="emptyList"></div>
            <div id="MenuEditorForm" class="card border-primary mb-3 item-menu">
                <div class="card-header bg-primary text-white">Edit item</div>
                <div class="card-body">
                    <form id="frmEdit" class="form-horizontal">
                        <input type="hidden" class="item-menu" name="Id" />
                        <input type="hidden" id="SerNO" name="SerNO" class="item-menu">
                        <div class="form-group">
                            <label for="Title">標題</label>
                            <div class="input-group">
                                <input type="text" class="form-control item-menu" id="Title" name="Title" placeholder="請輸入標題">
                                <div class="input-group-append">
                                    <button type="button" id="myEditor_icon" class="btn btn-outline-secondary"></button>
                                </div>
                            </div>
                            <input type="hidden" name="icon" class="item-menu">
                        </div>
                        <div class="form-group">
                            <label for="LinkUrl">連結</label>
                            <input type="text" class="form-control item-menu" id="LinkUrl" name="LinkUrl" placeholder="請輸入連結">
                        </div>
                        <div class="form-group">
                            <label for="Visible">是否顯示</label>
                            <select name="Visible" id="Visible" class="form-control item-menu">
                                <option value="true">是</option>
                                <option value="false">否</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="target">另開視窗</label>
                            <select name="Target" id="target" class="form-control item-menu">
                                <option value="true">是</option>
                                <option value="false">否</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="PopularVisible">顯示人氣值</label>
                            <select name="PopularVisible" id="PopularVisible" class="form-control item-menu">
                                <option value="true">是</option>
                                <option value="false">否</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="Popular">人氣值</label>
                            <input type="text" id="Popular" name="Popular" class="form-control item-menu" readonly>
                        </div>
                        <div class="form-group">
                            <label for="Description">描述</label>
                            <textarea type="text" id="Description" name="Description" class="form-control item-menu" placeholder="描述文字"></textarea>
                        </div>
                    </form>
                </div>
                <div class="card-footer">
                    <button type="button" id="btnUpdate" class="btn btn-primary" disabled><i class="fas fa-sync-alt"></i>更新</button>
                    <button type="button" id="btnAdd" class="btn btn-success"><i class="fas fa-plus"></i>新增</button>
                    <button type="button" id="btnRefresh" class="btn btn-info">
                        <i class="fa-sharp fa-solid fa-rotate-right"></i>清空
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>