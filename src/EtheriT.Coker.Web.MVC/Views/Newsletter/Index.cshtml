                            <h3>email使用title圖<br />(800*159)</h3>
                        </div>
                        <div class="align-self-center border-0 btn d-flex pb-0 pt-0">
                            <input id="VisibleConten3" type="checkbox" name="Visible" class="d-none selectedItem formItem" value="false" />
                            <label for="VisibleConten3" class="bg-transparent border-0 mb-0 text-primary d-flex align-self-center noselect" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="上架中">
                                <span class="material-symbols-outlined fs-2">open_in_new</span>
                                <span class="material-symbols-outlined fs-2">open_in_new_off</span>
                            </label>
                        </div>
                    </div>
                    <div class="mainTitle border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">標題</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" name="mainTitle" aria-label="With textarea" maxlength="50" placeholder="請輸入標題" required></textarea>
                    </div>
                    <div class="title border mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">子標題</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" name="Title" aria-label="With textarea" maxlength="50" placeholder="請輸入子標題" required></textarea>
                    </div>
                    <div class="memo">信箱最多截取前三筆</div>
                    @(Html.DevExtreme().DataGrid<NewsletterLinkDto>()
                        .ShowBorders(true)
                        .ElementAttr("data-name","List")
                        .OnContentReady("NewsletterReady")
                        .Paging(paging => paging.Enabled(false))
                        .Editing(editing =>
                        {
                            editing.Mode(GridEditMode.Row);
                            editing.AllowAdding(true);
                            editing.AllowDeleting(true);
                            editing.AllowUpdating(true);
                        }).Columns(c =>
                        {
                            c.AddFor(e => e.title).Caption("標題");
                            c.AddFor(e => e.memo).Caption("備註");
                            c.AddFor(e => e.conten).Caption("內文");
                            c.AddFor(e => e.link).Caption("連結");
                            c.AddFor(e => e.target).Lookup(lookup => lookup
                            .DataSource("getTarget")
                            .DisplayExpr("Name")
                            .ValueExpr("newWindow")
                            ).Caption("另開視窗");
                            c.AddFor(e => e.alert).Caption("提醒文字");
                        }).DataSource(new List<NewsletterLinkDto>())
                        )
                </div>
                <div data-key="footer" class="msf-view">
                    <div class="memo">固定兩個icon</div>
                    @(Html.DevExtreme().DataGrid<NewsletterLinkDto>()
                        .ShowBorders(true)
                        .ElementAttr("data-name", "List")
                        .OnContentReady("NewsletterReady")
                        .Paging(paging => paging.Enabled(false))
                        .Editing(editing =>
                        {
                            editing.Mode(GridEditMode.Row);
                            editing.AllowAdding(false);
                            editing.AllowDeleting(false);
                            editing.AllowUpdating(true);
                        }).Columns(c =>
                        {
                            c.AddFor(e => e.alert).Caption("提醒文字");
                            c.AddFor(e => e.link).Caption("連結");
                            c.AddFor(e => e.target).Lookup(lookup => lookup
                            .DataSource("getTarget")
                            .DisplayExpr("Name")
                            .ValueExpr("newWindow")
                            ).Caption("另開視窗");
                            c.AddFor(e => e.className).Visible(false).Caption("icon");
                        }).DataSource(new List<NewsletterLinkDto>())
                        )
                    <div class="conten border mt-3 mb-3 p-2 rounded">
                        <div class="d-flex justify-content-between w-100">
                            <span class="input-group-text bg-transparent border-0 p-0 required_all">內文</span>
                            <div class="count">0</div>
                        </div>
                        <textarea class="form-control border-0 formItem" name="Conten" aria-label="With textarea" maxlength="300" placeholder="請輸入內文" required></textarea>
                    </div>
                </div>
            </div>
            <div class="msf-navigation mt-3">
                <div class="row justify-content-center">
                    <div class="col-md-3">
                        <button type="button" data-type="back" class="btn btn-default msf-nav-button"><i class="fa fa-chevron-left"></i> 上一步 </button>
                    </div>

                    <div class="col-md-3 col-md-offset-6">
                        <button type="button" data-type="next" class="btn btn-default msf-nav-button">下一步 <i class="fa fa-chevron-right"></i></button>
                        <button type="submit" data-type="submit" class="btn btn-primary msf-nav-button">儲存</button>
                    </div>

                </div>
            </div>
        </form>
    </div>

    <div id="ArticleCanvas" class="border-0 d-none">
        <div id="gjs"></div>
    </div>
</div>