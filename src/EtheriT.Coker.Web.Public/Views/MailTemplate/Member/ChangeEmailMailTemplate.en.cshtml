@model EtheriT.Coker.Application.Shared.Dto.MailTemplate.ChangeEmailMailTemplateDto;
<style>
    .text-size1 {
        font-size: 1rem;
    }

    .d-flex {
        display: flex;
    }

    .text-bold {
        font-weight: bold;
    }

    .text-red {
        color: red;
    }

    .text-gray {
        color: gray;
    }
</style>

<div class='text-size1'>
    <h2 class='text-red'>Dear @Model.Name,</h2>
    <hr />
    <div class='d-flex'>You have successfully updated your email address to @Model.Email on @Model.CreationTime.ToString("yyyy/MM/dd HH:mm:ss").</div>
    <div class='d-flex'>All future notifications such as order updates from {Website.Title} will be sent to this new email address.</div>
    <br />
    <div class='text-bold text-red'>If you did not request this change, please visit your <a href='@Model.Url' title='Member Center'>Member Center</a> immediately to update your information.</div>
    <hr />
    <hr />
    <div class='text-bold text-red'>Reminder: This is a system-generated notification. Please do not reply directly to this email.</div>
    <div class='text-bold text-red'>Customer service staff will never ask you to change your account details or request ATM transfers.</div>
    <div class='text-bold text-red'>If you encounter any suspicious activity, please report it to the anti-fraud hotline immediately.</div>
    <hr />
    <hr />
    <br />
</div>