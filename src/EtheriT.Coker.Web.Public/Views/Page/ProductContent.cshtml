<div id="ProDisplayModal" class="modal fade" tabindex="-1" aria-labelledby="Product Display Modal" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content position-relative p-4">
			<button class="btn_close_prodisplaymodal btn-close rounded-circle position-absolute end-0 top-0 p-2 m-2" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
			<div class="modal-body p-2 mx-auto w-100 h-100 d-flex">
				<div id="Pro_Image" class="pro_img d-none"
					 data-folder="../images/product/"
					 data-filename-x=""
					 data-amount-x="1"
					 data-pointer-zoom="2"
					 hide-360-logo></div>
				<div id="Pro_360View" class="pro_360view d-none"
					 data-folder="../images/product/3d_pro/"
					 data-filename-x=""
					 data-amount-x=""
					 data-speed="100"
					 data-drag-speed="120"
					 data-pointer-zoom="2"></div>
				<iframe id="Pro_Youtube" class="pro_youtube d-none w-100" src="" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
			</div>
		</div>
	</div>
</div>

