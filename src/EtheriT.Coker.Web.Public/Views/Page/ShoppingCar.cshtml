							<div class="form-floating mb-3 col-12 col-sm-6">
								<input id="OrdererInputCellPhone" class="orderer_phone form-control" type="tel" placeholder="0987654321" value="0987654321" pattern="[0][9]\d{8}" maxlength="10" required>
