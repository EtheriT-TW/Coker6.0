				</div>

				<div class="card-body pt-5 d-none">
					<div class="list_title row d-none d-lg-flex">
						<div class="col-6 text-start">商品資訊</div>
						<div class="col-2">單價</div>
						<div class="col-2">數量</div>
						<div class="col-2">小計</div>
					</div>

					<ul class="purchase_list pb-4">
						<template id="Template_Purchase_Details">
							<li class="purchase_item row border-bottom border-top py-2 align-items-lg-center position-relative">
								<div class="image col-lg-6 col-sm-2 col-4 row gx-0">
									<a class="pro_link col-lg-2 col-12" href="">
										<img class="pro_image img-fluid" src="">
									</a>
									<a class="pro_link col text-start overflow-hidden" href="">
										<div class="content d-lg-block d-none">
											<div class="pro_name single_line fw-bold"></div>
											<div class="pro_detail d-flex flex-wrap">
												<div class="pro_specification pe-3"></div>
												<div class="pro_instructions single_line"></div>
											</div>
										</div>
									</a>
								</div>

								<div class="content col-sm-6 col row gx-0 overflow-hidden">
									<a class="pro_link" href="">
										<div class="d-lg-none d-block text-start">
											<div class="pro_name single_line fw-bold"></div>
											<div class="pro_detail d-flex flex-wrap">
												<div class="pro_specification pe-3"></div>
												<div class="pro_instructions single_line"></div>
											</div>
										</div>
									</a>

									<div class="pro_unit price col-12 col-lg-4 my-3 my-lg-0 fw-bold align-self-center text-start text-lg-center"></div>

									<div class="counter_input col-12 col-lg-4 d-flex justify-content-start justify-content-lg-center">
										<button class="btn_count_minus bg-white border-end-0">
											<i class="fa-solid fa-minus"></i>
										</button>

										<input class="pro_quantity text-center py-1" type="number" name="counter" value="">

										<button class="btn_count_plus bg-white border-start-0">
											<i class="fa-solid fa-plus"></i>
										</button>
									</div>

									<div class="pro_subtotal col-4 price fw-bold fs-5 d-lg-block d-none" data-subtotal=""></div>
								</div>

								<div class="btn_side_icon position-absolute d-flex flex-column top-0 end-0 p-2">
									<span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="移到收藏">
										<button class="btn_move_to_favorites bg-transparent border-0">
											<i class="fa-regular fa-heart"></i>
										</button>
									</span>
									<span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-placement="right" data-bs-trigger="hover focus" data-bs-content="移除商品">
										<button class="btn_remove_pro bg-transparent border-0">
											<i class="fa-solid fa-xmark"></i>
										</button>
									</span>
								</div>
							</li>
						</template>
					</ul>

					<div class="priceline pe-sm-5 col-12 col-md-6 offset-md-6">
						<div class="border-bottom py-2 d-flex justify-content-end text-end">
							<div>商品金額</div>
							<div class="subtotal price"></div>
						</div>
						<div class="py-2 d-flex justify-content-end text-end">
							<div>小計</div>
							<div class="subtotal price"></div>
						</div>
					</div>

