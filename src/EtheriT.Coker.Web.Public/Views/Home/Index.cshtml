@using EtheriT.Coker.Application.Shared.Dto.HtmlContent
@using EtheriT.Coker.Application.Shared.Dto.Product
@using EtheriT.Coker.Application.Shared.Dto.WebMenu
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Modal
@using EtheriT.Coker.Web.Public.Models
@using System.Web;
@model HomeViewModel
@{
    ViewData["SideName"] = Model.PageData.SiteName;
    ViewData["PageName"] = Model.PageData.Title;
}

<link rel="stylesheet" href="~/css/Home/Index.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Shared/css/Frame.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Shared/css/Swiper.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Shared/css/HoverEffect.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Shared/css/Directory.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/Shared/css/AnchorPoint.min.css" asp-append-version="true" />
<script src="~/js/ProductAction.min.js" asp-append-version="true"></script>
<script src="~/js/Home/Index.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/Frame.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/Swiper.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/ViewTypeChange.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/Sitemap.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/HoverEffect.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/DirectoryGetData.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/LinkWithIcon.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/AnchorPoint.min.js" asp-append-version="true"></script>
<script src="~/Shared/js/ShareBlock.min.js" asp-append-version="true"></script>

@switch (Model.PageData.LayoutType)
{
    case 3:
        @if (Model.MenuBread.Count() > 0)
        {
            <div class="top_title_3 p-3">
                <nav class="bread d-none d-md-block container">
                    <ol class="list-unstyled d-flex">
                        @foreach (var menu in Model.MenuBread ?? new List<GetMenuBreadDto>())
                        {
                            <li class="px-1"><a class="text-decoration-none" href="@menu.Link">@menu.Title</a></li>
                        }
                    </ol>
                </nav>
                <div class="title fs-1 fw-bold text-white container">@Model.PageData.Title</div>
            </div>
        }
        break;
    case 4:
        @if (Model.MenuBread.Count() > 0)
        {
            <div class="top_title_4 p-3 bg-white container">
                <nav class="bread d-none d-md-block container">
                    <ol class="list-unstyled d-flex">
                        @foreach (var menu in Model.MenuBread ?? new List<GetMenuBreadDto>())
                        {
                            <li class="px-1"><a class="text-decoration-none" href="@menu.Link">@menu.Title</a></li>
                        }
                    </ol>
                </nav>
                <div class="title fs-1 fw-bold text-black container">@Model.PageData.Title</div>
            </div>
        }
        break;
}

<Content class="d-none">@HttpUtility.HtmlEncode(Model.PageData.Html)</Content>
<div id="PostCSS" class="d-none">@HttpUtility.HtmlEncode(Model.PageData.Css)</div>

<div id="ShoppingCarModal" class="modal fade" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
    @await Component.InvokeAsync(nameof(Modal), new {dispaly = "ShoppingCarModal"})
</div>

