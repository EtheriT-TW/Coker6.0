@using EtheriT.Coker.Application.Shared.Dto.Marquee
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Header
@using EtheriT.Coker.Web.Public.Views.Shared.Components.MenuItem
@model HeaderViewModel

<link rel="stylesheet" href="~/css/Header/Header_Layout_1.min.css" asp-append-version="true" />
<script src="~/js/ProductAction.min.js" asp-append-version="true"></script>
<script src="~/js/Header/Header_Layout_1.min.js" asp-append-version="true"></script>

<nav class="navbar navbar-expand-lg flex-column p-0 fixed-top shadow-lg">

	<!-- Mega Menu -->
	<div id="Mega_Menu" class="bg-white navbar navbar-expand-lg w-100">
		<!-- Logo -->
		<div class="d-none d-lg-flex logo col-2 text-center py-lg-0 py-1">
			<a href="/">
				@if (string.IsNullOrEmpty(Model.Title))
				{
					<h1>@Model.Title</h1>
				}
				else
				{
					<img class="position-absolute translate-middle-y" src="@Model.LogoImageUrl" alt="@Model.Title" />
					<h1 class="d-none">@Model.Title</h1>
				}
			</a>
		</div>

		<!-- Menu Canvas -->
		<div id="Offcanvas_Mega_Menu" class="mega_menu_canvas offcanvas offcanvas-start col-lg-8 col visible" tabindex="-1" aria-labelledby="offcanvasExampleLabel">
			<!-- Menu Canvas Search Block -->
			<div class="offcanvas-header pt-2 ps-5">
				<h5 class="offcanvas-title fs-2 fw-bold" id="offcanvasLabel">@Model.Title</h5>
				@*<div class="d-lg-none d-flex justify-content-center align-items-center mt-4">
				<input class="border-1 rounded-pill" type="text">
				<button class="bg-transparent border-0"><i class="fa-solid fa-magnifying-glass"></i></button>
				<button class="bg-transparent border-0 d-none d-sm-flex">智慧搜尋</button>
				</div>*@
			</div>

			<!-- Menu Canvas Menu -->
			<ul class="navbar-nav offcanvas-body w-100 m-0">
				@foreach (var menu in Model.menuItemModels ?? new List<MenuItemModel>())
				{
					<li class="title nav-item flex-lg-grow-1 flex-grow-0">
						<a class="mt-0 mt-lg-4 nav-link pb-0 pb-lg-4 text-center text-nowrap">@menu.Title</a>
						<div class="content w-100 start-50 translate-middle-x">
							<ul class="d-flex flex-column flex-lg-row flex-wrap w-100 h-100">
								@foreach (var subMenu in menu.menuItemModels ?? new List<MenuItemModel>())
								{
									<li class="subtitle nav-item my-0 my-md-2">
										<a class="nav-link text-black m-auto py-1 text-nowrap" href="@subMenu.Link">@subMenu.Title</a>
									</li>
								}
							</ul>
						</div>

					</li>
				}
			</ul>
		</div>

		<div class="btn_menu navbar-toggler collapsed px-0 col-1 mt-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#Offcanvas_Mega_Menu">
			<div class="bar"></div>
			<div class="bar"></div>
			<div class="bar"></div>
		</div>

		<!-- Logo -->
		<div class="logo d-lg-none col-7 text-center py-lg-0 py-1">
			<a href="/">
				@if (string.IsNullOrEmpty(Model.Title))
				{
					<h1>@Model.Title</h1>
				}
				else
				{
					<img class="" src="@Model.LogoImageUrl" alt="Derek" />
					<h1 class="d-none">@Model.Title</h1>
				}
			</a>
		</div>

		<!-- Tool Bar -->
		<div class="col-lg-2 col-4 d-flex justify-content-center mt-0 mt-lg-3 pb-0 pb-lg-2">
			<!-- Search Block -->
			<button class="d-flex bg-transparent border-0">
				<span class="material-symbols-outlined bg-secondary bg-opacity-25 text-muted rounded-circle p-1 fs-5">search</span>
			</button>
			<button class="align-items-center bg-transparent border-0 d-flex p-0 p-lg-1">
				<div class="d-lg-flex d-none text-nowrap">智慧搜尋</div>
			</button>
			<div id="Cart_Dropdown_Parent" class="d-flex px-1">
				<button id="btn_car_dropdown" class="bg-transparent border-0 position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false">
					<span class="d-flex fs-4 fw-light material-symbols-outlined">shopping_cart</span>
					<span id="Car_Badge" class="badge position-absolute rounded-pill"></span>
				</button>

				<div id="Car_Dropdown" class="dropdown-menu dropdown-menu-end px-2 border-0 shadow-lg overflow-auto me-5" aria-labelledby="btn_car_dropdown">
					<ul class="m-0">
						<template id="Template_Car_Dropdown">
							<li class="border-bottom me-4" data-scid="">
								<figure class="position-relative mb-0">
									<a class="pro_link d-flex" href="">
										<img class="pro_image" src="" alt="" />
										<figcaption class="overflow-hidden">
											<div class="pro_name h-auto"></div>
											<div class="pro_spec h-auto my-1"></div>
											<div class="number d-flex">
												<div class="pro_unit price fw-bold"></div>
												<div class="pro_quantity fw-bold"></div>
											</div>
										</figcaption>
									</a>
									<button class="btn_cart_delete bg-transparent border-0 position-absolute">
										<i class="fa-solid fa-trash"></i>
									</button>
								</figure>
							</li>
						</template>
					</ul>

					<div id="Car_Dropdown_Null" class="drpy-3 text-center">購物車尚無商品</div>

					<button onclick="location.href='/ShoppingCar';" class="btn_car_buy border-0 rounded-1 w-100 py-1 mt-2 text-white" disabled>購買</button>
				</div>
			</div>

			<!-- Login Button -->
			<div class="d-flex">
				<button class="bg-transparent border-0 d-flex align-items-center" type="button">
					<span class="material-symbols-outlined">person</span>
				</button>
			</div>
		</div>
	</div>
</nav>