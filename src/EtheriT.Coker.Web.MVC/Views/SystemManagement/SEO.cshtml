@using EtheriT.Coker.Application.Shared.Dto.enumType
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal;
@model EtheriT.Coker.Application.Dto.StoreSet.StoreSetResponseMessageDto;
<link rel="stylesheet" href="~/css/SystemManagement/SEO.min.css" asp-append-version="true" />
<script src="~/js/SystemManagement/SEOSetting.min.js" asp-append-version="true"></script>

<div id="TopLine" class="d-flex justify-content-between mb-3 px-4">
    <div class="title fw-bold fs-3">網站資料</div>
    <a class="btn btn-primary text-decoration-none align-self-center d-none" href="#" role="button">返回網站資料</a>
</div>
<div id="WebDataMain">
    <!-- Google Setting -->
    <div class="py-2">
        <form id="StoreSet" class="card border-0 needs-validation" data-groupId="@Model.StoreSetGroupId" novalidate>
            @{
                if (Model.Success && Model.storeSets != null)
                {
                    for (int i = 0; i < Model.storeSets.Count; i++)
                    {
                        var group = Model.storeSets[i];

                        <div id="Setting@(group.Title)" class="card-body">
                            <div class="d-flex align-items-center pb-2">
                                <img src="@(group.Image)" />
                                <div class="fs-5 fw-bold px-2">@group.Title</div>
                            </div>

                            @for (int j = 0; j < group.storeSets.Count; j++)
                            {
                                var item = group.storeSets[j];
                                @switch (item.type)
                                {
                                    case SeoSetDataTypeEnum.text:
                                        <div class="d-flex align-items-center">
                                            <label class="form-label m-0" for="@(item.key)">@item.name</label>
                                            <input id="@(item.key)" name="@(item.key)" class="form-control text-center rounded mx-3" type="@(item.type)" placeholder="" pattern="@(item.pattern)" maxlength="@(item.maxlength)">
                                            <label class="form-label m-0" for="@(item.key)">@item.memo</label>
                                        </div>
                                        break;
                                    case SeoSetDataTypeEnum.textarea:
                                        <div class="mb-3">
                                            <label class="form-label m-0" for="@(item.key)">@item.name</label>
                                            <textarea id="@(item.key)" name="@(item.key)" class="form-control p-2" placeholder="@item.memo" maxlength="@(item.maxlength)" rows="6"></textarea>
                                        </div>
                                        break;
                                    case SeoSetDataTypeEnum.checkBox:
                                        <div class="d-flex flex-column">
                                            <div class="form-label m-0">@item.name</div>
                                            <div class="d-flex align-items-center border border-1 my-2 py-2 rounded">
                                                @foreach (var checkItem in item.storeSetItemOutputDtos)
                                                {
                                                    <input id="@($"{item.key}-{checkItem.Key}")" name="@(item.key)" class="mx-3" type="checkbox" value="@checkItem.Key">
                                                    <label for="@($"{item.key}-{checkItem.Key}")">@checkItem.Value</label>
                                                }
                                            </div>
                                            <div class="form-label m-0">@item.memo</div>
                                        </div>
                                        break;
                                    case SeoSetDataTypeEnum.select:
                                        <div class="mb-3">
                                            <label class="form-label m-0 required_all" for="@(item.key)">@item.name</label>
                                            <select id="@(item.key)" name="@(item.key)" class="form-select" required>
                                                <option value="">@item.memo</option>
                                                @foreach (var checkItem in item.storeSetItemOutputDtos)
                                                {
                                                    <option value="@checkItem.Key">@checkItem.Value</option>
                                                }
                                            </select>
                                            <div class="invalid-feedback">
                                                @item.name 不可為空
                                            </div>
                                        </div>
                                        break;
                                }
                            }
                        </div>
                    }
                    <div class="d-flex justify-content-center m-4">
                        <button class="btn submit rounded-2 bg-danger text-white" form="StoreSet">儲存</button>
                    </div>
                }
            }
        </form>
    </div>
</div>