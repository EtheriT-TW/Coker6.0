@using EtheriT.Coker.Web.Public.Views.Shared.Components.Footer
@model FooterViewModel

<link rel="stylesheet" href="~/css/Footer/Footer_Layout_6.min.css" asp-append-version="true" />

<div class="text-white font_small" style="background-image: url(@Model.Link/backgroundfooter.jpg)">
    <div class="container d-lg-flex justify-content-between align-items-end py-4">
        <div class="text pb-lg-4">
            @for (int i = 0; i < Model.Content.Count; i++)
            {
                <div>
                    @Model.Content[i]
                    @if (i == Model.Content.Count - 1 && Model.Sitemap_Link != null)
                    {
                        <a class="text-white" href="@Model.Sitemap_Link">網站導覽</a>
                    }
                </div>
            }
        </div>
        <div class="image d-lg-flex align-items-end col px-lg-4 justify-content-between">
            <div class="d-lg-flex d-none pb-lg-4">
                @if (Model.Privacy_Link != null)
                {
                    <a class="text-white" href="@Model.Privacy_Link">個資暨隱私權聲明</a>
                }
            </div>
            <div class="d-flex flex-lg-row-reverse align-items-center justify-content-around">
                <div>
                    <div class="d-lg-none pb-3">
                        @if (Model.Privacy_Link != null)
                        {
                            <a class="text-white" href="@Model.Privacy_Link">個資暨隱私權聲明</a>
                        }
                    </div>
                    @if (Model.Accessibility_Link != null && Model.Accessibility_Badge != null)
                    {
                        <a href="@Model.Accessibility_Link" title="連結至:無障礙網站(另開視窗)">
                            <img class="pe-lg-0 pe-2" alt="通過AA檢測等級無障礙網頁檢測" src="@Model.Accessibility_Badge" />
                        </a>
                    }
                </div>
                <div class="pe-lg-5 ps-lg-0 ps-2 m-0">
                    <img class="img_maxh150" alt="產業供需服務平臺line@@" src="@Model.line_qr" />
                </div>
            </div>
        </div>
    </div>
</div>