@model EtheriT.Coker.Application.Shared.Dto.MailTemplate.BackendTemplateResuleDto;
<style>
    body {
        font-family: Arial, "Microsoft JhengHei", sans-serif;
        line-height: 1.6;
    }

    .box {
        border: 1px solid #cccccc;
        padding: 12px;
        margin: 16px 0;
    }

    .label {
        font-weight: bold;
        width: 120px;
        vertical-align: top;
    }

    .hint {
        color: #666666;
        font-size: 12px;
    }

    .action {
        margin: 16px 0;
    }
</style>


<p>Hello @Model.Name,</p>

<p>
    A member account has been created for you by our administrator. Please complete the initial activation to start using your account.
</p>

<div class="box">
    <table>
        <tr>
            <td class="label">Account (Email)</td>
            <td>@Model.Email</td>
        </tr>
        <tr>
            <td class="label">Created On</td>
            <td>@Model.CreationTime.ToString("yyyy/MM/dd HH:mm")</td>
        </tr>
    </table>
</div>

<p>Please click the link below to set your initial password:</p>

<div class="action">
    <a href="@Model.SetPasswordUrl">Set Password</a>
</div>

<p>
    If clicking the link does not work, please copy the following URL and paste it into your browser:
</p>

<p>
    @Model.SetPasswordUrl
</p>

<p class="hint">
    ※ This link can only be used once and will expire after @Model.ExpireTime.ToString("yyyy/MM/dd HH:mm").<br>
    ※ If you did not request an account to be created, please ignore this email.
</p>

<p class="hint">
    This is an automated message, please do not reply.
</p>
