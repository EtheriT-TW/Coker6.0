@using EtheriT.Coker.Web.Public.Views.Shared.Components.Header
@using EtheriT.Coker.Web.Public.Views.Shared.Components.MenuItem
@model HeaderViewModel

<link rel="stylesheet" href="~/css/Header/Header_Layout_2.min.css" asp-append-version="true" />
<script src="~/js/Header/Header_Layout_2.min.js" asp-append-version="true"></script>

<nav id="HeaderMenu" class="navbar navbar-expand-lg bg-body-tertiary" data-laout="2">
    <div class="container-fluid">
        @{
            var home_target = Model.HomeTarget == true ? "_blank" : "_self";
            var home_title = Model.HomeTarget == true ? "連結至：首頁(另開視窗)" : "連結至：首頁";
        }
        <a class="navbar-brand" href="@Model.HomeLink" target="@home_target" rel="@(Model.HomeTarget == true ? $"noopener noreferrer" : "")" title="@home_title"><h1>@Model.Title</h1></a>
        <div Id="Offcanvas_Menu" class="collapse navbar-collapse offcanvas offcanvas-start" id="navbarSupportedContent" tabindex="-1" aria-labelledby="offcanvasExampleLabel">
            <a accesskey="U" href="javascript:void(0)" class="hide accesskey" title="上方區域">:::</a>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                @foreach (var menu in Model.menuItemModels ?? new List<MenuItemModel>())
                {
                    var target = menu.Target == true ? "_blank" : "_self";
                    var title = menu.Target == true ? $"連結至：{menu.Title}(另開視窗)" : $"連結至：{menu.Title}";
                    <li class="nav-item">
                        <a class="nav-link" href="@menu.Link" title="@title" target="@target" rel="@(menu.Target == true ? $"noopener noreferrer" : "")">@menu.Title</a>
                    </li>
                }
            </ul>
        </div>
        <div class="btn_menu navbar-toggler collapsed px-0 col-1 mt-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#Offcanvas_Menu">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>
    </div>
</nav>

