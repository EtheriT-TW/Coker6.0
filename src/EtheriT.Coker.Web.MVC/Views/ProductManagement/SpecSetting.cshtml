@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Product
@using EtheriT.Coker.Application.Shared.Dto.Specification
@{
	ViewData["Title"] = "SpecSetting";
}

<link rel="stylesheet" href="~/css/ProductManagement/SpecSetting.min.css" asp-append-version="true" />
<script src="~/js/ProductManagement/SpecSetting.min.js" asp-append-version="true"></script>
@{
	await Html.RenderPartialAsync(@"DevExpress\_GridCSRF");
}
<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-3 px-4">
		<div class="title fw-bold fs-3">規格設定</div>
	</div>

	<div id="" class="py-2">
		<div id="SpecSettingList" class="card border-0">
			<div class="card-body row">
				<div class="type_list position-relative col-12 col-lg-6">
					<div class="bg-black bg-opacity-10 py-2 rounded-3 mb-4 fs-5 text-center">規格類型</div>
					<div>
						@(Html.DevExtreme().DataGrid<SpecTypeListDto>()
							.DataSource(d => d.RemoteController().Key("Id")
							.LoadUrl("/api/Specification/GetAllTypeList").LoadMethod("Get")
							.InsertUrl("/api/Specification/TypeAddUp").InsertMethod("Post")
							.UpdateUrl("/api/Specification/TypeAddUp").UpdateMethod("Post")
							.OnBeforeSend("onBeforeSend")
							)
							.ID("TypeList")
							.RemoteOperations(true)
							.ShowBorders(true)
							.FilterRow(filterRow => filterRow
							.Visible(true)
							.ApplyFilter(GridApplyFilterMode.Auto)
							)
							.HeaderFilter(headerFilter => headerFilter.Visible(true))
							.SearchPanel(searchPanel => searchPanel
							.Visible(true)
							.Width(280)
							.Placeholder("請輸入要搜尋的資料")
							)
							.ShowRowLines(true)
							.Paging(paging => paging.PageSize(30))
							.Pager(pager =>
							{
								pager.Visible(true);
								pager.ShowPageSizeSelector(true);
								pager.AllowedPageSizes(new[] { 10, 20, 30 });
								pager.ShowInfo(true);
							})
							.Editing(editing =>
							{
								editing.Mode(GridEditMode.Row);
								editing.AllowAdding(true);
								editing.AllowDeleting(true);
								editing.AllowUpdating(true);
								editing.NewRowPosition(GridNewRowPosition.ViewportTop);
								editing.UseIcons(true);
							})
							.Columns(c =>
							{
								c.AddFor(e => e.Type).Caption("規格類型");
								c.Add()
								.Type(GridCommandColumnType.Buttons)
								.Buttons(b =>
								{
									b.Add().Icon("edit").OnClick("editButtonClicked").Visible(new JS("editButtonVisible"));
									b.Add().Name("save");
									b.Add().Name("cancel");
									b.Add().Name("delete").OnClick("typeDeleteButtonClicked");
								});
							})
							.Toolbar(toolbar =>
							{
								toolbar.Items(i =>
								{
									i.Add()
								.Name(DataGridToolbarItem.AddRowButton)
								.ShowText(ToolbarItemShowTextMode.Always)
								.Location(ToolbarItemLocation.Before);
								});

								toolbar.Items(i =>
								{
									i.Add()
								.Name(DataGridToolbarItem.SearchPanel)
								.ShowText(ToolbarItemShowTextMode.Always)
								.Location(ToolbarItemLocation.After);
								});
							})
							.OnContentReady("contentReady")
							.OnRowInserting("dataSaving")
							.OnRowUpdating("dataSaving"))
					</div>
				</div>
				<div class="spec_list position-relative col-12 col-lg-6">
					<div class="bg-black bg-opacity-10 py-2 rounded-3 mb-4 fs-5 text-center">規格名稱</div>
					<div>
						@(Html.DevExtreme().DataGrid<SpecSpecListDto>()
							.DataSource(d => d.RemoteController().Key("Id")
							.LoadUrl("/api/Specification/GetAllSpecList").LoadMethod("Get")
							.InsertUrl("/api/Specification/SpecAddUp_List").InsertMethod("Post")
							.UpdateUrl("/api/Specification/SpecAddUp_List").UpdateMethod("Post")
							.OnBeforeSend("onBeforeSend")
							)
							.ID("SpecList")
							.RemoteOperations(true)
							.ShowBorders(true)
							.FilterRow(filterRow => filterRow
							.Visible(true)
							.ApplyFilter(GridApplyFilterMode.Auto)
							)
							.HeaderFilter(headerFilter => headerFilter.Visible(true))
							.SearchPanel(searchPanel => searchPanel
							.Visible(true)
							.Width(280)
							.Placeholder("請輸入要搜尋的資料")
							)
							.ShowRowLines(true)
							.Paging(paging => paging.PageSize(30))
							.Pager(pager =>
							{
								pager.Visible(true);
								pager.ShowPageSizeSelector(true);
								pager.AllowedPageSizes(new[] { 10, 20, 30 });
								pager.ShowInfo(true);
							})
							.Editing(editing =>
							{
								editing.Mode(GridEditMode.Row);
								editing.AllowAdding(true);
								editing.AllowDeleting(true);
								editing.AllowUpdating(true);
								editing.NewRowPosition(GridNewRowPosition.ViewportTop);
								editing.UseIcons(true);
							})
							.Columns(c =>
							{
								c.AddFor(e => e.FK_Tid)
								.Lookup(lookup => lookup
								.DataSource("getType")
								.DisplayExpr("Type")
								.ValueExpr("Id")
								).Caption("規格類型");
								c.AddFor(e => e.Title).Caption("規格名稱");
								c.Add()
								.Type(GridCommandColumnType.Buttons)
								.Buttons(b =>
								{
									b.Add().Icon("edit").OnClick("editButtonClicked").Visible(new JS("editButtonVisible"));
									b.Add().Name("save");
									b.Add().Name("cancel");
									b.Add().Name("delete").OnClick("specDeleteButtonClicked");
								});
							})
							.Toolbar(toolbar =>
							{
								toolbar.Items(i =>
								{
									i.Add()
								.Name(DataGridToolbarItem.AddRowButton)
								.ShowText(ToolbarItemShowTextMode.Always)
								.Location(ToolbarItemLocation.Before);
								});

								toolbar.Items(i =>
								{
									i.Add()
								.Name(DataGridToolbarItem.SearchPanel)
								.ShowText(ToolbarItemShowTextMode.Always)
								.Location(ToolbarItemLocation.After);
								});
							})
							.OnContentReady("contentReady")
							.OnRowInserting("dataSaving")
							.OnRowUpdating("dataSaving"))
					</div>
				</div>
			</div>
		</div>
		<div class="text-end my-2 text-danger">※名稱不可以符號開頭</div>
	</div>
</div>

