@using EtheriT.Coker.Web.Public.Views.Shared.Components.Footer
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Header
@using EtheriT.Coker.Web.Public.Views.Shared.Components.LayoutType
@using EtheriT.Coker.Web.Public.Views.Shared.Components.SideFloating

<!DOCTYPE html>
<html lang="zh-tw">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["PageName"] 【@ViewData["SideName"]】</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/lib/fortawesome/css/all.min.css" />
	<link rel="stylesheet" href="~/lib/swiper/swiper-bundle.min.css" />
	<link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
	@await Component.InvokeAsync(nameof(LayoutType))
	<link rel="stylesheet" href="~/EtheriT.Coker.Web.Public.styles.css" asp-append-version="true" />

	<meta name="author" content="易碩網際科技股份有限公司" />
	<meta name="copyright" content="易碩網際科技股份有限公司" />
	<meta itemprop="name" content="@ViewData["PageName"]｜@ViewData["SideName"]" />
	<meta itemprop="description" content="@ViewData["Description"]" />
	<meta name="twitter:title" content="@ViewData["PageName"]｜@ViewData["SideName"]" />
	<meta name="twitter:description" content="@ViewData["Description"]" />
	<meta property="og:title" content="@ViewData["PageName"]｜@ViewData["SideName"]" />
	<meta property="og:type" content="website" />
	<meta property="og:url" content="@ViewData["CurrentUrl"]" />
	<meta property="og:site_name" content="@ViewData["SideName"]" />
	<meta property="og:description" content="@ViewData["Description"]" />
	<meta property="og:locale" content="zh-tw" />
	<style id="frameCss"></style>
</head>
<body onload="ready()">
	<div id="LoginModal" class="modal fade" aria-hidden="true" aria-labelledby="LoginModalLabel" tabindex="-1">
		<div class="modal-dialog modal-dialog-centered justify-content-center">
			<div class="modal-content">
				<div class="modal-header border-0">
					<button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<div class="text-center fs-4 fw-bold">會員登入</div>
					<form id="LoginForm" class="card-body needs-validation">
						<div class="login_mail input-group mb-3">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">mail</span>
							</div>
							<input id="InputLoginMail" class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input Login Mail" placeholder="信箱" required>
						</div>
						<div class="login_pass input-group mb-3">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">lock</span>
							</div>
							<input id="InputLoginPass" class="input_bg form-control rounded border-0 py-3" type="password" aria-label="Input Login Password" placeholder="密碼" required>
						</div>
						<div class="login_vcode input-group">
							<input id="InputLoginVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Login Verification Code" placeholder="輸入驗證碼" maxlength="4" required>
							<div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
								<img id="LoginImgCaptcha" class="img-fluid" src="" />
							</div>
						</div>
						<button class="btn_refresh border-0 bg-transparent text-end w-100 text-black-50">刷新驗證碼</button>
						<div class="form-check">
							<input id="CheckRemember" class="form-check-input" type="checkbox" value="">
							<label class="form-check-label" for="CheckRemember">記住我的帳號</label>
						</div>
					</form>
					<button class="btn_login w-100 rounded border-0 text-white py-2 fs-5 my-3">登　入</button>
					<div class="border-bottom pb-1 text-black-50 text-center">其他登入方式</div>
				</div>
				<div class="modal-footer d-flex justify-content-center border-0">
					<div class="text-black-50">不是會員？</div>
					<button class="bg-transparent border-0 text-decoration-underline text-black-50" data-bs-target="#RegisterModal" data-bs-toggle="modal" data-bs-dismiss="modal">立即註冊</button>
					<button class="bg-transparent border-0 text-decoration-underline text-black-50" data-bs-target="#ForgetModal" data-bs-toggle="modal" data-bs-dismiss="modal">忘記密碼</button>
				</div>
			</div>
		</div>
	</div>

	<div id="RegisterModal" class="modal fade" aria-hidden="true" aria-labelledby="RegisterModal" tabindex="-1">
		<div class="modal-dialog modal-dialog-centered justify-content-center">
			<div class="modal-content">
				<div class="modal-header border-0">
					<button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					<div class="text-center fs-4 fw-bold">加入會員</div>
					<form id="RegisterForm" class="card-body needs-validation">
						<div class="register_mail input-group mb-3">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">mail</span>
							</div>
							<input id="InputRegisterMail" class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input Register Mail" placeholder="信箱" required>
						</div>
						<div class="register_name input-group">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">account_circle</span>
							</div>
							<input id="InputRegisterName" class="input_bg form-control rounded border-0 py-3" type="text" aria-label="Input Register Name" placeholder="姓名/名稱" required>
						</div>
					</form>
					<div class="px-3">
						<div class="register_new_pass input-group">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">lock</span>
							</div>
							<input id="InputRegisterNewPass" class="input_bg form-control rounded border-0 py-3" type="text" aria-label="Input Register New Password" placeholder="密碼" required>
						</div>
						<div id="NewPassFeedBack" class="lh-1 text-danger pt-1">　</div>
						<div class="register_check_pass input-group">
							<div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
								<span class="material-symbols-outlined text-black-50">lock</span>
							</div>
							<input id="InputRegisterCheckPass" class="input_bg form-control rounded border-0 py-3" type="text" aria-label="Input Register Check Password" placeholder="確認密碼" required>
						</div>
						<div id="CheckPassFeedBack" class="lh-1 text-danger pt-1">　</div>
						<div class="register_vcode input-group">
							<input id="InputRegisterVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Register Verification Code" placeholder="輸入驗證碼" maxlength="4" required>
							<div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
								<img id="RegisterImgCaptcha" class="img-fluid" src="" />
							</div>
						</div>
						<button class="btn_refresh border-0 bg-transparent text-end w-100 text-black-50">刷新驗證碼</button>
						<div class="form-check">
							<input id="CheckAccept" class="form-check-input" type="checkbox" value="">
							<label class="form-check-label" for="CheckAccept">我已詳細閱讀並同意<span><a class="text-black text-decoration-underline" href="/Terms">會員條款</a></span></label>
						</div>
					</div>
					<button class="btn_register w-100 rounded border-0 text-white py-2 fs-5 my-3">註　冊</button>
				</div>
			</div>
		</div>
	</div>

	<header class="">
		@await Component.InvokeAsync(nameof(Header))
	</header>

	<div>
		@await Component.InvokeAsync(nameof(SideFloating))
	</div>

	@RenderBody()

	<footer>
		@await Component.InvokeAsync(nameof(Footer))
		<div id="Cookie" class="cookie position-fixed text-white w-100 bottom-0 justify-content-center align-items-center">
			<p class="cookie_text my-3 pe-3">本網站使用cookies。使用我們的網站並同意隱私權政策，即表示您同意我們根據本政策內的條款使用cookie。如果您不同意，請按照說明停用，本網站的cookie即不會安裝於您的裝置上。了解更多請見&ensp;<span style="cursor:pointer">隱私權政策</span>。</p>
			<div id="Cookie_button">
				<div class="btn_cookie_accept m-2 p-1 px-4 rounded-2 text-center">接受</div>
				<div class="btn_cookie_reject m-2 p-1 px-4 rounded-2 text-center">拒絕</div>
			</div>
		</div>
	</footer>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/lib/swiper/swiper-bundle.min.js"></script>
	<script src="~/lib/jquery-plugin-c-share/dist/jquery.c-share.min.js"></script>
	<script src="~/lib/sweetalert2/dist/sweetalert2.min.js"></script>
	<script src="~/lib/jquery-twzipcode/jquery.twzipcode.min.js"></script>
	<script src="~/lib/masonry-layout/dist/masonry.pkgd.min.js"></script>
	<script src="https://scaleflex.cloudimg.io/v7/plugins/js-cloudimage-360-view/latest/js-cloudimage-360-view.min.js?func=proxy"></script>
	<script src="~/js/site.min.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
