						<div class="form-check py-2">
							<input id="radio_payment_LINE" class="form-check-input" type="radio" name="RadioPayment" value="3" required>
							<label class="form-check-label" for="radio_payment_LINE">LINE Pay</label>
							<div class="invalid-feedback">請選擇付款方式</div>
						</div>
					</form>

					<div class="priceline px-3 pe-sm-5 col-12 col-md-6 offset-md-6">
