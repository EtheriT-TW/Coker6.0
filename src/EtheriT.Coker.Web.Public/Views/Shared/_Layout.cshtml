@using EtheriT.Coker.Web.Public.Views.Shared.Components.Footer
@using EtheriT.Coker.Web.Public.Views.Shared.Components.Header
@using EtheriT.Coker.Web.Public.Views.Shared.Components.LayoutType
@using EtheriT.Coker.Web.Public.Views.Shared.Components.SideFloating
@using EtheriT.Coker.Application.Shared.i18n;
@{
    var nonce = ViewContext.HttpContext.Items["CSPNonce"] as string;
    ViewBag.Nonce = nonce;
}
<!DOCTYPE html>
<html lang="@ViewData["Locale"]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["PageTagNameName"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/fortawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/swiper/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/Shared/shared.min.css" asp-append-version="true" />
    @switch (ViewData["PageView"])
    {
        case "Article":
            <link rel="canonical" href="@($"{ViewData["Root"]}/{ViewData["OrgName"]}/search/article/{ViewData["Id"]}")" />
            break;
        case "Product":
            <link rel="canonical" href="@($"{ViewData["Root"]}/{ViewData["OrgName"]}/search/product/{ViewData["Id"]}")" />
            break;
    }
    @await Component.InvokeAsync(nameof(LayoutType))

    <meta name="author" content="易碩網際科技股份有限公司" />
    <meta name="copyright" content="易碩網際科技股份有限公司" />
    <meta name="description" content="@Html.Raw(ViewData["Description"])">
    <meta itemprop="name" content="@Html.Raw(ViewData["PageName"])｜@Html.Raw(ViewData["SideName"])" />
    <meta itemprop="description" content="@Html.Raw(ViewData["Description"])" />
    <meta name="twitter:title" content="@Html.Raw(ViewData["PageName"])｜@Html.Raw(ViewData["SideName"])" />
    <meta name="twitter:description" content="@Html.Raw(ViewData["Description"])" />
    <meta property="og:title" content="@Html.Raw(ViewData["PageName"])｜@Html.Raw(ViewData["SideName"])" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@ViewData["CurrentUrl"]" />
    <meta property="og:site_name" content="@Html.Raw(ViewData["SideName"])" />
    <meta property="og:description" content="@Html.Raw(ViewData["Description"])" />
    <meta property="og:locale" content="zh-tw" />
    <meta name="csp-nonce" content="@Html.Raw(ViewBag.Nonce)" />
    <style nonce="@ViewBag.Nonce">
        :root {
            --orgName: @ViewData["OrgName"];
        }
    </style>
    <style id="frameCss" nonce="@ViewBag.Nonce"></style>
    <script nonce="@ViewBag.Nonce">
        window.CI360 = { notInitOnLoad: true }
        window.onload = function () {
            ready();
        }
        const originalAppendChild = Element.prototype.appendChild;
        const originalInsertBefore = Node.prototype.insertBefore;
        const nonce = document.querySelector('meta[name="csp-nonce"]').getAttribute('content');

        // 覆寫 appendChild 方法
        Element.prototype.appendChild = function (child) {
            // 檢查是否為 <script> 或 <style> 元素
            if (child.tagName === 'SCRIPT' || child.tagName === 'STYLE') {
                // 為元素添加 nonce 屬性
                child.setAttribute('nonce', nonce);
            }

            // 調用原始的 appendChild 方法
            return originalAppendChild.call(this, child);
        };

        // 覆寫 insertBefore 方法
        Node.prototype.insertBefore = function (newNode, referenceNode) {
            // 檢查插入的節點是否為 script 或 style
            if (newNode.tagName === 'SCRIPT' || newNode.tagName === 'STYLE') {
                // 添加 nonce 屬性
                newNode.setAttribute('nonce', nonce);
            }

            // 調用原始的 insertBefore 方法
            return originalInsertBefore.call(this, newNode, referenceNode);
        };
    </script>
    @if (ViewData["GA4"] != null && !string.IsNullOrEmpty(ViewData["GA4"].ToString() ?? ""))
    {
        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=@ViewData["GA4"]"></script>
        <script nonce="@ViewBag.Nonce">
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());

            gtag('config', "@ViewData["GA4"]");
        </script>
    }
    @if (ViewData["google.translate"] != null && !string.IsNullOrEmpty(ViewData["google.translate"]!.ToString() ?? ""))
    {
        <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
        <script nonce="@ViewBag.Nonce">
            function googleTranslateElementInit() {
                new google.translate.TranslateElement({
                    pageLanguage: 'zh-TW', includedLanguages: '@ViewData["google.translate"]', gaTrack: true
                }, 'google_translate_element');

                $('select.goog-te-combo').attr('title', 'translate');

            }
        </script>
    }
    @if (ViewData["GTM"] != null && !string.IsNullOrEmpty(ViewData["GTM"].ToString() ?? ""))
    {
        <!-- Google Tag Manager -->
        <script nonce="@ViewBag.Nonce">
            (function (w, d, s, l, i) {
                w[l] = w[l] || []; w[l].push({
                    'gtm.start':
                        new Date().getTime(), event: 'gtm.js'
                }); var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                        'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
            })(window, document, 'script', 'dataLayer', '@ViewData["GTM"]');</script>
        <!-- End Google Tag Manager -->
    }
</head>
<body id="@ViewData["Layout"]" class="@ViewData["bodyClass"]">
    @if (ViewData["GTM"] != null && !string.IsNullOrEmpty(ViewData["GTM"].ToString() ?? ""))
    {
        <!-- Google Tag Manager (noscript) -->
        <noscript>
            <iframe class="gtmIframe" src="https://www.googletagmanager.com/ns.html?id=@ViewData["GTM"]" height="0" width="0"></iframe>
        </noscript>
        <!-- End Google Tag Manager (noscript) -->
    }
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <a id="jumpToCenter" href="#ContainerBody" class="hide accesskey" title="@L.get("accesskeyJumpMain")">
        <span title="@L.get("accesskeyJumpMain")">@L.get("accesskeyJumpMain")</span>
    </a>
    @{
        if (ViewData["VisibleHeader"] == null)
        {
            ViewData["VisibleHeader"] = "true";
        }
        if (ViewData["VisibleFooter"] == null)
        {
            ViewData["VisibleFooter"] = "true";
        }
        string VisibleHeader = bool.Parse((ViewData["VisibleHeader"] ?? "true").ToString() ?? "true") ? "" : "d-none";
        string VisibleFooter = bool.Parse((ViewData["VisibleFooter"] ?? "true").ToString() ?? "true") ? "" : "d-none";

    }
    <header class="@VisibleHeader">
        @await Component.InvokeAsync(nameof(Header))
    </header>
    <noscript>
        <p id="noscript">
            <span>@L.get("noJavascript")</span><br />
            @L.get("noJavascriptMemo")
        </p>
    </noscript>
    <div id="ContainerBody">
        <a accesskey="C" href="javascript:void(0)" class="hide accesskey" title="@L.get("accesskeyCenter")">:::</a>
        @RenderBody()
    </div>
    <footer class="footer_pack_up @VisibleFooter">
        @await Component.InvokeAsync(nameof(Footer))
    </footer>
    @if (ViewBag.LoginEnable != null && ViewBag.LoginEnable)
    {
