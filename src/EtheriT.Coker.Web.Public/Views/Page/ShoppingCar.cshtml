@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Freight
@using EtheriT.Coker.Application.Shared.Dto.Recipients
@using EtheriT.Coker.Application.Shared.Dto.ThirdParty;
@using EtheriT.Coker.Web.Public.Models
@using EtheriT.Coker.Application.Shared.i18n;
@using System.Web
@model PageViewModel
<script nonce="@ViewBag.Nonce">
    const MinOrderForRedemption = @Json.Serialize(ViewBag.MinOrderForRedemption ?? 0);
    const MaxRedemptionPercent = @Json.Serialize(ViewBag.MaxRedemptionPercent ?? 0);
    const MinOrderForEarnPoints = @Json.Serialize(ViewBag.MinOrderForEarnPoints ?? 0);
    const RewardRatePercent = @Json.Serialize(ViewBag.RewardRatePercent ?? 0);
</script>
<link rel="stylesheet" href="~/css/Page/ShoppingCart.min.css" asp-append-version="true" />
<script src="~/js/Page/ShoppingCart.min.js" asp-append-version="true"></script>
@Html.AntiForgeryToken()
<!-- Modal -->
