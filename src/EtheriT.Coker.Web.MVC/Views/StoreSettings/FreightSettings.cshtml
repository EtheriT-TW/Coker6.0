@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Freight
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal
@{
	ViewData["Title"] = "FreightSettings";
}

<link rel="stylesheet" href="~/css/StoreSettings/FreightSettings.min.css" asp-append-version="true" />
<script src="~/js/StoreSettings/FreightSettings.min.js" asp-append-version="true"></script>


<div class="">
	<div id="TopLine" class="d-flex justify-content-between mb-4">
		<div class="d-flex">
			<div class="title fw-bold fs-3">運費設定<span class="fw-normal">(最多可設定六組)</span></div>
		</div>
	</div>

	<div id="FreightPageRoot" class="py-2">
		<div id="FreightList" data-hash-page="List" class="card border-0">
			<div class="card-body position-relative pb-5">
				<button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
					<span class="material-symbols-outlined">add</span>
				</button>
				@(
					Html.DevExtreme().DataGrid<FreightGetAllListDto>()
					.DataSource(d => d.RemoteController().Key("Id")
					.LoadUrl("/api/Freight/GetAllList").LoadMethod("Get")
					)
					.RemoteOperations(true)
					.ColumnHidingEnabled(true)
					.ShowBorders(true)
					.FilterRow(filterRow => filterRow
					.Visible(true)
					.ApplyFilter(GridApplyFilterMode.Auto)
					)
					.SearchPanel(searchPanel => searchPanel
					.Visible(true)
					.Width(480)
					.Placeholder("請輸入要搜尋的資料")
					)
					.ShowRowLines(true)
					.Columns(c =>
					{
						c.AddFor(e => e.Id).Caption("編號").Width(50);
						c.AddFor(e => e.Title).Caption("標題");
						c.AddFor(e => e.Describe).Caption("");
						c.Add()
						.Type(GridCommandColumnType.Buttons)
						.Buttons(b =>
						{
							b.Add().Name("edit").OnClick("editButtonClicked");
							b.Add().Name("delete").OnClick("deleteButtonClicked");
						});
					})
					.ColumnAutoWidth(true)
					.Paging(paging => paging.PageSize(30))
					.Pager(pager =>
					{
						pager.Visible(true);
						pager.ShowPageSizeSelector(true);
						pager.AllowedPageSizes(new[] { 10, 20, 30 });
						pager.ShowInfo(true);
					})
					.Editing(editing =>
					{
						editing.AllowDeleting(true);
						editing.AllowUpdating(true);
						editing.UseIcons(true);
					})
					.OnContentReady("contentReady")
					)
			</div>
		</div>

		<div id="FreightContent" data-hash-page="Content" class="card border-0 d-none">
			<div class="card-header d-flex justify-content-between">
				<div class="fw-bold fs-5 d-flex align-items-center">
					<button class="btn_back d-flex bg-transparent border-0 align-items-center">
						<span class="material-symbols-outlined">
							keyboard_backspace
						</span>
					</button>
					<div class="lh-lg" data-hash-title>運費設定</div>
				</div>
				<button class="btn_done btn-primary border-0 px-3 py-1 text-white" form="FreightForm">　儲存　</button>
			</div>

			<form id="FreightForm" class="card-body needs-validation">
				<div class="form-check mb-3">
					<input id="CheckDefault" class="form-check-input" name="Set_Default" type="checkbox" value="true">
					<label class="form-check-label" for="CheckDefault">設定為預設運費</label>
				</div>

				<div class="row align-items-center">
					<div class="name input-group col-12 col-sm-6 mb-3">
						<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
							<span class="material-symbols-outlined me-1 required_sign">local_shipping</span>名稱
						</div>
						<input id="InputName" class="form-control rounded" name="Title" type="text" aria-label="Input Name of Freight" autocomplete="off" required>
					</div>

					<div class="col-6 col-sm-3 mb-3 d-none">
						<select id="SelectPreserve" class="form-select" name="PreserveType" aria-label="Preserve Select"></select>
					</div>

					<div class="col-6 col-sm-3 mb-3">
						<select id="SelectStatus" class="form-select" name="FreightStatusType" aria-label="Status Select" required></select>
					</div>

					<div class="col-6 col-sm-3 mb-3">
						<select id="SelectShipping" class="form-select" name="LogisticsType" aria-label="Shipping Select" required></select>
					</div>

					<div class="form-check col-6 col-sm-3 mb-3 d-none">
						<input class="form-check-input" type="checkbox" id="SupportCashOnDeliveryCheckBox" name="SupportCashOnDelivery" checked>
						<label class="form-check-label" for="SupportCashOnDeliveryCheckBox">
							代收款項
						</label>
					</div>
				</div>

				<div class="d-flex mb-3">
					<div class="form-check me-5">
						<input id="FreightRadio_Free" class="form-check-input" type="radio" name="FreightType" value="1">
						<label class="form-check-label" for="FreightRadio_Free">免運</label>
					</div>
					<div class="form-check me-5">
						<input id="FreightRadio_Single" class="form-check-input" type="radio" name="FreightType" value="2">
						<label class="form-check-label" for="FreightRadio_Single">單筆計算</label>
					</div>
					<div class="form-check me-5">
						<input id="FreightRadio_Box" class="form-check-input" type="radio" name="FreightType" value="3">
						<label class="form-check-label" for="FreightRadio_Box">已箱計費</label>
					</div>
				</div>
				<div class="row logisticsPrice">
					<div class="col-6 col-sm-3 mb-3">
						<div class="freight input-group mb-3">
							<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
								<span class="material-symbols-outlined me-1">paid</span>單筆運費
							</div>
							<input id="InputFreight"
								   class="form-control rounded"
								   type="number"
								   name="Freight"
								   aria-label="Input Freight"
								   disabled="disabled"
								   required>
						</div>
					</div>

					<div class="col-6 col-sm-3 mb-3">
						<div class="low_con input-group mb-3">
							<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
								<span class="material-symbols-outlined me-1">toll</span>折抵低消
							</div>
							<input id="InputLowCon"
								   class="form-control rounded"
								   type="number"
								   name="Low_Con"
								   aria-label="Input Low Consumption"
								   disabled="disabled"
								   required>
						</div>
					</div>

					<div class="col-12 col-sm-6 mb-3 discountFreightGroupSection d-none">
						<div class="input-group discount-freight-group">

							<span class="input-group-text">折抵運費</span>

							<select id="SelectDiscountFreightType"
									class="form-select discount-freight-type"
									name="DiscountFreightType"
									disabled="disabled">
							</select>

							<span class="input-group-text">NT$</span>

							<input id="InputDfreight"
								   class="form-control"
								   type="number"
								   name="Dis_Freight"
								   disabled="disabled"
								   required>

						</div>
					</div>
				</div>
				<div class="d-flex gap-3">
					<div class="logisticsBoxSection col-6 d-none">
						<button type="button" id="InputLogisticsBox" class="btn btn-outline-primary btn-sm">
							選擇箱型
						</button>
						<div id="LogisticsBoxSelectedList" class="mt-2"></div>
					</div>

					<div class="prod input-group mb-3" name="prods" data-form-type="prods col">
						<div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
							<span class="material-symbols-outlined me-1">alternate_email</span>商品
						</div>
						<textarea id="InputProd" class="form-control rounded text-start InputProd formItem" name="ProdSelected" aria-label="Input Prod" data-bs-toggle="modal" data-bs-target="#ProdModal" readonly></textarea>
					</div>
				</div>
			</form>
			@await Component.InvokeAsync(nameof(Modal), new { dispaly = "ProdSelectModal" })
			@await Component.InvokeAsync(nameof(Modal), new { dispaly = "LogisticsBoxModal" })
		</div>
	</div>
</div>