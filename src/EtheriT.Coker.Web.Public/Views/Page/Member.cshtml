@using System.Web;
@using EtheriT.Coker.Application.Shared.Dto.WebMenu
@using EtheriT.Coker.Application.Shared.Dto.enumType;
@using EtheriT.Coker.Web.Public.Models;
@using EtheriT.Coker.Application.Shared.i18n;
@model PageViewModel
<link rel="stylesheet" href="~/css//Page/Member.min.css" asp-append-version="true" />
<script src="/js/Page/Member.min.js" asp-append-version="true"></script>
<script nonce="@ViewBag.Nonce">
    const PageKey = "@Model.option";
    const local = @Html.Raw(L.getAllJsonString());
</script>
@Html.AntiForgeryToken()
<!-- Modal -->
<div class="modal fade" id="ECPayModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="ECPayModal" aria-hidden="true" data-server-type="@(ViewBag.IsProduction ? "Prod" : "Stage")">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5 mx-auto" id="ECPayModalLabel">選擇支付方式</h1>
            </div>
            <div class="modal-body">
                <div id="ECPayPayment"></div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn_pay btn-primary rounded px-4">確認付款</button>
                <button type="button" class="btn btn_cancel btn-danger rounded px-4">取消付款</button>
            </div>
        </div>
    </div>
</div>
<div class="top_title_1 p-3">
    <nav class="bread d-none d-md-block container">
        <ol class="list-unstyled d-flex my-0">
            @foreach (var menu in Model.MenuBread ?? new List<GetMenuBreadDto>())
            {
                @if (@menu.Link == "")
                {
                    <li class="px-1">@menu.Title</li>
                }
                else
                {
                    <li class="px-1"><a class="text-decoration-none" href="@menu.Link" title="@L.get("LinkTo", menu.Title)">@menu.Title</a></li>
                }
            }
        </ol>
    </nav>
</div>
<Content id="main">
    <div id="ReOrderAlertModal" class="modal fade" aria-hidden="true" aria-labelledby="ReOrderAlertModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered justify-content-center">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center fs-4 fw-bold">訂單變動</div>
                    <div class="orderlist mb-3">
                        <ul class="list-unstyled"></ul>
                        <template id="RePayOrderListTemplate">
                            <li class="border-2 border-bottom pb-2">
                                <figure class="align-items-center d-flex mb-0">
                                    <img data-key="imagePath" src="" alt="" class="">
                                    <figcaption class="ps-3">
                                        <div data-key="title" class="fs-5 fw-bold"></div>
                                        <div class="spec"><span data-key="s1Title" class="border me-2 px-1 d-none"></span><span data-key="s2Title" class="border px-1 d-none"></span></div>
                                    </figcaption>
                                </figure>
                                <div class="align-items-center">
                                    <div data-key="describe" class="describe text-center fw-bold fs-5 red_text  d-none"></div>
                                    <div class="title row text-center">
                                        <div class="col-4">單價</div>
                                        <div class="col-4">數量</div><div class="col-4">小計</div>
                                    </div>
                                    <div class="content row text-center align-items-center">
                                        <div class="col-4">
                                            <div data-key="oldPrice" class="text-decoration-line-through fw-light price d-none"></div>
                                            <div data-key="price" class="price"></div>
                                        </div>
                                        <div class="col-4">
                                            <div data-key="oldQuantity" class="text-decoration-line-through fw-light quantity d-none"></div>
                                            <div data-key="quantity" class="quantity"></div>
                                        </div>
                                        <div class="col-4">
                                            <div data-key="subtotal_old" class="subtotal_old text-decoration-line-through fw-light price"></div>
                                            <div data-key="subtotal_new" class="subtotal_new price red_text"></div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        </template>
                        <div class="align-items-end row">
                            <div class="col-8 text-end">商品金額：</div><div class="col-4 ps-0 text-start">
                                <div class="oh_subtotal_old fw-light price text-decoration-line-through"></div>
                                <div class="oh_subtotal_new price"></div>
                            </div>
                        </div>
                        <div class="my-2 row"><div class="col-8 text-end">運費：</div><div class="oh_freight col-4 ps-0 text-start price"></div></div>
                        <div class="row"><div class="col-8 text-end fw-bold">總金額：</div><div class="oh_total col-4 fw-bold price ps-0 red_text text-start"></div></div>
                    </div>
                    <button class="btn_repay btn btn-primary rounded border-0 text-white px-3 w-100 fs-5 mb-3">進入付款程序</button>
                    <button class="btn_cancelrepay  btn btn-danger rounded border-0 text-white px-3 w-100 fs-5 mb-3">取　　消</button>
                </div>
            </div>
        </div>
    </div>
    <div id="ResetEmailModal" class="modal fade" aria-hidden="true" aria-labelledby="ResetEmailModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered justify-content-center">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center fs-4 fw-bold">@L.get("ChangeEmail")</div>
                    <form id="ResetEmailForm" class="card-body needs-validation" method="post">
                        <input type="hidden" name="authentiity_token" value="@ViewData["XSRF-TOKEN"]" />
                        <div class="input-group mb-3">
                            <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                <span class="material-symbols-outlined text-black-50">lock</span>
                            </div>
                            <input class="input_bg form-control rounded border-0 py-3 pass" type="password" autocomplete="off" aria-label="Input Password" placeholder="@L.get("Password")" required name="password">
                            <div class="position-absolute pe-3 end-0 top-50 d-flex translate-middle-y fs-4">
                                <button class="btn_passtoggle material-symbols-outlined text-black-50 bg-transparent border-0 px-0" title="@L.get("ShowPassword")">visibility_off</button>
                            </div>
                        </div>
                        <div class="input-group mb-3">
                            <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                <span class="material-symbols-outlined text-black-50">mail</span>
                            </div>
                            <input class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input New Mail" placeholder="新的電子信箱" required name="email">
                        </div>
                        <div class="newmail_vcode input-group">
                            <input id="InputNewMailVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input New Email Verification Code" placeholder="@L.get("VerificationCode")" maxlength="4" autocomplete="off" required>
                            <div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
                                <img id="NewMailImgCaptcha" alt="@L.get("Captcha")" class="img-fluid" src="" />
                            </div>
                        </div>
                    </form>
                    <div class="d-flex justify-content-end px-3">
                        <button class="btn_refresh border-0 bg-transparent text-black-50">@L.get("RefreshVerificationCode")</button>
                    </div>
                    <button class="btn_resetmail w-100 rounded border-0 text-white py-2 fs-5 my-3">@L.get("Confirm")</button>
                    <button class="btn_resetforget bg-transparent border-0 text-decoration-underline text-black-50 w-100">@L.get("ForgotPassword")?</button>
                </div>
            </div>
        </div>
    </div>
    <div class="container d-flex flex-row">
        <ul class="nav flex-column" id="ToolList" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-tab-pane" type="button" role="tab" aria-controls="info-tab-pane" aria-selected="true">
                    <span class="material-symbols-outlined mx-2">
                        account_circle
                    </span>@L.get("Profile")
                </button>
            </li>
            @if (ViewBag.ShoppingEnable && ViewBag.HasShoppingCar != null && ViewBag.HasShoppingCar && ViewBag.storeBuyState.IndexOf("noPay") < 0)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile-tab-pane" type="button" role="tab" aria-controls="profile-tab-pane" aria-selected="false">
                        <span class="material-symbols-outlined mx-2">
                            other_admission
                        </span>歷史訂單
                    </button>
                </li>
            }
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="favorite-tab" data-bs-toggle="tab" data-bs-target="#favorite-tab-pane" type="button" role="tab" aria-controls="favorite-tab-pane" aria-selected="false">
                    <span class="material-symbols-outlined mx-2">
                        favorite
                    </span>@L.get("FavoriteProducts")
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history-tab-pane" type="button" role="tab" aria-controls="history-tab-pane" aria-selected="false">
                    <span class="material-symbols-outlined mx-2">
                        pending_actions
                    </span>@L.get("BrowsingHistory")
                </button>
            </li>
        </ul>
        <div id="TabContent" class="tab-content">
            <div id="info-tab-pane" class="tab-pane fade show active" role="tabpanel" aria-labelledby="info-tab" tabindex="0">
                <form id="UserDataForm" class="">
                    <div class="row">
                        <div class="form-floating mb-3 col-12  col-sm-6">
                            <input id="Name" name="name" class="customer_info form-control" type="text" placeholder="" required>
                            <label class="required required_all" for="name">@L.get("Name")</label>
                            <div class="invalid-feedback">@L.get("ErrorNameRequired")!</div>
                        </div>
                        <fieldset class="row mb-3 col-12 col-sm-6 ">
                            <legend class="col-form-label col-sm-2 pt-0 align-content-center">@L.get("Gender")</legend>
                            <div class="col-sm-10 align-content-center">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="sex" id="inputSex1" value="1">
                                    <label class="form-check-label" for="inputSex1">@L.get("GenderMale")</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="sex" id="inputSex2" value="2">
                                    <label class="form-check-label" for="inputSex2">@L.get("GenderFemale")</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="sex" id="inputSex" value="3">
                                    <label class="form-check-label" for="inputSex">@L.get("GenderOther")</label>
                                </div>
                            </div>
                        </fieldset>
                    </div>
                    <div class="form-floating mb-3">
                        <input id="Birthday" name="birthday" class="customer_info form-control bg-white" type="date">
                        <label class="" for="Birthday">@L.get("Birthday")</label>
                    </div>
                    <div class="row mb-3">
                        <div class="form-floating col">
                            <input id="Email" name="email" class="customer_info form-control" type="Email" placeholder="" required disabled>
                            <label class="required required_all" for="Email">@L.get("Email")</label>
                            <div class="invalid-feedback">@L.get("ErrorEmailRequired")!</div>
                        </div>
                        <div class="col-12 col-sm-auto align-items-center d-flex pt-2 pt-sm-0">
                            <button class="btn_resetEmail btn btn-secondary rounded h-100 w-100">@L.get("ChangeEmail")</button>
                        </div>
                    </div>
                    <div class="form-floating mb-3">
                        <input id="CellPhone" name="cellPhone" class="customer_info form-control" type="tel" placeholder="">
                        <label class="" for="CellPhone">@L.get("MobilePhone")</label>
                    </div>
                    <div class="row">
                        <div class="form-floating mb-3 col-4 col-sm-2">
                            <input id="TelPhoneZone" class="form-control" name="zone" type="tel" placeholder="@L.get("HintEnterAreaCode")" value="" pattern="[0]\d{1,3}" maxlength="4">
                            <label class="px-4" for="TelPhoneZone">@L.get("PhoneAreaCode")</label>
                        </div>
                        <div class="form-floating mb-3 col pe-sm-0 ps-0">
                            <input id="TelPhone" class="form-control" name="telPhone" type="tel" placeholder="@L.get("請輸入聯絡電話")" value="" pattern="\d{7}" maxlength="7">
                            <label for="TelPhone">@L.get("PhoneNumber")</label>
                        </div>
                        <div class="form-floating mb-3 col-6 col-sm-3">
                            <input id="TelPhoneExt" class="form-control" name="ext" type="tel" placeholder="@L.get("HintEnterExtension")" value="" pattern="\d*">
                            <label class="px-4" for="TelPhoneExt">@L.get("PhoneExtension")</label>
                        </div>
                    </div>
                    <div id="TWzipcode" class="row" data-form-type="zipcode">
                        <div class="county form-floating mb-3 col-6 col-sm-3" data-role="county"></div>
                        <div class="district form-floating mb-3 col-6 col-sm-3 pe-sm-0 ps-0" data-role="district"></div>
                        <div class="form-floating mb-3 col-12 col-sm-6">
                            <input id="Address" name="address" class="address form-control" type="text" placeholder="@L.get("HintEnterAddress")">
                            <label class="px-4" for="Address">@L.get("Address")</label>
                            <div class="invalid-feedback">@L.get("ErrorAddressFormatInvalid")!</div>
                        </div>
                    </div>
                </form>
                <div class="btn_area">
                    <div class="d-flex w-100 mt-3 justify-content-center">
                        <button class="btn_modifi btn btn-secondary rounded">@L.get("SaveChanges")</button>
                        <button class="btn_resetPassword btn rounded">@L.get("ChangePassword")</button>
                        @* <button class="btn_resetEmail btn btn-secondary rounded">電子郵件修改</button> *@
                    </div>
                    <div class="d-flex justify-content-center mt-5">
                        <button class="btn_logout btn btn-secondary rounded border-0">@L.get("Logout")</button>
                    </div>
                </div>
            </div>
            @if (ViewBag.ShoppingEnable && ViewBag.HasShoppingCar != null && ViewBag.HasShoppingCar && ViewBag.storeBuyState.IndexOf("noPay") < 0)
            {
                <div id="profile-tab-pane" class="tab-pane fade" role="tabpanel" aria-labelledby="profile-tab" tabindex="1">
                    <div class="nodata h5 text-center fw-bold d-none">@L.get("EmptyOrderHistory")</div>

                    <ul class="page_btn d-flex justify-content-center mb-4 pagination d-none" data-init="false">
                        <li class="page-item btn_prev">
                            <button class="page-link text-black" title="@L.get("PaginationPrev")">
                                <i class="fa-solid fa-angle-left"></i>
                            </button>
                        </li>
                        <li class="page-item btn_next">
                            <button class="page-link text-black" title="@L.get("PaginationNext")">
                                <i class="fa-solid fa-angle-right"></i>
                            </button>
                        </li>
                    </ul>

                    <div class="content"></div>

                    <template id="Template_Order_List">
                        <div class="order_frame border border-5 rounded p-3 mb-3">
                            <div class="row mb-1 order_list_header">
                                <div class="col-3 text-center">訂單編號</div>
                                <div class="col-2 text-center">訂單日期</div>
                                <div class="col-2 text-center">訂購總額</div>
                                <div class="col-2 text-center">付款方式</div>
                                <div class="col-3 text-center">訂單狀態</div>
                            </div>
                            <div class="row my-1 fw-bold">
                                <div class="number col-3 text-center"></div>
                                <div class="date col-2 text-center"></div>
                                <div class="amount col-2 text-center text-danger"></div>
                                <div class="payment col-2 text-center"></div>
                                <div class="state col-3 text-center"></div>
                            </div>
                            <div class="w-100 d-flex justify-content-end align-items-end flex-column my-3">
                                <button class="btn_buyInfo btn border-0 rounded my-2 d-none" type="button" title="查詢付款資訊">
                                    查詢付款資訊
                                </button>
                                <button class="btn_buyAgain btn border-0 rounded my-2" type="button" title="再次購買">
                                    再買一次
                                </button>
                            </div>
                            <div class="collapse">
                                <div class="card card-body">
                                    <ul class="list-group list-group-flush mb-3">
                                        <li class="list-group-item">
                                            <div class="row d-lg-flex">
                                                <div class="col-2 text-center">商品圖片</div>
                                                <div class="col-4 text-start">商品名稱</div>
                                                <div class="col-2 text-end">單價</div>
                                                <div class="col-2 text-end">數量</div>
                                                <div class="col-2 text-end">小計</div>
                                            </div>
                                        </li>
                                    </ul>
                                    <div class="row d-lg-flex px-3">
                                        <div class="col-10 text-end align-content-center">商品金額：</div>
                                        <div class="header_subtotal price col-2 text-end align-content-center"></div>
                                    </div>
                                    <div class="row d-lg-flex px-3">
                                        <div class="col-10 text-end align-content-center">運費：</div>
                                        <div class="header_freight price col-2 text-end align-content-center"></div>
                                    </div>
                                    <div class="row d-lg-flex px-3">
                                        <div class="col-10 text-end align-content-center fw-bold">總金額：</div>
                                        <div class="header_total price col-2 text-end align-content-center fw-bold"></div>
                                    </div>
                                </div>
                            </div>
                            <button class="btn_collapse btn_detailed btn border-0 rounded w-100" type="button" data-bs-toggle="collapse" aria-expanded="false" aria-controls="collapseExample" title="查看訂單明細">
                                查看訂單明細
                            </button>
                        </div>
                    </template>

                    <template id="Template_Order_Details_List">
                        <li class="list-group-item">
                            <a href="" title="" target="_self">
                                <div class="row d-lg-flex">
                                    <div class="col-2 text-center"><img src="" alt="" /></div>
                                    <div class=" col-4 text-start align-content-center">
                                        <div class="title fw-bold"></div>
                                        <div class="spec d-flex"></div>
                                    </div>
                                    <span class="isHide">單價:</span><div class="price col-2 text-end align-content-center"></div>
                                    <p class="isWrap"></p>
                                    <span class="isHide">數量:</span><div class="quantity col-2 text-end align-content-center"></div>
                                    <p class="smailWrap"></p>
                                    <span class="isHide hideTotal">小計:</span><div class="subtotal price col-2 text-end align-content-center"></div>
                                </div>
                            </a>
                        </li>
                    </template>

                </div>
            }
            <div id="favorite-tab-pane" class="tab-pane fade" role="tabpanel" aria-labelledby="favorite-tab" tabindex="2">
                <div class="nodata h5 text-center fw-bold  d-none">@L.get("EmptyFavorites")</div>

                <div class="btn_switchViewType d-flex justify-content-end m-3 mt-0 d-none">
                    <button class="align-items-center bg-transparent border-0 d-flex mx-1 focus" data-type="grid">
                        <span class="material-symbols-outlined fs-5 me-1">grid_on</span>@L.get("TabImage")
                    </button>
                    <button class="align-items-center bg-transparent border-0 d-flex mx-1" data-type="list">
                        <span class="material-symbols-outlined fs-5 me-1">view_list</span>@L.get("TabImageText")
                    </button>
                </div>

                <template id="FavoriteTemplate">
                    <div class="type_change_frame row position-relative mb-3">
                        <a data-key="link" class="rounded">
                            <figure>
                                <div class="image_frame">
                                    <div>
                                        <img data-key="image" src="" alt="" />
                                    </div>
                                </div>
                                <figcaption class="w-100">
                                    <div>
                                        <div data-key="itemNo" class=""></div>
                                        <div data-key="title" class=""></div>
                                    </div>
                                    <div data-key="description"></div>
                                    <div class="price_group">
                                        <div data-key="oriPrice" class="text-decoration-line-through"></div>
                                        <div data-key="price" class="fw-bold text-danger"></div>
                                    </div>
                                </figcaption>
                            </figure>
                        </a>
                        <div class="shareBlock mt-1 p-1 position-absolute rounded-circle w-auto">
                            <button class="btn_share bg-transparent border-0" title="@L.get("ShareProduct")">
                                <i class="fa-solid fa-share text-white"></i>
                                <span class="d-none">@L.get("Share")</span>
                            </button>
                        </div>
                        <div class="favbtn position-absolute w-auto p-1 mt-2 rounded-circle">
                            <button class="btn_favorite bg-transparent border-0" title="@L.get("RemoveFavorite")">
                                <i class="font-rad fa-solid fa-heart"></i>
                            </button>
                        </div>
                    </div>
                </template>

                <div class="content row px-5 type_grid" data-storagename="Favorite">
                </div>

                <ul class="page_btn d-flex justify-content-center my-4 pagination d-none" data-init="false">
                    <li class="page-item btn_prev">
                        <button class="page-link text-black" title="@L.get("PaginationPrev")">
                            <i class="fa-solid fa-angle-left"></i>
                        </button>
                    </li>
                    <li class="page-item btn_next">
                        <button class="page-link text-black" title="@L.get("PaginationNext")">
                            <i class="fa-solid fa-angle-right"></i>
                        </button>
                    </li>
                </ul>
            </div>
            <div id="history-tab-pane" class="tab-pane fade" role="tabpanel" aria-labelledby="history-tab" tabindex="3">
                <div class="nodata h5 text-center fw-bold d-none">@L.get("EmptyBrowsingHistory")</div>

                <div class="btn_switchViewType d-flex justify-content-end m-3 mt-0 d-none">
                    <button class="align-items-center bg-transparent border-0 d-flex mx-1 focus" data-type="grid">
                        <span class="material-symbols-outlined fs-5 me-1">grid_on</span>@L.get("TabImage")
                    </button>
                    <button class="align-items-center bg-transparent border-0 d-flex mx-1" data-type="list">
                        <span class="material-symbols-outlined fs-5 me-1">view_list</span>@L.get("TabImageText")
                    </button>
                </div>

                <template id="BrowsingTemplate">
                    <div class="type_change_frame row position-relative mb-3">
                        <a data-key="link" class="rounded">
                            <figure>
                                <div class="image_frame">
                                    <div>
                                        <img data-key="image" src="" alt="" />
                                    </div>
                                </div>
                                <figcaption class="w-100">
                                    <div>
                                        <div data-key="itemNo" class=""></div>
                                        <div data-key="title" class=""></div>
                                    </div>
                                    <div data-key="description"></div>
                                    <div class="price_group">
                                        <div data-key="oriPrice" class="text-decoration-line-through"></div>
                                        <div data-key="price" class="fw-bold text-danger"></div>
                                    </div>
                                </figcaption>
                            </figure>
