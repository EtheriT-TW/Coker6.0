<div id="RecipientModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header border-0">
				<h5 id="staticBackdropLabel" class="modal-title fw-bold">選擇收件地址清單</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body text-center">
				<table class="table">
					<thead>
						<tr>
							<th scope="col" class="fw-normal">選擇</th>
							<th scope="col" class="fw-normal">姓名</th>
							<th scope="col" class="fw-normal">郵遞區號</th>
							<th scope="col" class="fw-normal">地址</th>
							<th scope="col" class="fw-normal">聯絡電話</th>
							<th scope="col" class="fw-normal">行動電話</th>
							<th scope="col" class="fw-normal">刪除</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<th scope="row" class="fw-normal">
								<input id="radio_recipient1" class="form-check-input" type="radio" name="RecipientDataRadio" checked>
							</th>
							<td class="fw-normal">姓○</td>
							<td class="fw-normal">806</td>
							<td class="fw-normal">地址資料***</td>
							<td class="fw-normal">07-1234***</td>
							<td class="fw-normal">0912-******</td>
							<td class="fw-normal">
								<button type="button" class="btn_delete_recipient bg-transparent border-0"><i class="fa-solid fa-xmark"></i></button>
							</td>
						</tr>
						<tr>
							<th scope="row" class="fw-normal">
								<input id="radio_recipient2" class="form-check-input" type="radio" name="RecipientDataRadio">
							</th>
							<td class="fw-normal">姓○</td>
							<td class="fw-normal">806</td>
							<td class="fw-normal">地址資料***</td>
							<td class="fw-normal">07-1234***</td>
							<td class="fw-normal">0912-******</td>
							<td class="fw-normal">
								<button type="button" class="btn_delete_recipient bg-transparent border-0"><i class="fa-solid fa-xmark"></i></button>
							</td>
						</tr>
					</tbody>
				</table>
			</div>
			<div class="modal-footer justify-content-center border-0">
				<button type="button" class="text-white border-0 px-5 py-1" data-bs-dismiss="modal">確定</button>
			</div>
		</div>
	</div>
</div>

<div class="history container my-4 d-flex flex-wrap justify-content-center justify-content-md-end">
	<a class="bg-white text-center m-1 py-2" href="/Favorites">
		<div>收藏商品<span class="fw-bold">20</span>件</div>
	</a>
	<a href="" class="bg-white text-center m-1 py-2">
		<div>買過商品<span class="fw-bold">3</span>件</div>
	</a>
</div>

<div id="BuyStepSwiper" class="container pt-5 pb-4 position-relative">
	<div id="memberLogin" class="container my-5">
		<div class="rounded-1 px-3 py-4 bg-white d-flex align-items-center justify-content-center justify-content-sm-start">
			<div>購買前登入會員可更方便查詢訂單！</div>
			<button class="btn_login bg-transparent rounded-1 ms-0 ms-sm-3">會員登入</button>
		</div>
	</div>

	<div class="swiper shadow-lg">
		<div class="swiper-wrapper">
			<div id="Step1" class="card text-center swiper-slide">
