								<input id="FreeShip" class="form-check-input" type="radio" name="RadioShipping" value="1" data-freight="0" required>
								<label class="form-check-label" for="FreeShip">免運</label>
								<div class="invalid-feedback">請選擇運送方式</div>
							</div>
							<div class="w-50">免運<span>(您已符合免運條件)</span></div>
						</div>
					</form>

					<div class="title px-3 py-2 d-flex align-items-center justify-content-between">
