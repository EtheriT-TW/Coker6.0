							<div>商品金額</div>
							<div class="subtotal price"></div>
						</div>
						<div class="py-2 d-flex justify-content-end text-end">
							<div>運費</div>
							<div class="shipping_fee price">0</div>
						</div>
						<div class="py-2 border-top d-flex justify-content-end text-end">
							<div>小計</div>
							<div class="total_amount price"></div>
						</div>
					</div>

					<div class="swiper_button my-5">
						<button class="btn_swiper_prev_buystep border-0 p-0 py-2 rounded-3 text-center text-white mx-2">
