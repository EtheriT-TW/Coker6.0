                    <div class="modal-header border-0">
                        <button type="button" class="btn-close rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="text-center fs-4 fw-bold">會員登入</div>
                        <form id="LoginForm" class="card-body needs-validation" method="post">
                            <input type="hidden" name="authentiity_token" value="@ViewData["XSRF-TOKEN"]" />
                            <div class="login_mail input-group mb-3">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">mail</span>
                                </div>
                                <input id="InputLoginMail" class="input_bg form-control rounded border-0 py-3" type="email" aria-label="Input Login Mail" placeholder="信箱" required name="Email">
                            </div>
                            <div class="login_pass input-group mb-3">
                                <div class="position-absolute ps-3 top-50 d-flex translate-middle-y fs-4">
                                    <span class="material-symbols-outlined text-black-50">lock</span>
                                </div>
                                <input id="InputLoginPass" class="input_bg form-control rounded border-0 py-3" type="password" autocomplete="off" aria-label="Input Login Password" placeholder="密碼" required name="Password">
                            </div>
                            <div class="login_vcode input-group">
                                <input id="InputLoginVCode" class="input_bg form-control rounded border-0 py-3 ps-3" type="text" aria-label="Input Login Verification Code" placeholder="輸入驗證碼" maxlength="4" required>
                                <div class="position-absolute d-flex ps-2 me-2 top-50 end-0 translate-middle-y z-index-up ">
                                    <img id="LoginImgCaptcha" alt="驗證碼" class="img-fluid" src="" />
                                </div>
                            </div>
                            <div class="d-flex justify-content-end">
                                <button class="btn_refresh border-0 bg-transparent text-black-50">刷新驗證碼</button>
                            </div>
                            <div class="form-check">
                                <input id="CheckRemember" class="form-check-input" type="checkbox" value="">
                                <label class="form-check-label" for="CheckRemember">記住我的帳號</label>
                            </div>
                        </form>
                        <button class="btn_login w-100 rounded border-0 text-white py-2 fs-5 my-3">登　入</button>
                        <button class="btn_other_login w-100 rounded border-0 text-white py-2 fs-5 " data-bs-target="#OtherLoginModal" data-bs-toggle="modal" data-bs-dismiss="modal">其他登入方式</button>
                    </div>
                    <div class="modal-footer d-flex justify-content-center border-0">
