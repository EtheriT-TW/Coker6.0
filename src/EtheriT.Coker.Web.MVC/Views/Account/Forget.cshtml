@{
    ViewData["Title"] = "忘記密碼";
}
<div class="row align-items-center justify-content-center align-items-center">
    <div class="col-md-12">
        <div class="form-block mx-auto">
            <div class="text-center mb-5">
                <h3 class="text-uppercase">@ViewData["Title"]</h3>
            </div>
            <form action="#" method="post">
                <div class="form-group first">
                    <label for="username">使用者帳號</label>
                    <input type="text" class="form-control" placeholder="請輸入Email" id="username">
                </div>
                <div class="d-sm-flex mb-5 align-items-center">
                    <span class="ml-auto">
                        <a class="forgot-pass" asp-area="" asp-controller="Account" asp-action="Index">回到登入頁</a>
                    </span>
                </div>
                <input type="submit" value="確認送出" class="btn btn-block py-2 btn-primary">
            </form>
        </div>
    </div>
</div>