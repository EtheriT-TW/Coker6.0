@using DevExtreme.AspNet.Mvc
@using EtheriT.Coker.Application.Shared.Dto.Article;
@using EtheriT.Coker.Application.Shared.Dto.Directory
@using EtheriT.Coker.Application.Shared.Dto.EnterAd
@using EtheriT.Coker.Application.Shared.Dto.TechnicalCertificate
@using EtheriT.Coker.Web.MVC.Views.Shared.Components.Modal
@using EtheriT.Coker.Web.MVC.Startup
@using EtheriT.Coker.Web.MVC.Extensions
@{
    ViewData["Title"] = "Directory";
}

<link rel="stylesheet" href="~/css/ContentManagement/Directory.min.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/ContentManagement/Article.min.css" asp-append-version="true" />
@{
    await Html.RenderPartialAsync(@"GrapesComponents\_ScriptComponents");
    var perm = Context.GetPermission();
}
<script src="~/js/ContentManagement/DirectoryFacet.min.js" asp-append-version="true"></script>
<script src="~/js/ContentManagement/Directory.min.js" asp-append-version="true"></script>
@Html.AntiForgeryToken()
<div class="">
    <div id="TopLine" class="py-2 px-4">
        <div class="d-flex">
            <div class="title fw-bold fs-3">目錄管理</div>
            <a class="btn btn-primary text-decoration-none align-self-center" href="#" role="button">返回選單</a>
        </div>
    </div>
    @await Component.InvokeAsync(nameof(Modal), new { dispaly = "TagSelectModal" })
    <div id="pages">
        <div id="DirectoryList" class="card border-0">
            @await Component.InvokeAsync(nameof(Modal), new { dispaly = "PermissionDetailsModal" })
            <div class="card-body position-relative">
                <button class="btn_add border btn-outline-light text-black d-flex p-1 rounded position-absolute text-decoration-none">
                    <span class="material-symbols-outlined">add</span>
                </button>
                @(
                    Html.DevExtreme().DataGrid<DirectoryGetListDto>()
                    .DataSource(d => d.RemoteController().Key("Id")
                    .LoadUrl("/api/Directory/GetAllList").LoadMethod("Get")
                    )
                    .RemoteOperations(true)
                    .ColumnHidingEnabled(true)
                    .ShowBorders(true)
                    .FilterRow(filterRow => filterRow
                    .Visible(true)
                    .ApplyFilter(GridApplyFilterMode.Auto)
                    )
                    .SearchPanel(searchPanel => searchPanel
                    .Visible(true)
                    .Width(480)
                    .Placeholder("請輸入要搜尋的資料")
                    )
                    .ShowRowLines(true)
                    .Columns(c =>
                    {
                        c.AddFor(e => e.Id).Caption("ID").Width(40).AllowEditing(false);
                        c.AddFor(e => e.Title).Caption("標題");
                        c.AddFor(e => e.Description).Caption("描述");
                        c.AddFor(e => e.Type).Caption("綁定內容").Width(100);
                        c.AddFor(e => e.Items).Caption("綁定標籤、選單");
                        c.AddFor(e => e.Visible).Caption("是否顯示").Width(100);
                        c.Add()
                        .Type(GridCommandColumnType.Buttons)
                        .Buttons(b =>
                        {
                            b.Add().Name("edit").Visible(perm.CanUpdate).OnClick("editButtonClicked");
                            b.Add().Icon("verticalaligncenter").Visible(perm.CanVisble).OnClick("reladataButtonClicked");
                            b.Add().Icon("group").Name("group").Visible(perm.superManager).OnClick("groupArticlesButtonClicked");
                            b.Add().Name("delete").Visible(perm.CanRemove).OnClick("deleteButtonClicked");
                        });
                    })
                    .ColumnAutoWidth(true)
                    .Paging(paging => paging.PageSize(30))
                    .Pager(pager =>
                    {
                        pager.Visible(true);
                        pager.ShowPageSizeSelector(true);
                        pager.AllowedPageSizes(new[] { 10, 20, 30 });
                        pager.ShowInfo(true);
                    })
                    .Editing(editing =>
                    {
                        editing.AllowDeleting(true);
                        editing.AllowUpdating(true);
                        editing.UseIcons(true);
                    })
                    .OnContentReady("contentReady")
                    )
            </div>
        </div>
        <div id="DirectoryContent" class="card border-0 d-none">
            <div class="card-header d-flex justify-content-between">
                <div class="fw-bold fs-5 d-flex align-items-center">
                    <button class="btn_back d-flex bg-transparent border-0 align-items-center">
                        <span class="material-symbols-outlined">
                            keyboard_backspace
                        </span>
                    </button>
                    <div class="lh-lg title">編輯目錄</div>
                </div>
                <div class="d-flex">
                    <a class="btn btn-primary btn-open-facet border-0 d-flex align-items-center me-3 text-decoration-none" role="button" href="#">
                        <span class="material-symbols-outlined me-1">settings_b_roll</span>
                        進階設定
                    </a>
                    <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3 " form="DirectorytForm">儲　存</button>
                </div>
            </div>

            <form id="DirectorytForm" class="card-body needs-validation">
                <div class="d-flex align-self-center mb-3 justify-content-between">
                    <div class="bind_type d-flex">
                        <label class="form-label mb-0 pe-3 align-self-center text-nowrap" for="BindType">綁定內容</label>
                        <select id="BindType" class="form-select" aria-label="Bind Type Select" required>
                            <option selected value="null" class="d-none">請選擇</option>
                            <option value="1">商品</option>
                            <option value="2">文章</option>
                            <option value="3">選單</option>
                        </select>
                    </div>
                    <button class="btn_display bg-transparent border-0 text-primary d-flex align-self-center" form="none" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
                        <span class="material-symbols-outlined fs-2">visibility</span>
                    </button>
                </div>

                <div class="title border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0">標題</span>
                        <div class="count">0</div>
                    </div>
                    <textarea class="form-control border-0" aria-label="With textarea" maxlength="60" placeholder="輸入文章標題"></textarea>
                </div>

                <div class="description border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0">描述</span>
                        <div class="count">0</div>
                    </div>
                    <textarea class="form-control border-0" aria-label="With textarea" maxlength="150" placeholder="輸入文章描述"></textarea>
                </div>
                <div class="tag input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1">alternate_email</span>標籤
                    </div>
                    <input id="InputTag" class="form-control rounded text-start InputTag formItem" name="TagSelected" type="button" aria-label="Input Tag" data-bs-toggle="modal" data-bs-target="#TagModal">
                </div>

                @await Component.InvokeAsync(nameof(Modal), new {dispaly = "WebmenuListModal"})

            </form>
        </div>

        <div id="DirectoryCanvas" class="card border-0 d-none">
            <div id="gjs"></div>
        </div>

        <div id="DirectoryItemps" class="card border-0 d-none">
            <div class="articles d-none">
                <div class="card-body position-relative">
                    <div class="d-flex position-absolute z-index-up">
                        <button class="btn_back border btn-outline-light text-black d-flex p-1 rounded text-decoration-none">
                            <span class="material-symbols-outlined">arrow_back</span>
                        </button>
                        <button class="btn_add border btn-outline-light text-black d-flex p-1 rounded text-decoration-none ml-3">
                            <span class="material-symbols-outlined">add</span>
                        </button>
                    </div>
                    @(
                        Html.DevExtreme().DataGrid<DirectoryReleInfoDto>()
                                .DataSource(d => d.RemoteController().Key("Id")
                                    .LoadUrl("/api/Directory/GetDirectoryDetailList").LoadMethod("Get")
                                    .LoadParams(new
                                    {
                                        id = new JS("GetDirectoryId"),
                                        type = new JS("GetDirectoryType")
                                    })
                            )
                        .OnContentReady("DirectoryDatailListReady")
                        .HeaderFilter(headerFilter => headerFilter.Visible(true))
                        .RemoteOperations(true)
                        .ColumnHidingEnabled(true)
                        .ShowBorders(true)
                        .FilterRow(filterRow => filterRow
                            .Visible(true)
                            .ApplyFilter(GridApplyFilterMode.Auto)
                        )
                        .SearchPanel(searchPanel => searchPanel
                            .Visible(true)
                            .Width(480)
                            .Placeholder("請輸入要搜尋的資料")
                        )
                        .ShowRowLines(true)
                        .Columns(c =>
                        {
                            c.AddFor(e => e.Id).Caption("編號").Width(90);
                            c.AddFor(e => e.Visible).Caption("顯示").AllowSearch(false).Width(90);
                            c.AddFor(e => e.Available).Caption("上架").AllowSearch(false).Width(90);
                            c.AddFor(e => e.Title).Caption("標題");
                            c.AddFor(e => e.NodeDate).Caption("發布日期").Width(90);
                            c.AddFor(e => e.StartTime).Caption("起始時間").Width(90).Visible(false);
                            c.AddFor(e => e.EndTime).Caption("結束時間").Width(90).Visible(false);
                            c.AddFor(e => e.SerNo).Caption("排序").Width(90);
                            c.AddFor(e => e.LastModificationTime).SortOrder(SortOrder.Desc).Format("yyyy/MM/dd HH:mm").Caption("最後編輯日期").Width(160);
                            c.Add()
                            .Type(GridCommandColumnType.Buttons)
                            .Buttons(b =>
                            {
                                b.Add().Name("edit").Visible(perm.CanUpdate).OnClick("editArticlesButtonClicked");
                                b.Add().Icon("palette").Visible(perm.CanUpdate).Name("edit").OnClick("paletteArticlesButtonClicked");
                                b.Add().Name("delete").Visible(perm.CanRemove).OnClick("deleteArticlesButtonClicked");
                            });
                        })
                        .ColumnAutoWidth(true)
                        .Paging(paging => paging.PageSize(30))
                        .Pager(pager =>
                        {
                            pager.Visible(true);
                            pager.ShowPageSizeSelector(true);
                            pager.AllowedPageSizes(new[] { 10, 20, 30 });
                            pager.ShowInfo(true);
                        })
                        .Editing(editing =>
                        {
                            editing.AllowDeleting(true);
                            editing.AllowUpdating(true);
                            editing.UseIcons(true);
                        })
                    )
                </div>
            </div>
            <div class="products d-none"></div>
            <div class="menus d-none"></div>
        </div>

        <div id="ArticleContent" class="card py-2 border-0 d-none">
            <div class="card-header d-flex justify-content-between">
                <div class="fw-bold fs-5 d-flex align-items-center">
                    <button class="btn_back d-flex bg-transparent border-0 align-items-center">
                        <span class="material-symbols-outlined">
                            keyboard_backspace
                        </span>
                    </button>
                    <div class="lh-lg">返回文章目錄</div>
                </div>
                <div class="d-flex">
                    <a class="btn btn-warning btn_permission_details border-0 d-flex align-items-center me-3 text-decoration-none" href="#" role="button">
                        <span class="material-symbols-outlined me-1">security</span>瀏覽權限
                    </a>
                    <button class="btn_done btn-primary border-0 px-3 py-1 text-white me-3  btn" form="ArticletForm">儲　存</button>
                    <button class="btn_to_canvas btn-success border-0 px-3 py-1 text-white d-flex align-items-center  btn" form="ArticletForm">
                        進階編輯<span class="material-symbols-outlined ms-1">palette</span>
                    </button>
                </div>
            </div>

            <form id="ArticletForm" class="card-body needs-validation">
                <input name="id" type="hidden" value="0" />
                <input name="fK_WebsiteId" type="hidden" />
                <div class="d-flex align-self-center mb-3 justify-content-between flex-wrap-reverse flex-md-nowrap">
                    <div id="ImageUpload" name="ImageUpload" data-form-type="images" data-image-type="6" data-image-size="3" data-target="id" class="d-flex justify-content-center image_upload" data-issinge="true" data-needcompress="false">
                        @await Component.InvokeAsync(nameof(Modal), new {dispaly = "ImageUploadModal"})
                    </div>
                    <div class="d-flex">
                        <input type="checkbox" id="ArticletFormVisible" class="selectedItem" name="visible" value="true" />
                        <label for="ArticletFormVisible" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示在畫面上">
                            <span class="material-symbols-outlined fs-2">visibility</span>
                            <span class="material-symbols-outlined fs-2">visibility_off</span>
                        </label>
                        <input type="checkbox" id="ArticletFormpoPularVisible" class="selectedItem" name="popularVisible" value="true" />
                        <label for="ArticletFormpoPularVisible" class="mx-3" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="是否顯示人氣值">
                            <span class="material-symbols-outlined fs-2">group</span>
                            <span class="material-symbols-outlined fs-2">group_off</span>
                        </label>
                        <input id="RemovedFromShelves" type="checkbox" name="removedFromShelves" class="selectedItem" checked value="true" />
                        <label for="RemovedFromShelves" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="上架">
                            <span class="material-symbols-outlined fs-2">open_in_new</span>
                            <span class="material-symbols-outlined fs-2">open_in_new_off</span>
                        </label>
                    </div>
                </div>

                <div class="title border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0 required_all">標題</span>
                        <div class="count">0</div>
                    </div>
                    <textarea name="title" class="form-control border-0" aria-label="With textarea" maxlength="50" placeholder="輸入文章標題" required></textarea>
                </div>
                <div class="date input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1">calendar_today</span>發布日期
                    </div>
                    <input id="NodeDate" name="nodeDate" data-form-type="date" class="form-control rounded" type="text" aria-label="Input Duration of Product" pattern="[1-9]\d{3}/\d{2}/\d{2}" autocomplete="off">
                </div>

                <div class="date input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">calendar_today</span>設定上架日期
                    </div>
                    <input id="InputDate" name="startEndDate" data-form-type="date_range" data-start="startTime" data-end="endTime" class="form-control rounded" type="text" aria-label="Input Duration of Product" name="datetimes" pattern="[1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2} ~ [1-9]\d{3}/\d{2}/\d{2} \d{2}:\d{2}" autocomplete="off" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up me-4">
                        <input id="PermanentCheck" name="permanent" data-form-type="disabled" data-target="InputDate" class="form-check-input" type="checkbox" checked value="true">
                        <label class="form-check-label fs-6 pe-2" for="PermanentCheck">永久顯示</label>
                    </div>
                </div>

                <div class="describe border mb-3 p-2 rounded">
                    <div class="d-flex justify-content-between w-100">
                        <span class="input-group-text bg-transparent border-0 p-0">描述</span>
                        <div class="count">0</div>
                    </div>
                    <textarea name="description" class="form-control border-0" aria-label="With textarea" maxlength="300" placeholder="輸入文章描述"></textarea>
                </div>

                <div class="tag input-group mb-3" name="tagSelected" data-form-type="tags">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1">alternate_email</span>標籤
                    </div>
                    <input class="form-control rounded text-start InputTag" name="tagDatas" type="button" aria-label="Input Tag" data-bs-toggle="modal" data-bs-target="#TagModal">
                </div>

                <div class="sort input-group mb-3">
                    <div class="position-absolute ps-2 top-50 d-flex translate-middle-y z-index-up">
                        <span class="material-symbols-outlined me-1 required_sign">sort_by_alpha</span>排序
                    </div>
                    <input id="ArticleSerNO" class="form-control rounded" name="serNO" type="number" aria-label="Input Sort of Article" disabled="disabled" required>
                    <div class="checkbox position-absolute end-0 top-50 translate-middle-y z-index-up me-4">
                        <input id="ArticleSortCheck" class="form-check-input" name="sortCheckbox" data-form-type="disabled" data-direct="reverse" data-value="500" data-target="ArticleSerNO" type="checkbox" value="false">
                        <label class="form-check-label fs-6 pe-2" for="ArticleSortCheck">自訂排序</label>
                    </div>
                </div>

                <template id="TemplateArticleFile">
                    <div class="data_upload row mx-0 border rounded mb-3 p-3 position-relative" data-uploadtype="5">
                        <ul class="col-12 p-0 overflow-auto mb-0">
                            <li class="btn_upload_add border mb-1 p-1 shadow-sm">
                                <button class="bg-transparent border-0 d-flex justify-content-center p-0 w-100" title="新增檔案">
                                    <span class="icon poiter  material-symbols-outlined">add</span>
                                </button>
                            </li>
                        </ul>
                        <div class="preview_frame col-12 border p-2 mb-2 d-none">
                            <div class="default_frame h-100 d-none d-flex justify-content-center align-items-center"><span>點選 + 號新增檔案</span></div>
                            <div class="upload_frame custom-file-container"></div>
                        </div>
                        <div class="position-absolute upload_title bg-white">檔案下載</div>
                        <div class="position-absolute upload_warning bg-white">已上鎖檔案不可解鎖</div>
                    </div>
                </template>

                <template id="TemplateUploadList">
                    <li class="upload_list d-flex align-items-center border bg-white shadow-sm px-2 py-1 gap-2 mb-1">
                        <div class="serNoTool gap-2 ">
                            <span class="icon move material-symbols-outlined" title="變更順序">open_with</span>
                            <input class="ser_no rounded text-center border text-black-50" type="number" aria-label="Upload data sort number" title="排序號碼" value="" step="1">
                        </div>
                        <span class="title ml-2 flex-grow-1 overflow-auto"></span>
                        <img class="thumb_img" src="/images/noImg.jpg" />
                        <a href="" class="btn_link d-flex bg-transparent border-0 p-0 d-none" target="_blank" title="開啟檔案">
                            <span class="icon poiter  material-symbols-outlined">search</span>
                        </a>
                        <button class="btn_lock d-flex bg-transparent border-0 p-0" title="是否加密">
                            <span class="icon poiter lock material-symbols-outlined">lock</span>
                            <span class="icon poiter unlock material-symbols-outlined">lock_open_right</span>
                        </button>
                        <button class="btn_remove d-flex bg-transparent border-0 p-0" title="移除檔案">
                            <span class="icon poiter  material-symbols-outlined">delete</span>
                        </button>
                    </li>
                </template>
            </form>
        </div>
    </div>
    
</div>

<!-- Directory Facet Config Modal -->
<div class="modal fade" id="facetModal" tabindex="-1" aria-labelledby="facetModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="facetModalLabel">目錄再分類（Facet）設定</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- DirectoryId -->
                <input type="hidden" id="facetDirectoryId" name="DirectoryId" value="" />

                <!-- 1) 分類方式設定 -->
                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <label for="facetType" class="form-label">分類型別</label>
                        <select class="form-select" id="facetType" name="FacetType" data-role="facet-type">
                            <option value="0">不分類</option>
                            <option value="10">依年份</option>
                        </select>
                    </div>

                    <!-- 2) 年份顯示方式（僅 Year 顯示） -->
                    <div class="col-12 col-lg-6" id="facetCalendarTypeWrap" data-section="calendar-type">
                        <label class="form-label mb-2">年份顯示方式</label>

                        <div class="d-flex flex-wrap gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="CalendarType" id="calendarAD" value="1" checked>
                                <label class="form-check-label" for="calendarAD">西元年</label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="CalendarType" id="calendarROC" value="2">
                                <label class="form-check-label" for="calendarROC">民國年</label>
                            </div>
                        </div>

                        <div class="form-text">
                            僅影響顯示與輸入；資料庫永遠存西元年（int）。
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <!-- 3) 分類區間設定 -->
                <div id="facetRangesWrap" data-section="ranges">
                    <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                        <div>
                            <h6 class="mb-1">分類區間</h6>
                            <div class="text-muted small">
                                不允許重疊、允許缺口；可拖曳調整順序。
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="facetBtnSortNatural">
                                依自然時間排序
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" id="facetBtnAddRange">
                                新增區間
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:48px;" class="text-center">序</th>
                                    <th style="width:56px;" class="text-center">拖曳</th>
                                    <th style="width:160px;">起始（Start）</th>
                                    <th style="width:160px;">結束（End）</th>
                                    <th style="width:96px;" class="text-center">啟用</th>
                                    <th style="width:96px;" class="text-center">刪除</th>
                                </tr>
                            </thead>

                            <tbody id="facetRangesTbody" data-role="ranges-sortable"></tbody>
                        </table>
                    </div>

                    <!-- empty state -->
                    <div class="border rounded-3 p-3 mt-2 text-muted small d-none" id="facetRangesEmpty">
                        尚未設定任何區間，請按「新增區間」。
                    </div>
                </div>
                <!-- error box -->
                <div class="alert alert-danger mt-3 d-none" id="facetErrorBox"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="facetBtnSave">儲存</button>
            </div>

        </div>
    </div>
</div>

<!-- ===== Row Template for JS ===== -->
<template id="facetRangeRowTemplate">
    <tr data-range-row>
        <td class="text-center">
            <span class="badge text-bg-secondary" data-role="range-order"></span>
            <input type="hidden" data-field="Sort" />
        </td>

        <td class="text-center">
            <span class="text-muted" style="cursor:grab;" data-role="drag-handle">☰</span>
        </td>

        <td>
            <input type="hidden" data-field="Id" />
